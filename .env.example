# Copiá a .env.local y completá los valores. No commitees secretos.

# Demo menú digital (remix-of-personal-blog) — en dev, el catálogo enlaza a este origen para la tarjeta correspondiente
# PUBLIC_DEMO_LANDING_URL=http://localhost:5173

# Template PYME (repo template-pyme) — base para resolver demoUrl `/servicios` y `/productos`
# Producción (Vercel):
# PUBLIC_TEMPLATE_PYME_URL=https://template-pyme.escalatunegocioconia.com
# Desarrollo local (el template Vite usa puerto 5174 por defecto; ver ese repo vite.config.ts):
# PUBLIC_TEMPLATE_PYME_URL=http://localhost:5174
