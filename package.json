{
  "name": "nh-portfolio",
  "type": "module",
  "version": "1.0.0",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "test": "node --import tsx --test ./schemas/index.test.ts ./src/lib/faq-jsonld.test.ts ./lib/chat-origin-allowlist.test.js",
    "check": "astro sync && astro check && tsc --noEmit -p .",
    "lint": "prettier --check . && npm run lint:no-raw-hex",
    "lint:no-raw-hex": "node scripts/check-no-raw-hex.mjs",
    "typecheck": "npm run check",
    "prepare": "husky"
  },
  "dependencies": {
    "@astrojs/mdx": "4.3.14",
    "@astrojs/sitemap": "^3.7.2",
    "@astrojs/tailwind": "5.1.5",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/outfit": "^5.2.8",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "astro": "5.18.1",
    "tailwindcss": "^3.4.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.2",
    "@google-cloud/text-to-speech": "^6.4.0",
    "@types/node": "^25.5.0",
    "eslint": "^10.2.0",
    "eslint-plugin-astro": "^1.7.0",
    "gray-matter": "^4.0.3",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.2",
    "prettier-plugin-astro": "^0.14.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.2"
  },
  "lint-staged": {
    "**/*.{js,jsx,ts,tsx,astro}": [
      "eslint --no-error-on-unmatched-pattern --fix",
      "prettier --write"
    ],
    "**/*.{json,md,mdx,css}": [
      "prettier --write"
    ]
  }
}
