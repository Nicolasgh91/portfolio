---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import HeroSection from '../components/HeroSection.astro';
import { getCollection } from 'astro:content';

// Obtener proyectos featured, ordenados
const allProjects = await getCollection('projects');
const featuredProjects = allProjects
  .filter((p) => p.data.featured)
  .sort((a, b) => a.data.order - b.data.order);
---

<Layout
  title="Nicolás Hruszczak — Software, IA y automatización para empresas"
  description="Desarrollo full stack, análisis funcional e implementación de IA para empresas y pymes que buscan resultados medibles. Diagnóstico gratuito."
  ogImage="/og-desktop.png"
>
  <Nav activePage="home" />

  <main id="main-content">
    <HeroSection />
    <div class="page-container">

      <!-- ── Stats bar ─────────────────────────────────────── -->
      <div class="stats-bar hidden" role="list" aria-label="Estadísticas">
        <div class="stat-item" role="listitem">
          <div class="stat-num">3+</div>
          <div
            class="stat-label"
            data-en="Years in full stack development"
            data-es="Años en desarrollo de soluciones de productos tecnológicos"
          >Años en desarrollo de soluciones de productos tecnológicos</div>
        </div>
        <div class="stat-item" role="listitem">
          <div class="stat-num">{allProjects.length}</div>
          <div
            class="stat-label"
            data-en="Active engineering projects"
            data-es="Proyectos de ingeniería activos"
          >Proyectos de ingeniería activos</div>
        </div>
        <div class="stat-item" role="listitem">
          <div class="stat-num">∞</div>
          <div
            class="stat-label"
            data-en="AI agent expertise"
            data-es="Dominio de agentes de IA"
          >Dominio de agentes de IA</div>
        </div>
      </div>

      <!-- ── Split CTA ──────────────────────────────────────── -->
      <nav class="split-cta" aria-label="Rutas de navegación">
        <a href="/servicios" class="btn-tertiary split-cta__cell p-0">
          <h2>
            <span aria-hidden="true">📊</span>
            <span
              data-en="For businesses &amp; SMEs"
              data-es="Para empresas y pymes"
            >Para empresas y pymes</span>
          </h2>
          <p
            data-en="Diagnosis, proposal and execution. Fixed cost reduction, process automation, and proprietary management systems."
            data-es="Diagnóstico, propuesta y ejecución. Reducción de costos fijos, automatización de procesos y sistemas de gestión propietarios."
          >Diagnóstico, propuesta y ejecución. Reducción de costos fijos, automatización de procesos y sistemas de gestión propietarios.</p>
          <span
            class="split-cta-arrow"
            data-en="Explore services →"
            data-es="Explorar servicios →"
          >Explorar servicios →</span>
        </a>

        <a href="/talento" class="btn-tertiary split-cta__cell p-0">
          <h2>
            <span aria-hidden="true">💼</span>
            <span
              data-en="For recruiters"
              data-es="Para reclutadores"
            >Para reclutadores</span>
          </h2>
          <p
            data-en="Functional analyst, full stack developer and software architect. Updated stack, AI expertise and agile methodologies."
            data-es="Analista funcional, desarrollador full stack y arquitecto de software. Stack actualizado, experiencia en IA y metodologías ágiles."
          >Analista funcional, desarrollador full stack y arquitecto de software. Stack actualizado, experiencia en IA y metodologías ágiles.</p>
          <span
            class="split-cta-arrow"
            data-en="View technical profile →"
            data-es="Ver perfil técnico →"
          >Ver perfil técnico →</span>
        </a>
      </nav>

      <div class="divider"></div>

      <!-- ── Proyectos recientes (dinámico) ────────────────── -->
      <section class="section" aria-labelledby="projects-heading">
        <div class="section-header">
          <span
            class="label"
            data-en="Projects"
            data-es="Proyectos"
          >Proyectos</span>
          <h2
            id="projects-heading"
            data-en="Recent work"
            data-es="Trabajo reciente"
          >Trabajo reciente</h2>
        </div>

        <div class="grid-2">
          {featuredProjects.map((project) => (
            <article class="project-card">
              <div class="project-header">
                <h3 style="display: flex; align-items: center; justify-content: center; gap: 8px;">
                  <span aria-hidden="true" style="font-size:20px">{project.data.icon}</span>
                  {project.data.title}
                </h3>
                {project.data.url && (
                  <a
                    href={project.data.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="project-url"
                  >{project.data.url.replace('http://', '').replace('https://', '')}&nbsp;↗</a>
                )}
                {project.data.status === 'in-progress' && (
                  <span class="tag tag-accent" style="font-size:10px">
                    <span data-en="In progress" data-es="En progreso">En progreso</span>
                  </span>
                )}
              </div>

              <p
                data-en={project.data.descriptionEn}
                data-es={project.data.description}
              >{project.data.description}</p>

              <div class="tags">
                <a href={`/talento#${project.slug}`} class="tag tag-accent"
                  data-en="View project →"
                  data-es="Ver proyecto →"
                >Ver proyecto →</a>
              </div>
            </article>
          ))}
        </div>

        <!-- Enlace al blog técnico -->
        <div style="text-align:center; margin-top: var(--sp-lg);">
          <a href="/blog" class="btn-secondary"
            data-en="Read technical articles →"
            data-es="Leer artículos técnicos →"
          >Leer artículos técnicos →</a>
        </div>
      </section>

    </div>
  </main>

</Layout>

<style>
  .cta-row > a {
    flex: 1;
    min-width: 250px;
    max-width: 320px;
    justify-content: center;
    text-align: center;
  }

  .stats-bar {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    border: 0.5px solid var(--border-normal);
    border-radius: var(--radius-lg);
    overflow: hidden;
    margin-bottom: var(--sp-xl);
  }
  /* Scoped `display:grid` beats global Tailwind `.hidden`. */
  .stats-bar.hidden {
    display: none;
  }
  @media (max-width: 480px) {
    .stats-bar { grid-template-columns: 1fr; }
  }
  .stat-item {
    padding: var(--sp-lg);
    text-align: center;
    border-right: 0.5px solid var(--border-normal);
  }
  .stat-item:last-child { border-right: none; }
  @media (max-width: 480px) {
    .stat-item { border-right: none; border-bottom: 0.5px solid var(--border-normal); }
    .stat-item:last-child { border-bottom: none; }
  }
  .stat-num {
    font-family: var(--font-display);
    font-size: calc(var(--text-2xl) * var(--font-scale));
    font-weight: 800;
    color: var(--accent);
    letter-spacing: -1px;
    line-height: 1;
  }
  .stat-label {
    font-size: var(--text-xs);
    color: var(--text-secondary);
    margin-top: 6px;
  }

  .split-cta {
    display: grid;
    grid-template-columns: 1fr 1fr;
    border: 0.5px solid var(--border-normal);
    border-radius: var(--radius-lg);
    overflow: hidden;
  }
  @media (max-width: 560px) { .split-cta { grid-template-columns: 1fr; } }
  .split-cta__cell {
    padding: var(--sp-lg);
    cursor: pointer;
    text-decoration: none;
    display: flex;
    flex-direction: column;
    height: 100%;
    align-items: center;
    text-align: center;
    width: 100%;
    transition: background 0.15s ease;
  }
  .split-cta__cell:hover {
    background: var(--accent-bg);
  }
  .split-cta__cell:first-child { border-right: 0.5px solid var(--border-normal); }
  @media (max-width: 560px) {
    .split-cta__cell:first-child { border-right: none; border-bottom: 0.5px solid var(--border-normal); }
  }
  .split-cta__cell h2 { display: flex; align-items: center; justify-content: center; gap: var(--sp-sm); margin-bottom: var(--sp-sm); font-size: calc(var(--text-lg) * var(--font-scale)); letter-spacing: -0.4px; color: var(--text-primary); font-family: var(--font-display); }
  .split-cta__cell p { font-size: var(--text-sm); line-height: 1.65; margin-bottom: var(--sp-md); flex: 1; display: flex; align-items: center; justify-content: center; color: var(--text-secondary); }
  .split-cta-arrow { font-size: var(--text-sm); color: var(--accent); margin-top: auto; }

  .project-card {
    background: var(--bg-card);
    border: 0.5px solid var(--border-subtle);
    border-radius: var(--radius-lg);
    padding: var(--sp-lg);
    transition: border-color 0.15s ease;
    display: flex;
    flex-direction: column;
    height: 100%;
    align-items: center;
    text-align: center;
  }
  .project-card:hover { border-color: var(--border-normal); }
  .project-header {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--sp-xs);
    margin-bottom: var(--sp-sm);
  }
  .project-header h3 { margin-bottom: 0; }
  .project-url { font-size: var(--text-xs); color: var(--text-muted); }
  .project-url:hover { color: var(--accent); }
  .project-card p { font-size: var(--text-sm); flex: 1; display: flex; align-items: center; justify-content: center; margin-bottom: var(--sp-sm); }
  .project-card .tags { margin-top: auto; justify-content: center; width: 100%; }

</style>
