---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import HeroSection from '../components/HeroSection.astro';
import SectionWrapper from '../components/SectionWrapper.astro';
import SectionLabel from '../components/SectionLabel.astro';
import ProjectCard from '../components/ProjectCard.astro';
import MetricDisplay from '../components/MetricDisplay.astro';
import CTAButton from '../components/CTAButton.astro';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('projects');
const featuredProjects = allProjects
  .filter((p) => p.data.featured)
  .sort((a, b) => a.data.order - b.data.order);
---

<Layout
  title="Nicolás Hruszczak — Software, IA y automatización para empresas"
  description="Desarrollo full stack, análisis funcional e implementación de IA para empresas y pymes que buscan resultados medibles. Diagnóstico gratuito."
  ogImage="/og-desktop.png"
>
  <Nav activePage="home" />

  <main id="main-content">
    <HeroSection />

    <SectionWrapper bg="bg-white" tone="default" padding="py-24 md:py-32" revealAlt>
      <nav class="grid gap-6 md:grid-cols-2 md:gap-8" aria-label="Rutas de navegación">
        <a
          href="/servicios"
          class="flex flex-col rounded-2xl border border-slate-200/80 bg-slate-50/50 p-8 transition-colors hover:border-orange-200 hover:bg-orange-50/30 md:p-10"
        >
          <h2 class="font-display text-2xl font-semibold tracking-tight text-slate-900">
            <span data-es>Para empresas y pymes</span>
            <span data-en class="hidden">For businesses &amp; SMEs</span>
          </h2>
          <p class="mt-4 flex-1 text-base leading-relaxed text-slate-600">
            <span data-es
              >Diagnóstico, propuesta y ejecución. Reducción de costos fijos, automatización de procesos y sistemas de
              gestión propietarios.</span
            >
            <span data-en class="hidden"
              >Diagnosis, proposal and execution. Fixed cost reduction, process automation, and proprietary management
              systems.</span
            >
          </p>
          <span class="mt-6 inline-flex items-center gap-1 text-sm font-semibold text-orange-600">
            <span data-es>Explorar servicios →</span>
            <span data-en class="hidden">Explore services →</span>
          </span>
        </a>

        <a
          href="/talento"
          class="flex flex-col rounded-2xl border border-slate-200/80 bg-slate-50/50 p-8 transition-colors hover:border-orange-200 hover:bg-orange-50/30 md:p-10"
        >
          <h2 class="font-display text-2xl font-semibold tracking-tight text-slate-900">
            <span data-es>Para reclutadores</span>
            <span data-en class="hidden">For recruiters</span>
          </h2>
          <p class="mt-4 flex-1 text-base leading-relaxed text-slate-600">
            <span data-es
              >Analista funcional, desarrollador full stack y arquitecto de software. Stack actualizado, experiencia en
              IA y metodologías ágiles.</span
            >
            <span data-en class="hidden"
              >Functional analyst, full stack developer and software architect. Current stack, AI expertise and agile
              practices.</span
            >
          </p>
          <span class="mt-6 inline-flex items-center gap-1 text-sm font-semibold text-orange-600">
            <span data-es>Ver perfil técnico →</span>
            <span data-en class="hidden">View technical profile →</span>
          </span>
        </a>
      </nav>
    </SectionWrapper>

    <SectionWrapper bg="bg-slate-950" tone="dark" padding="py-24 md:py-32" revealAlt>
      <header class="mb-12 md:mb-16">
        <SectionLabel text="Proyectos" textEn="Projects" />
        <h2 class="mt-3 font-display text-3xl font-bold tracking-tight text-white md:text-4xl">
          <span data-es>Trabajo reciente</span>
          <span data-en class="hidden">Recent work</span>
        </h2>
      </header>

      <div class="grid grid-cols-1 gap-6 md:grid-cols-3 md:gap-8">
        {
          featuredProjects.map((project) => (
            <ProjectCard
              title={project.data.title}
              titleEn={project.data.title}
              description={project.data.description}
              descriptionEn={project.data.descriptionEn}
              image={project.data.coverImage}
              href={
                project.data.url
                  ? project.data.url
                  : project.slug === 'huelladelfuego'
                    ? '/blog/caso-huelladelfuego'
                    : `/talento#${project.slug}`
              }
              badge={project.data.status === 'in-progress' ? 'En progreso' : undefined}
              badgeEn={project.data.status === 'in-progress' ? 'In progress' : undefined}
              span={project.slug === 'huelladelfuego' ? 2 : 1}
              external={Boolean(project.data.url)}
            />
          ))
        }
      </div>

      <div class="mt-12 text-center md:mt-16">
        <a
          href="/blog"
          class="btn-secondary inline-flex"
          data-en="Read technical articles →"
          data-es="Leer artículos técnicos →"
        >
          Leer artículos técnicos →
        </a>
      </div>
    </SectionWrapper>

    <SectionWrapper bg="bg-slate-50" tone="default" padding="py-24 md:py-32" revealAlt>
      <div class="grid grid-cols-1 gap-12 md:grid-cols-3 md:gap-8">
        <MetricDisplay
          value="+11"
          label="empresas acompañadas"
          labelEn="companies served"
        />
        <MetricDisplay
          value="−40%"
          label="reducción típica de costos fijos"
          labelEn="typical fixed-cost reduction"
        />
        <MetricDisplay value="24/7" label="disponibilidad IA en producción" labelEn="AI uptime in production" />
      </div>
    </SectionWrapper>

    <div class="px-6 pb-24 md:pb-32">
      <SectionWrapper
        bg="bg-orange-600"
        tone="accent"
        padding="py-16 md:py-20"
        maxWidth="max-w-4xl"
        class="rounded-3xl"
        innerClass="text-center"
        revealAlt
      >
        <h2 class="font-display text-2xl font-bold text-white md:text-3xl">
          <span data-es>Agendá una reunión sin compromiso</span>
          <span data-en class="hidden">Book a no-obligation call</span>
        </h2>
        <p class="mx-auto mt-4 max-w-xl text-base text-white/90">
          <span data-es>Revisamos su operación y le decimos en 48 h si tiene sentido avanzar con un diagnóstico formal.</span
          >
          <span data-en class="hidden"
            >We review your operations and tell you within 48 hours whether a formal diagnosis makes sense.</span
          >
        </p>
        <div class="mt-8 flex justify-center">
          <CTAButton
            href="/servicios#contacto"
            label="Agenda una reunión"
            labelEn="Schedule a meeting"
            variant="inverse"
          />
        </div>
      </SectionWrapper>
    </div>
  </main>
</Layout>
