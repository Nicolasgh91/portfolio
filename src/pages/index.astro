---
import { Image } from "astro:assets";
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import HeroSection from "../components/HeroSection.astro";
import SectionWrapper from "../components/SectionWrapper.astro";
import SectionLabel from "../components/SectionLabel.astro";
import ProjectCard from "../components/ProjectCard.astro";
import MetricDisplay from "../components/MetricDisplay.astro";
import { getCollection } from "astro:content";
import { landingTemplates } from "../data/landing-templates";
import type { LandingTemplate } from "../schemas";
import { getTemplateCarouselImage } from "../data/template-carousel-images";
import { resolveTemplateDemoUrl } from "../lib/resolve-template-demo-url";
import { localeFromPathname } from "../lib/locale-path";

const isEnglish = localeFromPathname(Astro.url.pathname) === "en";
const servicesHref = isEnglish ? "/en/services" : "/servicios";
const talentHref = isEnglish ? "/en/talent" : "/talento";
const blogHref = isEnglish ? "/en/blog" : "/blog";

const allProjects = await getCollection("projects");
const featuredProjects = allProjects
  .filter((p) => p.data.featured)
  .sort((a, b) => a.data.order - b.data.order);

const templatePymeBase =
  import.meta.env.PUBLIC_TEMPLATE_PYME_URL ??
  "https://template-pyme.escalatunegocioconia.com";

const templatesWithResolvedDemo = landingTemplates
  .filter((t) => t.status === "available")
  .map((t) => ({
    template: t,
    demoUrl: resolveTemplateDemoUrl(t, templatePymeBase),
  }))
  .filter(
    (x): x is { template: LandingTemplate; demoUrl: string } =>
      x.demoUrl !== null,
  )
  .sort((a, b) => b.template.priority - a.template.priority);
---

<Layout
  title="Nicolás Hruszczak — Software, IA y automatización para empresas"
  description="Desarrollo full stack, análisis funcional e implementación de IA para empresas y pymes que buscan resultados medibles. Diagnóstico gratuito."
  titleEn="Nicolás Hruszczak — Software, AI and automation for businesses"
  descriptionEn="Full stack development, functional analysis, and AI implementation for companies and SMEs that need measurable outcomes. Free diagnosis."
  ogImage="/og-desktop.png"
>
  <Nav activePage="home" />

  <main id="main-content">
    <HeroSection />

    <SectionWrapper
      tone="default"
      padding="py-24 md:py-32"
      revealAlt
      revealDelayMs={0}
    >
      <nav
        class="grid gap-6 md:grid-cols-2 md:gap-8"
        aria-label={isEnglish ? "Navigation routes" : "Rutas de navegación"}
      >
        <a
          href={servicesHref}
          class="btn-bounce flex flex-col gap-5 rounded-2xl border border-[var(--border-normal)] border-l-4 border-l-[var(--color-accent-600)] bg-[var(--bg-secondary)] p-6 transition-transform duration-200 hover:-translate-y-1 hover:bg-[var(--bg-tertiary)] md:p-8"
        >
          <h2
            class="font-display text-xl font-semibold tracking-tight text-[var(--text-primary)]"
          >
            <span data-es>Para empresas y pymes</span>
            <span data-en class="hidden">For businesses &amp; SMEs</span>
          </h2>
          <p class="text-base leading-relaxed text-[var(--text-secondary)]">
            <span data-es
              >Diagnóstico, propuesta y ejecución. Reducción de costos fijos,
              automatización de procesos y sistemas de gestión propietarios.</span
            >
            <span data-en class="hidden"
              >Diagnosis, proposal and execution. Fixed cost reduction, process
              automation, and proprietary management systems.</span
            >
          </p>
          <span
            class="mt-2 inline-flex items-center gap-2 text-sm font-semibold text-[var(--accent)] md:mt-3"
          >
            <span data-es>Explorar servicios</span>
            <span data-en class="hidden">Explore services</span>
            <span class="arrow" aria-hidden="true">
              <svg
                class="h-4 w-4"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M5 12h14M13 5l7 7-7 7"></path>
              </svg>
            </span>
          </span>
        </a>

        <a
          href={talentHref}
          class="btn-bounce flex flex-col gap-5 rounded-2xl border border-[var(--border-normal)] border-l-4 border-l-[var(--text-muted)] bg-[var(--bg-secondary)] p-6 transition-transform duration-200 hover:-translate-y-1 hover:bg-[var(--bg-tertiary)] md:p-8"
        >
          <h2
            class="font-display text-xl font-semibold tracking-tight text-[var(--text-primary)]"
          >
            <span data-es>Para reclutadores</span>
            <span data-en class="hidden">For recruiters</span>
          </h2>
          <p class="text-base leading-relaxed text-[var(--text-secondary)]">
            <span data-es
              >Analista funcional, desarrollador full stack y arquitecto de
              software. Stack actualizado, experiencia en IA y metodologías
              ágiles.</span
            >
            <span data-en class="hidden"
              >Functional analyst, full stack developer and software architect.
              Current stack, AI expertise and agile practices.</span
            >
          </p>
          <span
            class="mt-2 inline-flex items-center gap-2 text-sm font-semibold text-[var(--accent)] md:mt-3"
          >
            <span data-es>Ver perfil técnico</span>
            <span data-en class="hidden">View technical profile</span>
            <span class="arrow" aria-hidden="true">
              <svg
                class="h-4 w-4"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M5 12h14M13 5l7 7-7 7"></path>
              </svg>
            </span>
          </span>
        </a>
      </nav>
    </SectionWrapper>

    <SectionWrapper
      bg="bg-slate-950"
      tone="dark"
      padding="py-24 md:py-32"
      revealAlt
      revealDelayMs={100}
    >
      <header class="mb-12 md:mb-16">
        <SectionLabel text="Proyectos" textEn="Projects" />
        <h2
          class="mt-3 font-display text-3xl font-bold tracking-tight text-white md:text-4xl"
        >
          <span data-es>Trabajo reciente</span>
          <span data-en class="hidden">Recent work</span>
        </h2>
      </header>

      <div class="flex flex-col gap-6 md:gap-8">
        {
          featuredProjects.map((project, i) => (
            <ProjectCard
              headingId={`project-card-${project.slug}`}
              direction={i % 2 === 0 ? "left" : "right"}
              title={project.data.title}
              titleEn={project.data.title}
              description={project.data.description}
              descriptionEn={project.data.descriptionEn}
              coverPosition={project.data.coverPosition}
              image={project.data.coverImage}
              tags={project.data.tags}
              href={
                project.data.url
                  ? project.data.url
                  : project.slug === "huelladelfuego"
                    ? "/blog/caso-huelladelfuego"
                    : `/talento#${project.slug}`
              }
              badge={
                project.data.status === "live"
                  ? "En producción"
                  : project.data.status === "in-progress"
                    ? "En progreso"
                    : undefined
              }
              badgeEn={
                project.data.status === "live"
                  ? "Live"
                  : project.data.status === "in-progress"
                    ? "In progress"
                    : undefined
              }
              badgeVariant={
                project.data.status === "live" ? "live" : "in-progress"
              }
              external={Boolean(project.data.url)}
            />
          ))
        }
      </div>

      <div class="mt-12 text-center md:mt-16">
        <a
          href={blogHref}
          class="btn-secondary btn-bounce inline-flex items-center gap-1.5"
        >
          <span data-es>Leer artículos técnicos</span>
          <span data-en class="hidden">Read technical articles</span>
          <span class="arrow" aria-hidden="true">→</span>
        </a>
      </div>
    </SectionWrapper>

    <SectionWrapper
      bg="bg-[var(--bg-secondary)]"
      tone="default"
      padding="py-24 md:py-32"
      revealAlt
      revealDelayMs={200}
    >
      <header class="mb-12 md:mb-16">
        <SectionLabel
          text="Impacto"
          textEn="Impact"
          colorClass="text-[var(--accent)]"
        />
        <h2
          class="mt-3 font-display text-3xl font-bold tracking-tight text-[var(--text-primary)] md:text-4xl"
        >
          <span data-es>Métricas de impacto</span>
          <span data-en class="hidden">Impact metrics</span>
        </h2>
      </header>
      <div class="grid grid-cols-1 gap-12 md:grid-cols-3 md:gap-8">
        <MetricDisplay
          value="+11"
          label="empresas acompañadas"
          labelEn="companies served"
        />
        <MetricDisplay
          value="−40%"
          label="reducción típica de costos fijos"
          labelEn="typical fixed-cost reduction"
        />
        <MetricDisplay
          value="24/7"
          label="disponibilidad IA en producción"
          labelEn="AI uptime in production"
        />
      </div>
    </SectionWrapper>

    {
      templatesWithResolvedDemo.length > 0 && (
        <SectionWrapper
          tone="default"
          padding="py-24 md:py-32"
          revealAlt
          revealDelayMs={250}
        >
          <header class="mb-10 md:mb-12">
            <SectionLabel
              text="Proyectos web"
              textEn="Web projects"
              colorClass="text-[var(--accent)]"
            />
            <h2 class="mt-3 font-display text-3xl font-bold tracking-tight text-[var(--text-primary)] md:text-4xl">
              <span data-es>Sitios que ya están en producción</span>
              <span data-en class="hidden">
                Sites already in production
              </span>
            </h2>
            <p class="mt-2 max-w-2xl text-sm text-[var(--text-secondary)]">
              <span data-es>
                Recorré los proyectos web que nuestros clientes usan todos los
                días.
              </span>
              <span data-en class="hidden">
                Browse the web projects our clients use every day.
              </span>
            </p>
          </header>

          <div
            class="flex snap-x snap-mandatory gap-4 overflow-x-auto pb-2 [-ms-overflow-style:none] [scrollbar-width:none] md:grid md:grid-cols-3 md:gap-8 md:overflow-visible md:snap-none [&::-webkit-scrollbar]:hidden"
            role="list"
            aria-label="Proyectos web"
          >
            {templatesWithResolvedDemo.map(({ template, demoUrl }) => {
              const thumb = getTemplateCarouselImage(template.slug);
              const external = /^https?:\/\//i.test(demoUrl);
              return (
                <article
                  class="w-[min(280px,86vw)] shrink-0 snap-start md:w-auto"
                  role="listitem"
                >
                  <a
                    href={demoUrl}
                    class="group btn-bounce flex flex-col"
                    {...(external
                      ? { target: "_blank", rel: "noopener noreferrer" }
                      : {})}
                  >
                    <div class="aspect-video overflow-hidden rounded-xl border border-[var(--border-normal)] bg-[var(--bg-tertiary)]">
                      {thumb ? (
                        <Image
                          src={thumb}
                          alt=""
                          width={640}
                          height={360}
                          sizes="(min-width: 768px) 30vw, 86vw"
                          class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-[1.02] motion-reduce:transition-none motion-reduce:group-hover:scale-100"
                        />
                      ) : (
                        <div class="flex h-full w-full items-center justify-center bg-[var(--bg-tag)] text-xs font-medium text-[var(--text-muted)]">
                          <span data-es>Vista previa</span>
                          <span data-en class="hidden">
                            Preview
                          </span>
                        </div>
                      )}
                    </div>
                    <h3 class="mt-3 font-display text-base font-semibold tracking-tight text-[var(--text-primary)]">
                      <span data-es>{template.title}</span>
                      <span data-en class="hidden">
                        {template.titleEn}
                      </span>
                    </h3>
                    <span class="mt-2 inline-flex items-center gap-1.5 text-sm font-semibold text-[var(--accent)]">
                      <span data-es>Ir al sitio</span>
                      <span data-en class="hidden">
                        Visit site
                      </span>
                      <span class="arrow" aria-hidden="true">
                        →
                      </span>
                    </span>
                  </a>
                </article>
              );
            })}
          </div>
        </SectionWrapper>
      )
    }
  </main>
</Layout>
