---
import { Fragment } from "astro/jsx-runtime";
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import PageHeroSection from "../components/PageHeroSection.astro";
import SectionWrapper from "../components/SectionWrapper.astro";
import ProjectCard from "../components/ProjectCard.astro";
import LiquidGlassMarquee from "../components/LiquidGlassMarquee.astro";
import { getCollection } from "astro:content";
import bannerTalentoNaranja from "../assets/talento/banner-talento-naranja.webp";
import { localeFromPathname } from "../lib/locale-path";

const GITHUB_REPOS_URL = "https://github.com/Nicolasgh91?tab=repositories";
const isEnglish = localeFromPathname(Astro.url.pathname) === "en";
const talentHref = isEnglish ? "/en/talent" : "/talento";
const servicesContactHref = isEnglish
  ? "/en/services#contacto"
  : "/servicios#contacto";

const allProjects = await getCollection("projects");
const sortedProjects = allProjects.sort((a, b) => a.data.order - b.data.order);

function statusLabel(status: string, lang = "es") {
  const map: Record<string, { es: string; en: string }> = {
    live: { es: "En producción", en: "Live" },
    "in-progress": { es: "En progreso", en: "In progress" },
    completed: { es: "Completado", en: "Completed" },
  };
  return map[status]?.[lang as "es" | "en"] ?? status;
}

const capabilities = [
  {
    title: "Arquitectura de agentes IA",
    titleEn: "AI agent architecture",
    description:
      "Diseño de sistemas multi-agente con memoria persistente, herramientas y planificación autónoma.",
    descriptionEn:
      "Design of multi-agent systems with persistent memory, tools and autonomous planning.",
  },
  {
    title: "Infraestructura y DevOps",
    titleEn: "Infrastructure & DevOps",
    description:
      "Despliegue de servicios en cloud y on-premise, CI/CD, contenedores y monitoreo de producción.",
    descriptionEn:
      "Cloud and on-premise service deployment, CI/CD, containers and production monitoring.",
  },
  {
    title: "Sistemas geoespaciales",
    titleEn: "Geospatial systems",
    description:
      "Análisis y visualización de datos geográficos integrados en plataformas de gestión operativa.",
    descriptionEn:
      "Analysis and visualization of geographic data integrated into operational management platforms.",
  },
];

const softSkills = [
  {
    title: "Comunicación efectiva",
    titleEn: "Effective communication",
    description:
      "Síntesis clara entre contexto técnico y negocio, y documentación acorde a cada audiencia.",
    descriptionEn:
      "Clear synthesis between technical and business context, with documentation suited to each audience.",
  },
  {
    title: "Liderazgo técnico",
    titleEn: "Technical leadership",
    description:
      "Dirección de decisiones de arquitectura, priorización y calidad sin perder velocidad de entrega.",
    descriptionEn:
      "Guiding architecture choices, prioritization, and quality without sacrificing delivery speed.",
  },
  {
    title: "Mentoría y facilitación",
    titleEn: "Mentoring and facilitation",
    description:
      "Acompañamiento a perfiles en formación y dinámicas que alinean al equipo en objetivos comunes.",
    descriptionEn:
      "Support for early-career profiles and facilitation that keeps teams aligned on shared goals.",
  },
  {
    title: "Resolución de conflictos",
    titleEn: "Conflict resolution",
    description:
      "Negociación empática y foco en acuerdos accionables cuando hay tensión técnica u operativa.",
    descriptionEn:
      "Empathetic negotiation and actionable agreements when technical or operational tension arises.",
  },
  {
    title: "Pensamiento sistémico",
    titleEn: "Systems thinking",
    description:
      "Visión integral de dependencias, riesgos y efectos colaterales antes de comprometer cambios.",
    descriptionEn:
      "Holistic view of dependencies, risks, and side effects before committing to change.",
  },
  {
    title: "Gestión de stakeholders",
    titleEn: "Stakeholder management",
    description:
      "Expectativas alineadas, seguimiento de compromisos y comunicación predecible con negocio.",
    descriptionEn:
      "Aligned expectations, commitment tracking, and predictable communication with the business.",
  },
];
---

<Layout
  title="Perfil profesional — Nicolás Hruszczak"
  description="Analista funcional, desarrollador full stack y arquitecto de software. Stack: Python, Astro, Next.js. Especialización en agentes de IA e ingeniería de contexto."
  titleEn="Professional Profile — Nicolás Hruszczak"
  descriptionEn="Functional analyst, full stack developer, and software architect. Stack: Python, Astro, Next.js. Specialized in AI agents and context engineering."
  ogImage="/og-desktop.png"
>
  <Nav activePage="talento" />

  <main id="main-content">
    <PageHeroSection
      image={bannerTalentoNaranja}
      alt={isEnglish
        ? "Warm orange visual banner for the professional profile page."
        : "Banner visual cálido en tonos naranja para la página de perfil profesional."}
      imageWidth={1671}
      imageHeight={940}
      headingId="talento-hero-heading"
      labelText="Analista funcional · Desarrollador full-stack · Arquitecto de software"
      labelTextEn="Functional analyst · Full-stack developer · Software architect"
    >
      <Fragment slot="heading">Nicolás Hruszczak</Fragment>
      <p>
        {
          isEnglish ? (
            <>
              Analyst-developer of{" "}
              <em class="not-italic text-[var(--accent-text)]">
                full-stack or functional solutions
              </em>{" "}
              for any software application.{" "}
              <em class="not-italic text-[var(--accent-text)]">
                Analysis of needs and pain points
              </em>
              , with{" "}
              <em class="not-italic text-[var(--accent-text)]">
                efficient improvement proposals
              </em>{" "}
              aligned with the agreed scope.{" "}
              <em class="not-italic text-[var(--accent-text)]">
                Clear communication with business and stakeholders
              </em>
              , mentoring for early-career profiles and product judgment to
              prioritize high-impact delivery.
            </>
          ) : (
            <>
              Analista desarrollador de{" "}
              <em class="not-italic text-[var(--accent-text)]">
                soluciones full stack o funcionales
              </em>{" "}
              para cualquier aplicación de Software.{" "}
              <em class="not-italic text-[var(--accent-text)]">
                Análisis de necesidades y puntos de dolor
              </em>
              , con{" "}
              <em class="not-italic text-[var(--accent-text)]">
                propuestas de mejora eficientes
              </em>{" "}
              y acorde al alcance establecido.{" "}
              <em class="not-italic text-[var(--accent-text)]">
                Comunicación clara con negocio y stakeholders
              </em>
              , mentoría a perfiles en formación y criterio de producto para
              priorizar entregas con impacto.
            </>
          )
        }
      </p>
      <div class="mt-8 flex justify-center md:justify-start">
        <a
          href={GITHUB_REPOS_URL}
          class="btn-secondary border-white/20 bg-white/5 text-white hover:border-white/35 hover:bg-white/10"
          target="_blank"
          rel="noopener noreferrer"
          aria-label={isEnglish
            ? "View GitHub repositories"
            : "Ver repositorios en GitHub"}
          data-en="GitHub repositories"
          data-es="Repositorios en GitHub"
        >
          Repositorios en GitHub
        </a>
      </div>
    </PageHeroSection>

    <div class="page-container">
      <section
        class="mb-16 rounded-2xl bg-[var(--bg-surface-container-low)] px-5 py-10 opacity-0 translate-y-4 transition-all duration-700 md:mb-24 md:px-8 md:py-12"
        aria-labelledby="capabilities-heading"
        data-alt-reveal
      >
        <header class="mb-10 md:mb-12">
          <p
            class="text-xs font-bold uppercase tracking-widest text-[var(--accent-text)]"
          >
            {isEnglish ? "Capabilities" : "Capacidades"}
          </p>
          <h2
            id="capabilities-heading"
            class="mt-2 font-display text-2xl font-bold tracking-tight text-[var(--text-primary)] md:text-3xl"
          >
            {isEnglish ? "Technical capabilities" : "Capacidades técnicas"}
          </h2>
        </header>
        <div class="grid grid-cols-1 gap-6 md:grid-cols-2 md:gap-8">
          {
            capabilities.map((cap) => (
              <div class="service-card-shell-bg shell-hover rounded-2xl p-6 md:p-8">
                <h3 class="font-display text-xl font-semibold tracking-tight text-[var(--text-primary)] md:text-2xl">
                  {isEnglish ? cap.titleEn : cap.title}
                </h3>
                <p class="mt-3 text-base font-normal leading-relaxed text-[var(--text-secondary)]">
                  {isEnglish ? cap.descriptionEn : cap.description}
                </p>
              </div>
            ))
          }
        </div>
      </section>

      <div
        class="my-12 h-px bg-[var(--border-subtle)] md:my-16"
        aria-hidden="true"
      >
      </div>

      <!-- Roles -->
      <section
        class="mb-16 rounded-2xl bg-[var(--bg-primary)] px-5 py-10 opacity-0 translate-y-4 transition-all duration-700 md:mb-20 md:px-8 md:py-12"
        aria-labelledby="roles-heading"
        data-alt-reveal
      >
        <header class="mb-8 md:mb-10">
          <div class="mb-2 flex items-center gap-3">
            <div
              class="h-px w-8 shrink-0 bg-[var(--accent)]"
              aria-hidden="true"
            >
            </div>
            <span
              class="inline-flex rounded-full bg-[hsla(var(--accent-h),var(--accent-s),56%,0.12)] px-3 py-1 text-[0.65rem] font-bold uppercase tracking-[0.2em] text-[var(--accent-text)]"
              data-en="Professional background"
              data-es="Trayectoria profesional"
              >{
                isEnglish
                  ? "Professional background"
                  : "Trayectoria profesional"
              }</span
            >
          </div>
          <h2
            id="roles-heading"
            class="font-display text-2xl font-extrabold tracking-tight text-[var(--text-primary)] md:text-3xl"
            data-en="Roles & experience"
            data-es="Roles y experiencia"
          >
            {isEnglish ? "Roles & experience" : "Roles y experiencia"}
          </h2>
        </header>

        <div class="grid gap-6 sm:grid-cols-2">
          <article
            class="service-card-shell-bg relative overflow-hidden rounded-2xl p-8 sm:col-span-2 md:p-10"
          >
            <div
              class="pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,_hsla(var(--accent-h),var(--accent-s),56%,0.12)_0%,_transparent_55%)]"
              aria-hidden="true"
            >
            </div>
            <div class="relative">
              <h3
                class="mb-3 font-display text-xl font-extrabold tracking-tight text-[var(--text-primary)] md:text-2xl"
                data-en="Developer & software architect"
                data-es="Desarrollador y arquitecto de software"
              >
                {
                  isEnglish
                    ? "Developer & software architect"
                    : "Desarrollador y arquitecto de software"
                }
              </h3>
              <p
                class="text-sm leading-relaxed text-[var(--text-secondary)] md:text-base"
                data-en="Design and implementation of scalable architectures (Huella del fuego en Argentina), microservices creation with FastAPI, full stack development, and cloud deployment."
                data-es="Diseño e implementación de arquitecturas escalables (Huella del fuego en Argentina), creación de microservicios con FastAPI, desarrollo full stack y despliegue en la nube."
              >
                {
                  isEnglish
                    ? "Design and implementation of scalable architectures (Huella del fuego en Argentina), microservices creation with FastAPI, full stack development, and cloud deployment."
                    : "Diseño e implementación de arquitecturas escalables (Huella del fuego en Argentina), creación de microservicios con FastAPI, desarrollo full stack y despliegue en la nube."
                }
              </p>
            </div>
          </article>

          <article
            class="service-card-shell-bg relative overflow-hidden rounded-2xl p-8 md:p-10"
          >
            <div
              class="pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,_hsla(var(--accent-h),var(--accent-s),56%,0.12)_0%,_transparent_55%)]"
              aria-hidden="true"
            >
            </div>
            <div class="relative">
              <h3
                class="mb-3 font-display text-xl font-extrabold tracking-tight text-[var(--text-primary)] md:text-2xl"
                data-en="Functional analyst"
                data-es="Analista funcional"
              >
                {isEnglish ? "Functional analyst" : "Analista funcional"}
              </h3>
              <p
                class="text-sm leading-relaxed text-[var(--text-secondary)] md:text-base"
                data-en="Requirements engineering under Scrum (Finnegans), workflow documentation (MRM), BPMN modeling, and Product Owner support for backlog management."
                data-es="Ingeniería de requerimientos bajo marco Scrum (Finnegans), documentación de workflows (MRM), modelado BPMN y soporte al Product Owner en la gestión del backlog."
              >
                {
                  isEnglish
                    ? "Requirements engineering under Scrum (Finnegans), workflow documentation (MRM), BPMN modeling, and Product Owner support for backlog management."
                    : "Ingeniería de requerimientos bajo marco Scrum (Finnegans), documentación de workflows (MRM), modelado BPMN y soporte al Product Owner en la gestión del backlog."
                }
              </p>
            </div>
          </article>

          <article
            class="service-card-shell-bg relative overflow-hidden rounded-2xl p-8 md:p-10"
          >
            <div
              class="pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,_hsla(var(--accent-h),var(--accent-s),56%,0.12)_0%,_transparent_55%)]"
              aria-hidden="true"
            >
            </div>
            <div class="relative">
              <h3
                class="mb-3 font-display text-xl font-extrabold tracking-tight text-[var(--text-primary)] md:text-2xl"
                data-en="Content analyst"
                data-es="Analista de contenido"
              >
                {isEnglish ? "Content analyst" : "Analista de contenido"}
              </h3>
              <p
                class="text-sm leading-relaxed text-[var(--text-secondary)] md:text-base"
                data-en="Technical and product copy, documentation structure, and editorial criteria aligned with SEO and clarity for end users."
                data-es="Redacción técnica y de producto, estructura de documentación y criterios editoriales alineados a SEO y claridad para el usuario final."
              >
                {
                  isEnglish
                    ? "Technical and product copy, documentation structure, and editorial criteria aligned with SEO and clarity for end users."
                    : "Redacción técnica y de producto, estructura de documentación y criterios editoriales alineados a SEO y claridad para el usuario final."
                }
              </p>
            </div>
          </article>

          <article
            class="service-card-shell-bg relative overflow-hidden rounded-2xl p-8 md:p-10"
          >
            <div
              class="pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,_hsla(var(--accent-h),var(--accent-s),56%,0.12)_0%,_transparent_55%)]"
              aria-hidden="true"
            >
            </div>
            <div class="relative">
              <h3
                class="mb-3 font-display text-xl font-extrabold tracking-tight text-[var(--text-primary)] md:text-2xl"
                data-en="Mentor & technical facilitator"
                data-es="Mentor y facilitador técnico"
              >
                {
                  isEnglish
                    ? "Mentor & technical facilitator"
                    : "Mentor y facilitador técnico"
                }
              </h3>
              <p
                class="text-sm leading-relaxed text-[var(--text-secondary)] md:text-base"
                data-en="Experience as a teaching assistant and tutor for Initial Programming I at UTN Avellaneda."
                data-es="Experiencia como ayudante de cátedra y tutor para Programación Inicial I en la UTN Avellaneda, guiando alumnos en sus primeros pasos técnicos."
              >
                {
                  isEnglish
                    ? "Experience as a teaching assistant and tutor for Initial Programming I at UTN Avellaneda."
                    : "Experiencia como ayudante de cátedra y tutor para Programación Inicial I en la UTN Avellaneda, guiando alumnos en sus primeros pasos técnicos."
                }
              </p>
            </div>
          </article>
        </div>
      </section>

      <div
        class="opacity-0 translate-y-4 transition-all duration-700"
        data-alt-reveal
      >
        <LiquidGlassMarquee
          items={[
            "Astro",
            "React",
            "TypeScript",
            "Python",
            "Java",
            "Spring Boot",
            "SQL",
            "AWS",
            "Google Cloud",
            "Oracle Cloud",
            "CI/CD",
            "FastAPI",
            "Tailwind CSS",
            "PostgreSQL",
            "Docker",
            "Vercel",
            "Supabase",
            "Zod",
            "MDX",
          ]}
          label="Stack y herramientas"
          labelEn="Stack & tools"
        />
      </div>

      <div
        class="my-12 h-px bg-[var(--border-subtle)] md:my-16"
        aria-hidden="true"
      >
      </div>

      <!-- Habilidades interpersonales -->
      <section
        class="mb-16 rounded-2xl bg-[var(--bg-surface-container-low)] px-5 py-10 opacity-0 translate-y-4 transition-all duration-700 md:mb-20 md:px-8 md:py-12"
        aria-labelledby="soft-skills-heading"
        data-alt-reveal
      >
        <header class="mb-8 md:mb-10">
          <div class="mb-2 flex items-center gap-3">
            <div
              class="h-px w-8 shrink-0 bg-[var(--accent)]"
              aria-hidden="true"
            >
            </div>
            <span
              class="inline-flex rounded-full bg-[hsla(var(--accent-h),var(--accent-s),56%,0.12)] px-3 py-1 text-[0.65rem] font-bold uppercase tracking-[0.2em] text-[var(--accent-text)]"
              data-en="Profile"
              data-es="Perfil">Perfil</span
            >
          </div>
          <h2
            id="soft-skills-heading"
            class="font-display text-2xl font-extrabold tracking-tight text-[var(--text-primary)] md:text-3xl"
            data-en="Interpersonal skills"
            data-es="Habilidades interpersonales"
          >
            Habilidades interpersonales
          </h2>
        </header>
        <div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
          {
            softSkills.map((item) => (
              <div class="service-card-shell-bg shell-hover rounded-2xl p-5 md:p-6">
                <h3 class="font-display text-lg font-semibold tracking-tight text-[var(--text-primary)]">
                  {isEnglish ? item.titleEn : item.title}
                </h3>
                <p class="mt-2 text-sm leading-relaxed text-[var(--text-secondary)] md:text-base">
                  {isEnglish ? item.descriptionEn : item.description}
                </p>
              </div>
            ))
          }
        </div>
      </section>

      <div
        class="my-12 h-px bg-[var(--border-subtle)] md:my-16"
        aria-hidden="true"
      >
      </div>

      <!-- Formación -->
      <section
        class="mb-16 rounded-2xl bg-[var(--bg-secondary)] px-5 py-10 opacity-0 translate-y-4 transition-all duration-700 md:mb-20 md:px-8 md:py-12"
        aria-labelledby="edu-heading"
        data-alt-reveal
      >
        <header class="mb-8 md:mb-10">
          <div class="mb-2 flex items-center gap-3">
            <div
              class="h-px w-8 shrink-0 bg-[var(--accent)]"
              aria-hidden="true"
            >
            </div>
            <span
              class="inline-flex rounded-full bg-[hsla(var(--accent-h),var(--accent-s),56%,0.12)] px-3 py-1 text-[0.65rem] font-bold uppercase tracking-[0.2em] text-[var(--accent-text)]"
              data-en="Education"
              data-es="Formación">Formación</span
            >
          </div>
          <h2
            id="edu-heading"
            class="font-display text-2xl font-extrabold tracking-tight text-[var(--text-primary)] md:text-3xl"
            data-en="Academic background"
            data-es="Estudios"
          >
            Estudios
          </h2>
        </header>

        <ul class="list-none space-y-4 p-0" role="list">
          <li role="listitem">
            <article
              class="service-card-shell-bg shell-hover flex flex-col gap-3 rounded-2xl p-5 sm:flex-row sm:items-center sm:justify-between md:p-6"
            >
              <div class="min-w-0">
                <div class="flex flex-wrap items-center gap-2">
                  <span
                    class="inline-flex rounded-full bg-[hsla(var(--accent-h),var(--accent-s),56%,0.1)] px-2.5 py-0.5 text-[11px] font-semibold uppercase tracking-wide text-[var(--accent-text)]"
                    data-en="In progress"
                    data-es="En curso">En curso</span
                  >
                  <span
                    class="text-sm font-bold text-[var(--text-primary)]"
                    data-en="Bachelor's degree in technology and information management"
                    data-es="Licenciatura en gestión de tecnología de la información"
                  >
                    Licenciatura en gestión de tecnología de la información
                  </span>
                </div>
                <div
                  class="mt-1 text-xs text-[var(--text-muted)]"
                  data-en="UADE · 2024–2028"
                  data-es="UADE · 2024–2028"
                >
                  UADE · 2024–2028
                </div>
              </div>
              <span
                class="inline-flex shrink-0 self-start rounded-full bg-[hsla(var(--accent-h),var(--accent-s),56%,0.1)] px-2.5 py-0.5 text-[11px] font-semibold uppercase tracking-wide text-[var(--accent-text)] sm:self-center"
                data-en="University"
                data-es="Universidad">Universidad</span
              >
            </article>
          </li>
          <li role="listitem">
            <article
              class="service-card-shell-bg shell-hover flex flex-col gap-3 rounded-2xl p-5 sm:flex-row sm:items-center sm:justify-between md:p-6"
            >
              <div class="min-w-0">
                <div class="flex flex-wrap items-center gap-2">
                  <span
                    class="inline-flex rounded-full bg-[hsla(var(--accent-h),var(--accent-s),56%,0.1)] px-2.5 py-0.5 text-[11px] font-semibold uppercase tracking-wide text-[var(--accent-text)]"
                    data-en="Completed"
                    data-es="Completado">Completado</span
                  >
                  <span
                    class="text-sm font-bold text-[var(--text-primary)]"
                    data-en="Technician in Computer Programming"
                    data-es="Tecnicatura en Programación Informática"
                  >
                    Tecnicatura en Programación Informática
                  </span>
                </div>
                <div
                  class="mt-1 text-xs text-[var(--text-muted)]"
                  data-en="UTN · 2023–2024"
                  data-es="UTN · 2023–2024"
                >
                  UTN · 2023–2024
                </div>
              </div>
              <span
                class="inline-flex shrink-0 self-start rounded-full bg-[hsla(var(--accent-h),var(--accent-s),56%,0.1)] px-2.5 py-0.5 text-[11px] font-semibold uppercase tracking-wide text-[var(--accent-text)] sm:self-center"
                data-en="University"
                data-es="Universidad">Universidad</span
              >
            </article>
          </li>
          <li role="listitem">
            <article
              class="service-card-shell-bg shell-hover flex flex-col gap-3 rounded-2xl p-5 sm:flex-row sm:items-center sm:justify-between md:p-6"
            >
              <div class="min-w-0">
                <div class="flex flex-wrap items-center gap-2">
                  <span
                    class="inline-flex rounded-full bg-[hsla(var(--accent-h),var(--accent-s),56%,0.1)] px-2.5 py-0.5 text-[11px] font-semibold uppercase tracking-wide text-[var(--accent-text)]"
                    data-en="Completed"
                    data-es="Completado">Completado</span
                  >
                  <span
                    class="text-sm font-bold text-[var(--text-primary)]"
                    data-en="Business Analysis Diploma"
                    data-es="Diplomatura en Análisis de Negocios"
                  >
                    Diplomatura en Análisis de Negocios
                  </span>
                </div>
                <div
                  class="mt-1 text-xs text-[var(--text-muted)]"
                  data-en="UTN FRBA · 2024"
                  data-es="UTN FRBA · 2024"
                >
                  UTN FRBA · 2024
                </div>
              </div>
              <span
                class="inline-flex shrink-0 self-start rounded-full bg-[hsla(var(--accent-h),var(--accent-s),56%,0.1)] px-2.5 py-0.5 text-[11px] font-semibold uppercase tracking-wide text-[var(--accent-text)] sm:self-center"
                data-en="Specialization"
                data-es="Diplomatura">Diplomatura</span
              >
            </article>
          </li>
        </ul>
      </section>

      <div
        class="my-12 h-px bg-[var(--border-subtle)] md:my-16"
        aria-hidden="true"
      >
      </div>

      <!-- Proyectos -->
      <section
        class="mb-16 rounded-2xl bg-[var(--bg-primary)] px-4 py-12 opacity-0 translate-y-4 transition-all duration-700 md:mb-24 md:px-8 md:py-16"
        aria-labelledby="projects-heading"
        data-alt-reveal
      >
        <header class="mb-10 md:mb-12">
          <p
            class="text-xs font-bold uppercase tracking-widest text-[var(--accent-text)]"
          >
            {isEnglish ? "Engineering" : "Ingeniería"}
          </p>
          <h2
            id="projects-heading"
            class="mt-2 font-display text-2xl font-bold tracking-tight text-[var(--text-primary)] md:text-3xl"
          >
            {isEnglish ? "Technical projects" : "Proyectos técnicos"}
          </h2>
        </header>

        <div class="flex flex-col gap-6 md:gap-8">
          {
            sortedProjects.map((project, i) => (
              <div id={project.slug}>
                <ProjectCard
                  headingId={`project-card-${project.slug}`}
                  direction={i % 2 === 0 ? "left" : "right"}
                  title={project.data.title}
                  titleEn={project.data.title}
                  description={project.data.description}
                  descriptionEn={project.data.descriptionEn}
                  coverPosition={project.data.coverPosition}
                  image={project.data.coverImage}
                  tags={project.data.tags}
                  href={
                    project.data.url
                      ? project.data.url
                      : project.slug === "huelladelfuego"
                        ? isEnglish
                          ? "/en/blog/caso-huelladelfuego"
                          : "/blog/caso-huelladelfuego"
                        : `${talentHref}#${project.slug}`
                  }
                  badge={
                    project.data.status === "live" ||
                    project.data.status === "in-progress"
                      ? statusLabel(project.data.status, "es")
                      : undefined
                  }
                  badgeEn={
                    project.data.status === "live" ||
                    project.data.status === "in-progress"
                      ? statusLabel(project.data.status, "en")
                      : undefined
                  }
                  badgeVariant={
                    project.data.status === "live" ? "live" : "in-progress"
                  }
                  external={Boolean(project.data.url)}
                />
              </div>
            ))
          }
        </div>
      </section>

      <div class="mb-16 md:mb-24">
        <SectionWrapper
          bg="bg-[var(--accent)]"
          tone="accent"
          padding="py-16 md:py-24"
          maxWidth="max-w-3xl"
          class="rounded-3xl"
          innerClass="text-center"
          revealAlt
        >
          <h2
            class="font-display text-2xl font-bold text-[var(--color-on-accent)] md:text-3xl"
          >
            {isEnglish ? "Let's talk" : "¿Hablamos?"}
          </h2>
          <p
            class="mx-auto mt-3 max-w-lg text-sm leading-relaxed text-[var(--color-on-accent)] opacity-90"
          >
            {
              isEnglish
                ? "If you have questions about my background, want to check references, or explore a consulting engagement, the site footer includes the contact form if you prefer a structured message."
                : "Si tenés dudas sobre mi perfil, querés consultar referencias o explorar una colaboración de consultoría, el pie del sitio incluye el formulario de contacto si preferís dejar un mensaje estructurado."
            }
          </p>
          <p class="mt-8">
            <a
              href={servicesContactHref}
              class="btn-secondary btn-bounce border-black/25 bg-black/10 text-[var(--color-on-accent)] hover:border-black/40 hover:bg-black/15"
            >
              <span>{isEnglish ? "Contact" : "Contactar"}</span>
              <span class="arrow" aria-hidden="true">→</span>
            </a>
          </p>
        </SectionWrapper>
      </div>
    </div>
  </main>
</Layout>
