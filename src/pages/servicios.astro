---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import ServiceBentoCard from '../components/ServiceBentoCard.astro';
import { getCollection } from 'astro:content';

const allServices = await getCollection('services');
const sortedServices = allServices.sort((a, b) => a.data.order - b.data.order);

/** Anclas alineadas con Nav.astro (#agentes-ia, #landing, …). */
function serviceAnchorId(slug: string): string {
  const map: Record<string, string> = {
    'chatbots-ia': 'agentes-ia',
    'landing-page': 'landing',
    'ecommerce-platforms': 'ecommerce',
    'workflow-automation': 'automatizacion',
    'local-llms': 'local-llms',
    'seo-geo': 'seo-geo',
  };
  return map[slug] ?? `service-${slug}`;
}

type BentoVariant = 'wide-left' | 'narrow-top' | 'narrow-bottom' | 'wide-right' | 'default';

const variantByIndex: BentoVariant[] = ['wide-left', 'narrow-top', 'narrow-bottom', 'wide-right'];
const colSpanByIndex = ['md:col-span-8', 'md:col-span-4', 'md:col-span-4', 'md:col-span-8'];

const siteUrl = 'https://escalatunegocioconia.com';
const servicesJsonLd = {
  '@context': 'https://schema.org',
  '@graph': sortedServices.map((s) => ({
    '@type': 'Service',
    name: s.data.title,
    description: s.data.shortDescription ?? s.data.description,
    url: `${siteUrl}/servicios#${serviceAnchorId(s.slug)}`,
    provider: {
      '@type': 'Person',
      name: 'Nicolás Hruszczak',
      url: siteUrl,
    },
  })),
};
---

<Layout
  title="Servicios de desarrollo web y automatización con IA | Nicolás Hruszczak"
  description="Soluciones digitales para tu negocio: landing pages, chatbots con IA, SEO local, e-commerce y automatización. Resultados medibles, entrega rápida."
  ogImage="/og-desktop.png"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(servicesJsonLd)} />
  </Fragment>
  <Nav activePage="servicios" />

  <main id="main-content">

    <!-- ── Hero editorial ──────────────────────────────────── -->
    <header class="mx-auto max-w-7xl px-6 pb-24 pt-12">
      <div class="flex flex-col justify-between gap-8 md:flex-row md:items-end">
        <div class="max-w-2xl">
          <span
            class="label mb-4 block uppercase tracking-[0.1em]"
            style="color: var(--text-secondary); font-size: var(--text-xs);"
            data-es="Nuestros servicios"
            data-en="Our services"
          >Nuestros servicios</span>
          <h1
            class="font-extrabold tracking-tighter"
            style="font-family: var(--font-display); font-size: clamp(2.5rem, 6vw, var(--text-3xl)); line-height: 1.1; color: var(--text-primary);"
            data-es='Soluciones digitales<br/><span class="gradient-text">para tu negocio.</span>'
            data-en='Digital solutions<br/><span class="gradient-text">for your business.</span>'
          >Soluciones digitales<br/><span class="inline-block bg-gradient-to-r bg-clip-text text-transparent" style="--tw-gradient-from: var(--color-accent-600); --tw-gradient-to: var(--color-accent-400);">para tu negocio.</span></h1>
        </div>
        <div class="max-w-sm">
          <p
            class="pb-2 leading-relaxed"
            style="font-family: var(--font-body); font-size: var(--text-base); color: var(--text-secondary);"
            data-es="Tecnología que trabaja por vos. Desde landing pages hasta chatbots con IA, cada solución está diseñada para generar resultados medibles."
            data-en="Technology that works for you. From landing pages to AI chatbots, every solution is designed to deliver measurable results."
          >Tecnología que trabaja por vos. Desde landing pages hasta chatbots con IA, cada solución está diseñada para generar resultados medibles.</p>
        </div>
      </div>
    </header>

    <!-- ── Bento grid ──────────────────────────────────────── -->
    <section class="mx-auto max-w-7xl space-y-8 px-6" aria-labelledby="services-heading">
      <h2 class="sr-only" id="services-heading"
          data-es="Servicios" data-en="Services">Servicios</h2>
      <div class="grid grid-cols-1 gap-8 md:grid-cols-12">
        {sortedServices.map((service, i) => {
          const variant = variantByIndex[i] ?? 'default';
          const colSpan = colSpanByIndex[i] ?? 'md:col-span-4';
          return (
            <div
              id={serviceAnchorId(service.slug)}
              class={`col-span-1 scroll-mt-24 ${colSpan}`}
            >
              <ServiceBentoCard
                title={service.data.title}
                titleEn={service.data.titleEn}
                description={service.data.description}
                descriptionEn={service.data.descriptionEn}
                shortDescription={service.data.shortDescription}
                shortDescriptionEn={service.data.shortDescriptionEn}
                roiFocus={service.data.roiFocus}
                roiFocusEn={service.data.roiFocusEn}
                icon={service.data.icon}
                module={service.data.module}
                href={service.data.href}
                variant={variant}
              />
            </div>
          );
        })}
      </div>
    </section>

    <!-- ── Diferenciadores ─────────────────────────────────── -->
    <section class="mt-32 py-32" style="background: var(--bg-secondary);" aria-labelledby="diff-heading">
      <div class="mx-auto max-w-7xl px-6">
        <div class="mb-20 text-center">
          <span
            class="label mb-4 block uppercase tracking-[0.1em]"
            style="color: var(--text-secondary); font-size: var(--text-xs);"
            data-es="Por qué elegirnos"
            data-en="Why choose us"
          >Por qué elegirnos</span>
          <h2
            id="diff-heading"
            class="font-extrabold tracking-tight"
            style="font-family: var(--font-display); font-size: var(--text-2xl); color: var(--text-primary);"
            data-es="Tecnología accesible, resultados concretos."
            data-en="Accessible technology, concrete results."
          >Tecnología accesible, resultados concretos.</h2>
        </div>
        <div class="grid grid-cols-1 gap-12 md:grid-cols-3">

          <!-- Diferenciador 1 -->
          <div class="rounded-[var(--radius-lg)] border p-8"
               style="background: var(--bg-card); border-color: var(--border-subtle);">
            <span class="mb-4 block text-4xl" aria-hidden="true">⚡</span>
            <h4
              class="mb-2 font-bold"
              style="font-family: var(--font-display); font-size: var(--text-lg); color: var(--text-primary);"
              data-es="Entrega rápida"
              data-en="Fast delivery"
            >Entrega rápida</h4>
            <p
              style="font-size: var(--text-sm); color: var(--text-secondary); line-height: 1.7;"
              data-es="Tu solución funcionando en 1 a 3 semanas. Sin meses de espera ni reuniones interminables."
              data-en="Your solution running in 1 to 3 weeks. No months of waiting or endless meetings."
            >Tu solución funcionando en 1 a 3 semanas. Sin meses de espera ni reuniones interminables.</p>
          </div>

          <!-- Diferenciador 2 -->
          <div class="rounded-[var(--radius-lg)] border p-8"
               style="background: var(--bg-card); border-color: var(--border-subtle);">
            <span class="mb-4 block text-4xl" aria-hidden="true">🌐</span>
            <h4
              class="mb-2 font-bold"
              style="font-family: var(--font-display); font-size: var(--text-lg); color: var(--text-primary);"
              data-es="Hosting sin costo"
              data-en="Free hosting"
            >Hosting sin costo</h4>
            <p
              style="font-size: var(--text-sm); color: var(--text-secondary); line-height: 1.7;"
              data-es="Deploy en Vercel con CDN global. Cero gastos de infraestructura para tu negocio."
              data-en="Deployed on Vercel with global CDN. Zero infrastructure costs for your business."
            >Deploy en Vercel con CDN global. Cero gastos de infraestructura para tu negocio.</p>
          </div>

          <!-- Diferenciador 3 -->
          <div class="rounded-[var(--radius-lg)] border p-8"
               style="background: var(--bg-card); border-color: var(--border-subtle);">
            <span class="mb-4 block text-4xl" aria-hidden="true">🛡️</span>
            <h4
              class="mb-2 font-bold"
              style="font-family: var(--font-display); font-size: var(--text-lg); color: var(--text-primary);"
              data-es="Soporte incluido"
              data-en="Support included"
            >Soporte incluido</h4>
            <p
              style="font-size: var(--text-sm); color: var(--text-secondary); line-height: 1.7;"
              data-es="30 días de soporte post-lanzamiento. No te dejamos solo después de la entrega."
              data-en="30 days of post-launch support. We don't leave you alone after delivery."
            >30 días de soporte post-lanzamiento. No te dejamos solo después de la entrega.</p>
          </div>

        </div>
      </div>
    </section>

    <!-- ── CTA final ───────────────────────────────────────── -->
    <section id="contacto" class="mx-auto mt-32 max-w-4xl px-6 pb-32 text-center" aria-labelledby="cta-heading">
      <div class="relative overflow-hidden rounded-[var(--radius-xl)] p-12 md:p-16"
           style="background: var(--bg-secondary);">
        <div class="absolute right-0 top-0 -mr-16 -mt-16 h-64 w-64 rounded-full blur-3xl"
             style="background: var(--color-accent-400); opacity: 0.1;" aria-hidden="true"></div>
        <div class="absolute bottom-0 left-0 -mb-16 -ml-16 h-64 w-64 rounded-full blur-3xl"
             style="background: var(--color-accent-600); opacity: 0.05;" aria-hidden="true"></div>

        <h2
          id="cta-heading"
          class="relative z-10 mb-4 font-extrabold tracking-tight"
          style="font-family: var(--font-display); font-size: var(--text-2xl); color: var(--text-primary);"
          data-es="¿Listo para escalar tu negocio?"
          data-en="Ready to scale your business?"
        >¿Listo para escalar tu negocio?</h2>
        <p
          class="relative z-10 mx-auto mb-8 max-w-md"
          style="font-size: var(--text-base); color: var(--text-secondary); line-height: 1.7;"
          data-es="Contanos tu desafío y te proponemos la solución más eficiente."
          data-en="Tell us your challenge and we'll propose the most efficient solution."
        >Contanos tu desafío y te proponemos la solución más eficiente.</p>

        <div class="relative z-10 flex flex-col justify-center gap-4 sm:flex-row">
          <a
            href="mailto:comercial@escalatunegocioconia.com"
            class="btn-primary inline-flex items-center justify-center gap-2 rounded-[var(--radius-md)] px-6 py-3 font-bold transition-transform hover:scale-105"
            data-es="Escribinos por email"
            data-en="Send us an email"
          >Escribinos por email</a>
          <a
            href="/contacto"
            class="inline-flex items-center justify-center gap-2 rounded-[var(--radius-md)] border px-6 py-3 font-bold transition-colors"
            style="border-color: var(--border-normal); color: var(--text-primary);"
            data-es="Completar formulario"
            data-en="Fill out form"
          >Completar formulario</a>
        </div>
      </div>
    </section>

  </main>
</Layout>
