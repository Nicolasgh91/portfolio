---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import ContactForm from '../components/ContactForm.astro';
import { getCollection } from 'astro:content';
import ServiceCard from '../components/ServiceCard.astro';


// Obtener servicios ordenados desde la colección de contenido
const allServices = await getCollection('services');
const sortedServices = allServices.sort((a, b) => a.data.order - b.data.order);

// Precios desde variables de entorno (actualizables sin tocar el código)
const prices: Record<string, { price?: string; priceUnit?: string }> = {
  'ia-agents': {
    price: import.meta.env.PUBLIC_PRICE_IA_AGENTS,
    priceUnit: import.meta.env.PUBLIC_PRICE_UNIT_IA_AGENTS,
  },
  'local-llms': {
    price: import.meta.env.PUBLIC_PRICE_LOCAL_LLMS,
    priceUnit: import.meta.env.PUBLIC_PRICE_UNIT_LOCAL_LLMS,
  },
  'ecommerce-platforms': {
    price: import.meta.env.PUBLIC_PRICE_ECOMMERCE,
    priceUnit: import.meta.env.PUBLIC_PRICE_UNIT_ECOMMERCE,
  },
  'workflow-automation': {
    price: import.meta.env.PUBLIC_PRICE_AUTOMATION,
    priceUnit: import.meta.env.PUBLIC_PRICE_UNIT_AUTOMATION,
  },
};
---

<Layout
  title="Servicios B2B — Nicolás Hruszczak"
  description="Software a medida, automatización con IA y auditoría de procesos para empresas y pymes que buscan reducir costos y multiplicar resultados."
  ogImage="/og-desktop.png"
>
  <Nav activePage="servicios" />

  <main id="main-content">
    <div class="page-container">

      <!-- ── Hero ─────────────────────────────────────────── -->
      <section class="hero" aria-label="Propuesta de valor B2B">
        <div
          class="badge"
          data-en="B2B Services · Free diagnosis"
          data-es="Servicios para empresas · Diagnóstico gratuito"
        >Servicios para empresas · Diagnóstico gratuito</div>

        <h1
          data-en='Custom software to<br><em>multiply ROI</em><br>for your business.'
          data-es='Software a medida para<br><em>multiplicar el ROI</em><br>de su negocio.'
        >Software a medida para<br><em>multiplicar el ROI</em><br>de su negocio.</h1>

        <p
          class="hero-sub"
          data-en="Fixed cost reduction and operational optimization through automation, artificial intelligence, and exclusive management systems."
          data-es="Reducción de gastos fijos y optimización operativa mediante automatización, inteligencia artificial y sistemas de gestión exclusivos."
        >Reducción de gastos fijos y optimización operativa mediante automatización, inteligencia artificial y sistemas de gestión exclusivos.</p>

        <div class="cta-row">
          <a
            href="#contacto"
            class="btn-primary"
            data-en="Request free diagnosis"
            data-es="Solicitar diagnóstico gratuito"
          >Solicitar diagnóstico gratuito</a>
        </div>
      </section>

      <!-- ── Value banner ──────────────────────────────────── -->
      <div
        class="value-banner"
        role="region"
        aria-label="Propuesta de valor: de gasto a inversión"
      >
        <div class="value-banner-col">
          <h3
            data-en="Software as expense"
            data-es="Software como gasto"
          >Software como gasto</h3>
          <p
            data-en="Recurring licenses, disconnected tools, manual processes that consume hours and capital month after month."
            data-es="Licencias recurrentes, herramientas desconectadas, procesos manuales que consumen horas y capital mes a mes."
          >Licencias recurrentes, herramientas desconectadas, procesos manuales que consumen horas y capital mes a mes.</p>
        </div>
        <div class="value-banner-arrow" aria-hidden="true">→</div>
        <div class="value-banner-col accent">
          <h3
            data-en="Software as investment"
            data-es="Software como inversión"
          >Software como inversión</h3>
          <p
            data-en="Proprietary systems, measurable automation and concrete return on every peso invested."
            data-es="Sistemas propietarios, automatización medible y retorno concreto sobre cada peso invertido."
          >Sistemas propietarios, automatización medible y retorno concreto sobre cada peso invertido.</p>
        </div>
      </div>

      <!-- ── Catálogo de servicios (dinámico) ──────────────── -->
      <section class="section" aria-labelledby="services-heading">
        <div class="section-header">
          <span
            class="label"
            data-en="Catalog"
            data-es="Catálogo"
          >Catálogo</span>
          <h2
            id="services-heading"
            data-en="Services"
            data-es="Servicios"
          >Servicios</h2>
          <p
            style="margin-top:6px;font-size:var(--text-sm)"
            data-en="Four intervention axes with direct operational impact."
            data-es="Cuatro ejes de intervención con impacto directo en la operación."
          >Cuatro ejes de intervención con impacto directo en la operación.</p>
        </div>

      <div class="services-carousel" id="services-carousel">
        {sortedServices.map((service) => {
          const priceData = prices[service.slug] ?? {};
          return (
            <ServiceCard service={{
              title: service.data.title,
              titleEn: service.data.titleEn,
              shortDescription: service.data.shortDescription ?? service.data.description,
              shortDescriptionEn: service.data.shortDescriptionEn ?? service.data.descriptionEn,
              imageKey: service.data.imageKey,
              featured: service.data.featured,
              href: service.data.href,
              price: priceData.price,
              priceUnit: priceData.priceUnit,
            }} />
          );
        })}
      </div>
      </section>

      <!-- ── Case study ─────────────────────────────────────── -->
      <section class="section" aria-labelledby="case-heading">
        <div class="section-header">
          <span
            class="label"
            data-en="Use case"
            data-es="Caso de uso"
          >Caso de uso</span>
        </div>

        <div class="case-block">
          <div class="case-header">
            <h2
              id="case-heading"
              data-en="Success story: comprehensive sports management (Double Click™)"
              data-es="Caso de éxito: gestión integral deportiva (Double Click™)"
            >Caso de éxito: gestión integral deportiva (Double Click™)</h2>
            <span class="tag tag-warn" aria-label="Proyecto en curso">⚠ En curso</span>
          </div>

          <p
            style="margin:var(--sp-sm) 0 var(--sp-lg);font-size:var(--text-sm)"
            data-en="A custom application centralizes bookings, billing, and client retention for a Pilates studio — eliminating the need for three separate paid software tools."
            data-es="Una aplicación a medida centraliza reservas, facturación y retención de clientes para un estudio de Pilates, eliminando la necesidad de tres herramientas de software con pago mensual."
          >Una aplicación a medida centraliza reservas, facturación y retención de clientes para un estudio de Pilates, eliminando la necesidad de tres herramientas de software con pago mensual.</p>

          <div class="grid-2">
            <div
              class="mock-placeholder"
              role="img"
              aria-label="Espacio reservado para captura del dashboard de gestión"
            >
              [ Dashboard mockup ]<br><br>
              Panel de reservas · Métricas · Clientes
            </div>

            <div class="card" style="align-self:start">
              <h3
                style="font-size:var(--text-base);margin-bottom:var(--sp-sm)"
                data-en="Result"
                data-es="Resultado"
              >Resultado</h3>
              <p
                style="font-size:var(--text-sm)"
                data-en="Elimination of 3 monthly subscriptions. Significant reduction in administrative management time. Unified client retention metrics panel."
                data-es="Eliminación de 3 suscripciones mensuales. Reducción significativa del tiempo de gestión administrativa. Panel unificado de métricas de retención de clientes."
              >Eliminación de 3 suscripciones mensuales. Reducción significativa del tiempo de gestión administrativa. Panel unificado de métricas de retención de clientes.</p>
              <div class="tags">
                <span class="tag">Python</span>
                <span class="tag">Next.js</span>
                <span class="tag">PostgreSQL</span>
                <a href="#contacto" class="tag tag-accent"
                  data-en="Request similar solution →"
                  data-es="Solicitar solución similar →"
                >Solicitar solución similar →</a>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- ── FAQ ─────────────────────────────────────────────── -->
      <section class="section" aria-labelledby="faq-heading">
        <div class="section-header">
          <span
            class="label"
            data-en="FAQ"
            data-es="Preguntas frecuentes"
          >Preguntas frecuentes</span>
          <h2
            id="faq-heading"
            data-en="Common questions"
            data-es="Consultas habituales"
          >Consultas habituales</h2>
        </div>

        <div class="faq-list" itemscope itemtype="https://schema.org/FAQPage">

          <details class="faq-item" itemscope itemprop="mainEntity" itemtype="https://schema.org/Question">
            <summary class="faq-q" itemprop="name"
              data-en="How long does it take to build a custom system?"
              data-es="¿Cuánto tiempo lleva construir un sistema a medida?"
            >¿Cuánto tiempo lleva construir un sistema a medida?</summary>
            <div class="faq-a" itemscope itemprop="acceptedAnswer" itemtype="https://schema.org/Answer">
              <p itemprop="text"
                data-en="Depends on scope. A minimum viable product (MVP) is typically delivered in 4–8 weeks. A complete system integrating billing, bookings, and clients generally takes 3–4 months. The free diagnosis session defines the real timeline."
                data-es="Depende del alcance. Un producto mínimo viable (MVP) se entrega en 4–8 semanas. Un sistema completo que integra facturación, reservas y clientes lleva generalmente 3–4 meses. La sesión de diagnóstico gratuito define el cronograma real."
              >Depende del alcance. Un producto mínimo viable (MVP) se entrega en 4–8 semanas. Un sistema completo que integra facturación, reservas y clientes lleva generalmente 3–4 meses. La sesión de diagnóstico gratuito define el cronograma real.</p>
            </div>
          </details>

          <details class="faq-item" itemscope itemprop="mainEntity" itemtype="https://schema.org/Question">
            <summary class="faq-q" itemprop="name"
              data-en="Do you work with companies of any size?"
              data-es="¿Trabajás con empresas de cualquier tamaño?"
            >¿Trabajás con empresas de cualquier tamaño?</summary>
            <div class="faq-a" itemscope itemprop="acceptedAnswer" itemtype="https://schema.org/Answer">
              <p itemprop="text"
                data-en="Yes. The approach is especially valuable for SMEs and growing teams that want to eliminate recurring SaaS costs and replace them with proprietary systems."
                data-es="Sí. El enfoque es especialmente valioso para pymes y equipos en crecimiento que quieren eliminar costos recurrentes de SaaS y reemplazarlos por sistemas propios."
              >Sí. El enfoque es especialmente valioso para pymes y equipos en crecimiento que quieren eliminar costos recurrentes de SaaS y reemplazarlos por sistemas propios.</p>
            </div>
          </details>

          <details class="faq-item" itemscope itemprop="mainEntity" itemtype="https://schema.org/Question">
            <summary class="faq-q" itemprop="name"
              data-en="What does the free diagnosis consist of?"
              data-es="¿En qué consiste el diagnóstico gratuito?"
            >¿En qué consiste el diagnóstico gratuito?</summary>
            <div class="faq-a" itemscope itemprop="acceptedAnswer" itemtype="https://schema.org/Answer">
              <p itemprop="text"
                data-en="A 45-minute virtual session to map your main operational pain points, identify immediate automation or optimization opportunities, and define a realistic action plan — with no obligation to hire."
                data-es="Una sesión virtual de 45 minutos para mapear sus principales puntos de dolor operativos, identificar oportunidades de automatización u optimización inmediatas y definir un plan de acción realista, sin compromiso de contratación."
              >Una sesión virtual de 45 minutos para mapear sus principales puntos de dolor operativos, identificar oportunidades de automatización u optimización inmediatas y definir un plan de acción realista, sin compromiso de contratación.</p>
            </div>
          </details>

          <details class="faq-item" itemscope itemprop="mainEntity" itemtype="https://schema.org/Question">
            <summary class="faq-q" itemprop="name"
              data-en="What technologies do you use?"
              data-es="¿Qué tecnologías utilizás?"
            >¿Qué tecnologías utilizás?</summary>
            <div class="faq-a" itemscope itemprop="acceptedAnswer" itemtype="https://schema.org/Answer">
              <p itemprop="text"
                data-en="Python (FastAPI) for backends, React/Next.js or Astro for frontends, PostgreSQL for databases, Docker for deployment."
                data-es="Python (FastAPI) para backends, React/Next.js o Astro para frontends, PostgreSQL para bases de datos, Docker para despliegue."
              >Python (FastAPI) para backends, React/Next.js o Astro para frontends, PostgreSQL para bases de datos, Docker para despliegue.</p>
            </div>
          </details>

        </div>
      </section>

      <!-- ── Formulario de contacto ──────────────────────────── -->
      <section id="contacto" class="section" aria-labelledby="contact-heading">
        <div class="section-header">
          <span
            class="label"
            data-en="Contact"
            data-es="Contacto"
          >Contacto</span>
          <h2
            id="contact-heading"
            data-en="Let's evaluate your challenge"
            data-es="Evaluemos su desafío"
          >Evaluemos su desafío</h2>
        </div>
        <ContactForm />
      </section>

    </div>
  </main>

  <!-- Script: drag-to-scroll para el carrusel de servicios -->
  <script>
    const carousel = document.getElementById('services-carousel');
    if (carousel) {
      let isDown = false;
      let startX = 0;
      let scrollLeft = 0;

      carousel.addEventListener('mousedown', (e) => {
        isDown = true;
        carousel.classList.add('is-dragging');
        startX = e.pageX - carousel.offsetLeft;
        scrollLeft = carousel.scrollLeft;
      });

      document.addEventListener('mouseup', () => {
        isDown = false;
        carousel.classList.remove('is-dragging');
      });

      carousel.addEventListener('mouseleave', () => {
        isDown = false;
        carousel.classList.remove('is-dragging');
      });

      carousel.addEventListener('mousemove', (e) => {
        if (!isDown) return;
        e.preventDefault();
        const x = e.pageX - carousel.offsetLeft;
        carousel.scrollLeft = scrollLeft - (x - startX) * 1.2;
      });
    }
  </script>

</Layout>
<style>
  .faq-list { margin-top: var(--sp-xl); display: flex; flex-direction: column; gap: 2px; }
  .faq-item {
    background: var(--bg-secondary);
    border: 0.5px solid var(--border-subtle);
    border-radius: var(--radius-md);
    overflow: hidden;
    transition: border-color 0.15s ease;
  }
  .faq-item[open] { border-color: var(--accent-border); }
  .faq-q {
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--sp-md);
    padding: var(--sp-md) var(--sp-lg);
    font-size: calc(var(--text-sm) * var(--font-scale));
    font-weight: 500;
    color: var(--text-primary);
    cursor: pointer;
    user-select: none;
    transition: color 0.15s ease;
  }
  .faq-q::-webkit-details-marker { display: none; }
  .faq-q::after { content: '+'; font-size: 18px; color: var(--accent); flex-shrink: 0; transition: transform 0.2s ease; }
  .faq-item[open] .faq-q::after { transform: rotate(45deg); }
  .faq-q:hover { color: var(--accent); }
  .faq-a { padding: 0 var(--sp-lg) var(--sp-md); }
  .faq-a p { font-size: var(--text-sm); color: var(--text-secondary); line-height: 1.65; }

  .value-banner {
    display: flex;
    align-items: center;
    gap: var(--sp-xl);
    background: var(--bg-tertiary);
    border: 0.5px solid var(--border-normal);
    border-radius: var(--radius-lg);
    padding: var(--sp-lg) var(--sp-xl);
    margin: var(--sp-xl) 0;
  }
  @media (max-width: 640px) {
    .value-banner { flex-direction: column; text-align: center; gap: var(--sp-lg); }
    .value-banner-arrow { transform: rotate(90deg); }
  }
  .value-banner-col { flex: 1; }
  .value-banner-col h3 { margin-bottom: 6px; }
  .value-banner-col.accent h3 { color: var(--accent); }
  .value-banner-arrow { font-size: 28px; color: var(--accent); flex-shrink: 0; }

  .case-block {
    background: var(--bg-card);
    border: 0.5px solid var(--border-subtle);
    border-radius: var(--radius-lg);
    padding: var(--sp-lg);
    margin: var(--sp-xl) 0;
  }
  .mock-placeholder {
    background: var(--bg-tertiary);
    border: 0.5px dashed var(--border-normal);
    border-radius: var(--radius-md);
    padding: 40px var(--sp-lg);
    text-align: center;
    font-size: var(--text-xs);
    color: var(--text-muted);
    margin-bottom: var(--sp-md);
  }
  .case-header {
    display: flex;
    align-items: center;
    gap: var(--sp-sm);
    flex-wrap: wrap;
    margin-bottom: var(--sp-sm);
  }
  .case-header h2 { font-size: calc(var(--text-xl) * var(--font-scale)); letter-spacing: -0.5px; }

  /* ── Carrusel de servicios ───────────────────────────────── */
  .services-carousel {
    display: flex;
    gap: 14px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    -webkit-overflow-scrolling: touch;
    cursor: grab;
    /* padding para que la sombra hover no quede cortada */
    padding-bottom: 12px;
    padding-top: 4px;
    /* ocultar scrollbar visualmente */
    scrollbar-width: none;
  }
  .services-carousel::-webkit-scrollbar { display: none; }
  .services-carousel.is-dragging { cursor: grabbing; scroll-behavior: auto; }
</style>
