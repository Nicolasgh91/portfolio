---
import { Fragment } from 'astro/jsx-runtime';
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import ContactForm from '../components/ContactForm.astro';
import SectionWrapper from '../components/SectionWrapper.astro';
import SectionLabel from '../components/SectionLabel.astro';
import FAQAccordion from '../components/FAQAccordion.astro';
import CTAButton from '../components/CTAButton.astro';
import { getCollection } from 'astro:content';
import ServiceCard from '../components/ServiceCard.astro';
import type { CollectionEntry } from 'astro:content';
import pricing from '../data/pricing.json';
import { buildFaqPageJsonLd } from '../lib/faq-jsonld';

// Obtener servicios ordenados desde la colección de contenido
const allServices = await getCollection('services');
const sortedServices = allServices.sort((a, b) => a.data.order - b.data.order);

// FAQ: un archivo JSON = un ítem de colección; `data` es el array validado por Zod.
const faqDocs = await getCollection('faq');
const faqEntries = faqDocs
  .flatMap((doc) => doc.data)
  .sort((a, b) => a.order - b.order);

/** Anclas alineadas con Nav.astro (#agentes-ia, #sitios-web, …). */
function serviceAnchorId(slug: string): string {
  const map: Record<string, string> = {
    'chatbots-ia': 'agentes-ia',
    'landing-page': 'sitios-web',
    'ecommerce-platforms': 'ecommerce',
    'workflow-automation': 'automatizacion',
    'local-llms': 'local-llms',
  };
  return map[slug] ?? `service-${slug}`;
}

type PricingEntry = { price: string; unit?: string; prefix?: string };

type ServicePriceSlug =
  | 'chatbots-ia'
  | 'landing-page'
  | 'local-llms'
  | 'ecommerce-platforms'
  | 'workflow-automation';

const prices = pricing as Record<ServicePriceSlug, PricingEntry>;

/** Sentinel que ServiceCard interpreta como CTA a contacto (no bloque numérico). */
const PRICE_INQUIRE = 'Consultar';

function parsePriceFromFrontmatter(
  data: CollectionEntry<'services'>['data'],
): { price: string; priceUnit?: string; pricePrefix: string } | null {
  const raw = data.priceFrom?.trim();
  if (!raw) return null;
  const ars = raw.match(/^ARS\s+(.+)$/i);
  if (ars) {
    const price = ars[1].trim();
    if (!price) return null;
    return { price, priceUnit: 'ARS', pricePrefix: '' };
  }
  if (raw.startsWith('$')) {
    const price = raw.slice(1).trim();
    if (!price) return null;
    return { price, priceUnit: undefined, pricePrefix: '$' };
  }
  return { price: raw, priceUnit: undefined, pricePrefix: '' };
}

function resolveServicePrice(
  slug: string,
  data: CollectionEntry<'services'>['data'],
): { price?: string; priceUnit?: string; pricePrefix: string } {
  const fromMatter = parsePriceFromFrontmatter(data);
  if (fromMatter) return fromMatter;

  const entry = prices[slug as ServicePriceSlug];
  const numeric = entry?.price?.trim();
  if (numeric) {
    const unit = entry.unit?.trim();
    return {
      price: numeric,
      priceUnit: unit || undefined,
      pricePrefix: entry.prefix ?? '',
    };
  }

  return { price: PRICE_INQUIRE, pricePrefix: '', priceUnit: undefined };
}

function serviceCardPayload(service: CollectionEntry<'services'>) {
  const resolved = resolveServicePrice(service.slug, service.data);
  return {
    title: service.data.title,
    titleEn: service.data.titleEn,
    shortDescription: service.data.shortDescription ?? service.data.description,
    shortDescriptionEn: service.data.shortDescriptionEn ?? service.data.descriptionEn,
    roiFocus: service.data.roiFocus,
    roiFocusEn: service.data.roiFocusEn,
    coverImage: service.data.coverImage,
    imageKey: service.data.imageKey,
    featured: service.data.featured,
    href: service.data.href,
    price: resolved.price,
    priceUnit: resolved.priceUnit,
    pricePrefix: resolved.pricePrefix,
  };
}

const siteUrl = 'https://escalatunegocioconia.com';
const servicesJsonLd = {
  '@context': 'https://schema.org',
  '@graph': sortedServices.map((s) => ({
    '@type': 'Service',
    name: s.data.title,
    description: s.data.shortDescription ?? s.data.description,
    url: `${siteUrl}/servicios#${serviceAnchorId(s.slug)}`,
    provider: {
      '@type': 'Person',
      name: 'Nicolás Hruszczak',
      url: siteUrl,
    },
  })),
};

const faqJsonLd = buildFaqPageJsonLd(faqEntries);

const servicesRow1 = sortedServices.slice(0, 3);
const servicesRow2 = sortedServices.slice(3);

/** RD-4.1 stagger Alt B: `Math.min(i * 100, 600)` según secciones visibles */
const altRevealDelays: Record<string, number> = {};
{
  const keys = [
    'catalog1',
    ...(servicesRow2.length > 0 ? ['catalog2'] : []),
    'caseStudy',
    'how',
    'faq',
    'ctaOrange',
    'contact',
  ];
  keys.forEach((key, i) => {
    altRevealDelays[key] = Math.min(i * 100, 600);
  });
}
---

<Layout
  title="Servicios B2B — Nicolás Hruszczak"
  description="Software a medida, automatización con IA y auditoría de procesos para empresas y pymes que buscan reducir costos y multiplicar resultados."
  ogImage="/og-desktop.png"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(servicesJsonLd)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />
  </Fragment>
  <Nav activePage="servicios" />

  <main id="main-content">
    <SectionWrapper bg="bg-white" tone="default" padding="py-24 md:py-32">
      <div class="max-w-3xl" aria-label="Propuesta de valor">
        <SectionLabel
          text="Servicios para emprendedores · creadores · pymes"
          textEn="For entrepreneurs, creators &amp; small businesses"
        />
        <h1
          class="mt-3 font-display font-extrabold tracking-tight text-slate-900"
          style="font-size: var(--text-5xl);"
        >
          <span data-es
            >Software a medida para <em class="not-italic text-orange-600">multiplicar el ROI</em> de su negocio.</span
          >
          <span data-en class="hidden"
            >Custom software to <em class="not-italic text-orange-600">multiply ROI</em> for your business.</span
          >
        </h1>
        <p class="mt-6 max-w-3xl text-base leading-relaxed text-slate-600">
          <span data-es
            >Si estás empezando, necesitás ordenar la oferta y la conversión sin depender de diez herramientas sueltas. Si
            creás contenido o marca personal, querés un sitio y flujos que te representen sin perder tiempo en
            parches. Si llevás una pyme, el foco es menos fricción día a día y números que se entiendan. En los tres
            casos ayudamos a definir qué conviene automatizar, integrar o construir a medida, con entregas claras y
            seguimiento — sin promesas técnicas vacías.</span
          >
          <span data-en class="hidden"
            >If you are starting out, you need a clear offer and conversion path without juggling ten disconnected
            tools. If you are a creator or personal brand, you want a site and flows that represent you without endless
            workarounds. If you run an SME, the focus is less daily friction and metrics everyone can act on. In all
            three cases we help you decide what to automate, integrate, or build custom — with clear milestones and
            follow-through, not empty technical promises.</span
          >
        </p>
      </div>
    </SectionWrapper>

    <SectionWrapper
      bg="bg-white"
      tone="default"
      padding="py-24 md:py-32"
      revealAlt
      revealDelayMs={altRevealDelays.catalog1}
    >
      <header class="mb-8 md:mb-12" aria-labelledby="services-heading">
        <SectionLabel text="Catálogo" textEn="Catalog" />
        <h2 id="services-heading" class="mt-3 font-display text-3xl font-bold tracking-tight text-slate-900 md:text-4xl">
          <span data-es>Servicios</span>
          <span data-en class="hidden">Services</span>
        </h2>
        <p class="mt-2 max-w-2xl text-sm text-slate-600">
          <span data-es>
            {sortedServices.length} ejes de intervención con impacto directo en la operación.
          </span>
          <span data-en class="hidden">
            {sortedServices.length} focus areas with direct operational impact.
          </span>
        </p>
      </header>

      <div class="mb-6 md:mb-8">
        <SectionLabel text="Más solicitados" textEn="Most requested" />
      </div>

      <p class="mb-3 text-sm text-slate-500 md:hidden">
        <span data-es>Deslizá horizontalmente para ver todos los servicios.</span>
        <span data-en class="hidden">Swipe sideways to see all services.</span>
      </p>

      <div
        class="flex w-max max-w-full snap-x snap-mandatory gap-4 overflow-x-auto pb-4 [scrollbar-width:none] md:grid md:w-full md:snap-none md:grid-cols-2 md:gap-8 md:overflow-visible lg:grid-cols-3 [&::-webkit-scrollbar]:hidden"
        role="region"
        aria-labelledby="services-heading"
        tabindex="0"
      >
        {
          servicesRow1.map((service) => (
            <div
              id={serviceAnchorId(service.slug)}
              class="service-card-anchor w-[min(300px,86vw)] shrink-0 md:w-auto"
            >
              <ServiceCard service={serviceCardPayload(service)} />
            </div>
          ))
        }
      </div>
    </SectionWrapper>

    {
      servicesRow2.length > 0 && (
        <SectionWrapper
          bg="bg-slate-50"
          tone="default"
          padding="py-24 md:py-32"
          revealAlt
          revealDelayMs={altRevealDelays.catalog2}
        >
          <p class="mb-8 text-sm text-slate-500 md:hidden">
            <span data-es>Deslizá para ver el resto del catálogo.</span>
            <span data-en class="hidden">Swipe to see the rest of the catalog.</span>
          </p>
          <div
            class="flex w-max max-w-full snap-x snap-mandatory gap-4 overflow-x-auto pb-4 [scrollbar-width:none] md:grid md:w-full md:snap-none md:grid-cols-2 md:gap-8 md:overflow-visible lg:grid-cols-3 [&::-webkit-scrollbar]:hidden"
            role="region"
            aria-label="Catálogo de servicios, continuación"
            tabindex="0"
          >
            {servicesRow2.map((service) => (
              <div
                id={serviceAnchorId(service.slug)}
                class="service-card-anchor w-[min(300px,86vw)] shrink-0 md:w-auto"
              >
                <ServiceCard service={serviceCardPayload(service)} />
              </div>
            ))}
          </div>
        </SectionWrapper>
      )
    }

    <SectionWrapper
      bg="bg-white"
      tone="default"
      padding="py-24 md:py-32"
      revealAlt
      revealDelayMs={altRevealDelays.caseStudy}
    >
      <SectionLabel text="Caso de uso" textEn="Use case" />
      <div class="mt-6 rounded-2xl border border-slate-200/80 bg-slate-50/80 p-6 md:p-8">
        <div class="mb-4 flex flex-wrap items-center gap-3">
          <h2
            id="case-heading"
            class="font-display text-xl font-bold tracking-tight text-slate-900 md:text-2xl"
          >
            <span data-es>Caso de éxito: gestión integral deportiva (Double Click™)</span>
            <span data-en class="hidden">Success story: comprehensive sports management (Double Click™)</span>
          </h2>
          <span
            class="inline-flex items-center rounded-full border border-amber-200/90 bg-amber-50 px-2.5 py-0.5 text-xs font-semibold text-amber-900"
          >
            <span data-es>En curso</span>
            <span data-en class="hidden">In progress</span>
          </span>
        </div>
        <p class="mb-8 text-sm leading-relaxed text-slate-600">
          <span data-es
            >Una aplicación a medida centraliza reservas, facturación y retención de clientes para un estudio de
            Pilates, eliminando la necesidad de tres herramientas de software con pago mensual.</span
          >
          <span data-en class="hidden"
            >A custom application centralizes bookings, billing, and client retention for a Pilates studio — eliminating
            the need for three separate paid software tools.</span
          >
        </p>
        <div class="grid gap-6 md:grid-cols-2">
          <div
            class="flex min-h-[200px] items-center justify-center rounded-xl border border-dashed border-slate-300 bg-white p-8 text-center text-xs text-slate-500"
            role="img"
            aria-label="Espacio reservado para captura del dashboard de gestión"
          >
            [ Dashboard mockup ]<br /><br />
            Panel de reservas · Métricas · Clientes
          </div>
          <div class="card self-start">
            <h3 class="mb-2 font-display text-base font-bold text-slate-900">
              <span data-es>Resultado</span>
              <span data-en class="hidden">Result</span>
            </h3>
            <p class="text-sm leading-relaxed text-slate-600">
              <span data-es
                >Eliminación de 3 suscripciones mensuales. Reducción significativa del tiempo de gestión administrativa.
                Panel unificado de métricas de retención de clientes.</span
              >
              <span data-en class="hidden"
                >Elimination of 3 monthly subscriptions. Significant reduction in administrative management time.
                Unified client retention metrics panel.</span
              >
            </p>
            <div class="tags mt-4">
              <span class="tag">Python</span>
              <span class="tag">Next.js</span>
              <span class="tag">PostgreSQL</span>
              <a href="#contacto" class="tag tag-accent" data-en="Request similar solution →" data-es="Solicitar solución similar →">
                Solicitar solución similar →
              </a>
            </div>
          </div>
        </div>
      </div>
    </SectionWrapper>

    <SectionWrapper
      bg="bg-slate-950"
      tone="dark"
      padding="py-24 md:py-32"
      revealAlt
      revealDelayMs={altRevealDelays.how}
    >
      <h2 class="mb-4 text-center font-display text-2xl font-bold text-white md:mb-16 md:text-3xl">
        <span data-es>Cómo trabajamos</span>
        <span data-en class="hidden">How we work</span>
      </h2>
      <div class="grid gap-12 md:grid-cols-3">
        <div class="relative pt-1">
          <p
            class="pointer-events-none absolute left-0 top-0 font-display font-black leading-none text-orange-500/10 select-none"
            style="font-size: var(--text-6xl);"
            aria-hidden="true"
          >
            01
          </p>
          <h3 class="relative z-10 mt-10 font-display text-xl font-bold text-white md:mt-12">
            <span data-es>Diagnóstico</span>
            <span data-en class="hidden">Discovery</span>
          </h3>
          <p class="mt-2 text-sm leading-relaxed text-slate-300">
            <span data-es>Entendemos procesos, cuellos de botella y oportunidades de automatización con métricas claras.</span
            >
            <span data-en class="hidden"
              >We map processes, bottlenecks and automation opportunities with clear metrics.</span
            >
          </p>
        </div>
        <div class="relative pt-1">
          <p
            class="pointer-events-none absolute left-0 top-0 font-display font-black leading-none text-orange-500/10 select-none"
            style="font-size: var(--text-6xl);"
            aria-hidden="true"
          >
            02
          </p>
          <h3 class="relative z-10 mt-10 font-display text-xl font-bold text-white md:mt-12">
            <span data-es>Propuesta y entrega</span>
            <span data-en class="hidden">Proposal &amp; delivery</span>
          </h3>
          <p class="mt-2 text-sm leading-relaxed text-slate-300">
            <span data-es>Priorizamos impacto, definimos alcance y ejecutamos con entregas iterativas visibles.</span>
            <span data-en class="hidden">We prioritize impact, define scope and ship in visible iterations.</span>
          </p>
        </div>
        <div class="relative pt-1">
          <p
            class="pointer-events-none absolute left-0 top-0 font-display font-black leading-none text-orange-500/10 select-none"
            style="font-size: var(--text-6xl);"
            aria-hidden="true"
          >
            03
          </p>
          <h3 class="relative z-10 mt-10 font-display text-xl font-bold text-white md:mt-12">
            <span data-es>Evolución</span>
            <span data-en class="hidden">Evolution</span>
          </h3>
          <p class="mt-2 text-sm leading-relaxed text-slate-300">
            <span data-es>Mediciones, mejoras y soporte para que el sistema siga pagándose solo en el tiempo.</span>
            <span data-en class="hidden">Measurement, improvements and support so the system keeps paying for itself.</span>
          </p>
        </div>
      </div>
    </SectionWrapper>

    <SectionWrapper
      bg="bg-white"
      tone="default"
      padding="py-24 md:py-32"
      revealAlt
      revealDelayMs={altRevealDelays.faq}
    >
      <FAQAccordion
        entries={faqEntries}
        ctaHref="#contacto"
        showSidebarCta={false}
        class="!mt-0 border-0 bg-transparent p-0"
      />
    </SectionWrapper>

    <div class="px-6 pb-16 md:pb-24">
      <SectionWrapper
        bg="bg-orange-600"
        tone="accent"
        padding="py-24 md:py-32"
        maxWidth="max-w-4xl"
        class="rounded-3xl"
        innerClass="text-center"
        revealAlt
        revealDelayMs={altRevealDelays.ctaOrange}
      >
        <h2 class="font-display text-2xl font-bold text-white md:text-3xl">
          <span data-es>¿Listo para el siguiente paso?</span>
          <span data-en class="hidden">Ready for the next step?</span>
        </h2>
        <p class="mx-auto mt-3 max-w-xl text-sm leading-relaxed text-white/90">
          <span data-es
            >Agendá un diagnóstico gratuito de 30 minutos: analizamos tu operación y te decimos si tiene sentido trabajar
            juntos. También podés escribirnos por el formulario de abajo cuando quieras.</span
          >
          <span data-en class="hidden"
            >Book a free 30-minute diagnosis — we review your operations and tell you if working together makes sense.
            You can also reach us anytime via the form below.</span
          >
        </p>
        <div class="mt-6 flex justify-center">
          <CTAButton
            href="#contacto"
            label="Ir a contacto"
            labelEn="Go to contact"
            variant="inverse"
          />
        </div>
      </SectionWrapper>
    </div>

    <SectionWrapper
      bg="bg-slate-50"
      tone="default"
      padding="py-24 md:py-32"
      id="contacto"
      revealAlt
      revealDelayMs={altRevealDelays.contact}
    >
      <div class="section-header mb-10">
        <span class="label" data-en="Contact" data-es="Contacto">Contacto</span>
        <h2
          id="contact-heading"
          class="font-display text-2xl font-bold text-slate-900 md:text-3xl"
          data-en="Let's evaluate your challenge"
          data-es="Evaluemos su desafío"
        >
          Evaluemos su desafío
        </h2>
      </div>
      <ContactForm />
    </SectionWrapper>
  </main>

</Layout>
<style>
  .service-card-anchor {
    scroll-margin-top: 7rem;
  }
</style>
