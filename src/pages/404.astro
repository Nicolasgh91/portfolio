---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";
import { localeFromPathname } from "../lib/locale-path";

const isEnglish = localeFromPathname(Astro.url.pathname) === "en";
---

<Layout
  title="404 — Página no encontrada"
  description="La URL solicitada no existe. Volvé al inicio o explorá servicios y artículos técnicos."
  titleEn="404 — Page not found"
  descriptionEn="The requested URL does not exist. Go back home or explore services and technical articles."
>
  <Nav />
  <main
    id="main-content"
    class="mx-auto flex min-h-[60vh] max-w-3xl flex-col items-center justify-center gap-5 px-6 py-16 text-center"
  >
    <p
      class="text-xs font-semibold uppercase tracking-[0.18em] text-[var(--text-muted)]"
    >
      Error 404
    </p>
    <h1
      class="font-display text-4xl font-bold tracking-tight text-[var(--text-primary)] md:text-5xl"
    >
      {isEnglish ? "Page not found" : "Página no encontrada"}
    </h1>
    <p class="max-w-xl text-sm leading-relaxed text-[var(--text-secondary)]">
      {
        isEnglish
          ? "The route you tried to open is not available. You can go back home or continue through the main sections."
          : "La ruta que intentaste abrir no está disponible. Podés volver al inicio o seguir por las secciones principales."
      }
    </p>
    <div class="flex flex-wrap items-center justify-center gap-3">
      <a href={isEnglish ? "/en" : "/"} class="btn-primary btn-bounce">
        {isEnglish ? "Go home" : "Ir al inicio"}
      </a>
      <a href={isEnglish ? "/en/services" : "/servicios"} class="btn-secondary">
        {isEnglish ? "View services" : "Ver servicios"}
      </a>
      <a href={isEnglish ? "/en/blog" : "/blog"} class="btn-secondary">
        {isEnglish ? "Read blog" : "Leer blog"}
      </a>
    </div>
  </main>
</Layout>
