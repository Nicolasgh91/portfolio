---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import TaxonomyFilter from '../../components/TaxonomyFilter.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();

// Datos para JSON-LD
const siteUrl = 'https://escalatunegocioconia.com';
const postUrl = `${siteUrl}/blog/${post.slug}`;
const authorName = 'Nicolás Hruszczak';
const pubDateISO = post.data.pubDate.toISOString();

// JSON-LD: Article schema
const articleJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: post.data.title,
  description: post.data.description,
  datePublished: pubDateISO,
  dateModified: pubDateISO,
  author: {
    '@type': 'Person',
    name: authorName,
    url: siteUrl,
  },
  publisher: {
    '@type': 'Person',
    name: authorName,
    url: siteUrl,
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': postUrl,
  },
  keywords: post.data.tags.join(', '),
  articleSection: post.data.category,
  inLanguage: 'es-AR',
  url: postUrl,
};

// JSON-LD: BreadcrumbList schema
const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Inicio',
      item: siteUrl,
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'Blog',
      item: `${siteUrl}/blog`,
    },
    {
      '@type': 'ListItem',
      position: 3,
      name: post.data.title,
      item: postUrl,
    },
  ],
};

// Formatear fecha
function formatDate(date: Date): string {
  return date.toLocaleDateString('es-AR', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}

// Para el filtro lateral
const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const allCategories = [...new Set(allPosts.map((p) => p.data.category))].sort();
const allTags = [...new Set(allPosts.flatMap((p) => p.data.tags))].sort();

// Artículos relacionados (misma categoría, excluyendo el actual)
const related = allPosts
  .filter((p) => p.slug !== post.slug && p.data.category === post.data.category)
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 2);
---

<Layout
  title={`${post.data.title} — Nicolás Hruszczak`}
  description={post.data.description}
  ogImage={post.data.coverImage ?? '/og-desktop.png'}
>
  <!-- JSON-LD inyectado en el <head> via slot -->
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(articleJsonLd)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} />
    <!-- Open Graph adicionales para artículos -->
    <meta property="og:type" content="article" />
    <meta property="article:published_time" content={pubDateISO} />
    <meta property="article:author" content={authorName} />
    <meta property="article:section" content={post.data.category} />
    {post.data.tags.map((tag) => (
      <meta property="article:tag" content={tag} />
    ))}
  </Fragment>

  <Nav activePage="blog" />

  <main id="main-content">
    <div class="page-container">

      <!-- Breadcrumb visible -->
      <nav class="breadcrumb" aria-label="Ruta de navegación">
        <a href="/">Inicio</a>
        <span aria-hidden="true">/</span>
        <a href="/blog">Blog</a>
        <span aria-hidden="true">/</span>
        <a href={`/blog/categoria/${post.data.category}`}>{post.data.category}</a>
        <span aria-hidden="true">/</span>
        <span aria-current="page">{post.data.title}</span>
      </nav>

      <div class="article-layout">

        <!-- ── Columna principal ──────────────────────────── -->
        <div class="article-main">

          <!-- Header del artículo -->
          <header class="post-header">
            <div class="post-meta">
              <a href={`/blog/categoria/${post.data.category}`} class="post-category">
                {post.data.category}
              </a>
              <time datetime={pubDateISO} class="post-date">
                {formatDate(post.data.pubDate)}
              </time>
              {post.data.readingTime && (
                <span class="post-reading"
                  data-en={`${post.data.readingTime} min read`}
                  data-es={`${post.data.readingTime} min de lectura`}
                >{post.data.readingTime} min de lectura</span>
              )}
            </div>

            <h1
              data-en={post.data.titleEn ?? post.data.title}
              data-es={post.data.title}
            >{post.data.title}</h1>

            <p
              class="post-description"
              data-en={post.data.descriptionEn ?? post.data.description}
              data-es={post.data.description}
            >{post.data.description}</p>

            <div class="tags" style="margin-top: var(--sp-md);">
              {post.data.tags.map((tag) => (
                <a href={`/blog/etiqueta/${tag}`} class="tag">{tag}</a>
              ))}
            </div>
          </header>

          <div class="divider"></div>

          <!-- Cuerpo MDX -->
          <article class="prose" aria-label={`Contenido: ${post.data.title}`}>
            <Content />
          </article>

          <div class="divider"></div>

          <!-- Footer del artículo -->
          <footer class="post-footer">
            <div class="post-footer__author">
              <div class="post-footer__avatar" aria-hidden="true">NH</div>
              <div>
                <p class="post-footer__name">{authorName}</p>
                <p class="post-footer__role"
                  data-en="Functional analyst & full stack developer"
                  data-es="Analista funcional y desarrollador full stack"
                >Analista funcional y desarrollador full stack</p>
              </div>
            </div>
            <div class="post-footer__actions">
              <a href="/blog" class="btn-secondary"
                data-en="← Back to blog"
                data-es="← Volver al blog"
              >← Volver al blog</a>
              <a href="/servicios#contacto" class="btn-primary"
                data-en="Let's work together →"
                data-es="Hablemos →"
              >Hablemos →</a>
            </div>
          </footer>

          <!-- Artículos relacionados -->
          {related.length > 0 && (
            <section class="related" aria-labelledby="related-heading">
              <h2 id="related-heading" class="related__title"
                data-en="Related articles"
                data-es="Artículos relacionados"
              >Artículos relacionados</h2>
              <div class="related__grid">
                {related.map((r) => (
                  <a href={`/blog/${r.slug}`} class="related__card">
                    <span class="related__cat">{r.data.category}</span>
                    <h3
                      data-en={r.data.titleEn ?? r.data.title}
                      data-es={r.data.title}
                    >{r.data.title}</h3>
                    <span class="related__cta"
                      data-en="Read →"
                      data-es="Leer →"
                    >Leer →</span>
                  </a>
                ))}
              </div>
            </section>
          )}
        </div>

        <!-- ── Sidebar ────────────────────────────────────── -->
        <aside class="article-sidebar" aria-label="Navegación del blog">
          <div class="sidebar-sticky">
            <p class="sidebar-heading"
              data-en="Browse by topic"
              data-es="Explorar por tema"
            >Explorar por tema</p>
            <TaxonomyFilter
              categories={allCategories}
              tags={allTags}
              activeCategory={post.data.category}
            />
          </div>
        </aside>

      </div>
    </div>
  </main>

  <footer class="site-footer">
    <div class="page-container footer-inner">
      <a href="/" style="font-family:var(--font-display);font-size:16px;font-weight:800;color:var(--text-muted);text-decoration:none">
        nh<span style="color:var(--accent)">.</span>
      </a>
      <div style="display:flex;gap:var(--sp-md)">
        <a href="/blog" style="font-size:var(--text-xs);color:var(--text-muted)">Blog</a>
        <a href="/servicios" style="font-size:var(--text-xs);color:var(--text-muted)">Servicios</a>
        <a href="/talento" style="font-size:var(--text-xs);color:var(--text-muted)">Perfil</a>
        <a href="mailto:comercial@escalatunegocioconia.com"
          style="font-size:var(--text-xs);color:var(--text-muted)">Contacto</a>
      </div>
    </div>
  </footer>
</Layout>

<style>
  /* ── Breadcrumb ─────────────────────────────────────────── */
  .breadcrumb {
    display: flex;
    align-items: center;
    gap: var(--sp-sm);
    font-size: var(--text-xs);
    color: var(--text-muted);
    padding: var(--sp-md) 0 var(--sp-xl);
    flex-wrap: wrap;
  }
  .breadcrumb a { color: var(--text-muted); transition: color 0.15s; }
  .breadcrumb a:hover { color: var(--accent); }
  .breadcrumb span[aria-hidden] { opacity: 0.4; }

  /* ── Layout ─────────────────────────────────────────────── */
  .article-layout {
    display: grid;
    grid-template-columns: 1fr 240px;
    gap: var(--sp-xl);
    align-items: start;
  }
  @media (max-width: 780px) {
    .article-layout { grid-template-columns: 1fr; }
    .article-sidebar { display: none; }
  }

  /* ── Sidebar ────────────────────────────────────────────── */
  .sidebar-sticky {
    position: sticky;
    top: 80px;
  }
  .sidebar-heading {
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: var(--sp-md);
  }

  /* ── Header del artículo ────────────────────────────────── */
  .post-header { margin-bottom: var(--sp-lg); }
  .post-meta {
    display: flex;
    align-items: center;
    gap: var(--sp-sm);
    margin-bottom: var(--sp-md);
    flex-wrap: wrap;
  }
  .post-category {
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--accent-text);
    background: var(--accent-bg);
    border: 0.5px solid var(--accent-border);
    border-radius: var(--radius-pill);
    padding: 2px 10px;
    text-decoration: none;
  }
  .post-date { font-size: var(--text-xs); color: var(--text-muted); }
  .post-reading {
    font-size: var(--text-xs);
    color: var(--text-muted);
  }
  .post-reading::before { content: '·'; margin-right: var(--sp-sm); }

  .post-header h1 {
    font-size: calc(var(--text-2xl) * var(--font-scale));
    margin-bottom: var(--sp-sm);
    line-height: 1.15;
  }
  .post-description {
    font-size: calc(var(--text-base) * var(--font-scale));
    color: var(--text-secondary);
    line-height: 1.75;
  }
  .tags a { text-decoration: none; transition: border-color 0.15s, color 0.15s; }
  .tags a:hover { border-color: var(--accent-border); color: var(--accent-text); }

  /* ── Prosa del artículo ─────────────────────────────────── */
  .prose { max-width: 100%; }

  .prose :global(h2) {
    font-size: calc(var(--text-xl) * var(--font-scale));
    margin-top: var(--sp-xl);
    margin-bottom: var(--sp-md);
    letter-spacing: -0.5px;
    color: var(--text-primary);
  }
  .prose :global(h3) {
    font-size: calc(var(--text-lg) * var(--font-scale));
    margin-top: var(--sp-lg);
    margin-bottom: var(--sp-sm);
    color: var(--text-primary);
  }
  .prose :global(p) {
    color: var(--text-secondary);
    line-height: 1.8;
    margin-bottom: var(--sp-md);
    font-size: calc(var(--text-base) * var(--font-scale));
  }
  .prose :global(ul),
  .prose :global(ol) {
    padding-left: var(--sp-lg);
    margin-bottom: var(--sp-md);
    color: var(--text-secondary);
  }
  .prose :global(li) {
    margin-bottom: var(--sp-sm);
    line-height: 1.75;
    font-size: calc(var(--text-base) * var(--font-scale));
  }
  .prose :global(strong) { color: var(--text-primary); font-weight: 600; }
  .prose :global(em) { color: var(--accent); font-style: normal; }
  .prose :global(a) { color: var(--accent); text-decoration: underline; text-underline-offset: 3px; }
  .prose :global(a:hover) { color: var(--accent-hover); }
  .prose :global(code) {
    background: var(--bg-tertiary);
    border: 0.5px solid var(--border-subtle);
    border-radius: 4px;
    padding: 2px 6px;
    font-family: var(--font-mono);
    font-size: 0.88em;
    color: var(--accent-text);
  }
  .prose :global(pre) {
    background: var(--bg-tertiary);
    border: 0.5px solid var(--border-normal);
    border-radius: var(--radius-md);
    padding: var(--sp-lg);
    overflow-x: auto;
    margin-bottom: var(--sp-md);
  }
  .prose :global(pre code) {
    background: none;
    border: none;
    padding: 0;
    color: var(--text-secondary);
    font-size: var(--text-sm);
  }
  .prose :global(blockquote) {
    border-left: 3px solid var(--accent);
    padding: var(--sp-sm) var(--sp-md);
    margin: var(--sp-md) 0;
    background: var(--accent-bg);
    border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
  }
  .prose :global(blockquote p) { margin-bottom: 0; color: var(--text-secondary); }
  .prose :global(hr) {
    border: none;
    border-top: 0.5px solid var(--border-subtle);
    margin: var(--sp-xl) 0;
  }

  /* ── Footer del artículo ────────────────────────────────── */
  .post-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--sp-lg);
    flex-wrap: wrap;
    padding: var(--sp-lg) 0;
  }
  .post-footer__author {
    display: flex;
    align-items: center;
    gap: var(--sp-md);
  }
  .post-footer__avatar {
    width: 44px; height: 44px;
    border-radius: var(--radius-md);
    background: var(--accent-bg);
    border: 0.5px solid var(--accent-border);
    display: flex; align-items: center; justify-content: center;
    font-family: var(--font-display); font-size: 14px; font-weight: 800; color: var(--accent);
    flex-shrink: 0;
  }
  .post-footer__name {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 2px;
  }
  .post-footer__role {
    font-size: var(--text-xs);
    color: var(--text-muted);
  }
  .post-footer__actions {
    display: flex;
    gap: var(--sp-sm);
    flex-wrap: wrap;
  }

  /* ── Artículos relacionados ─────────────────────────────── */
  .related { margin-top: var(--sp-xl); }
  .related__title {
    font-size: calc(var(--text-lg) * var(--font-scale));
    margin-bottom: var(--sp-lg);
    letter-spacing: -0.3px;
  }
  .related__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: var(--sp-md);
  }
  .related__card {
    display: flex;
    flex-direction: column;
    gap: var(--sp-sm);
    padding: var(--sp-lg);
    background: var(--bg-card);
    border: 0.5px solid var(--border-subtle);
    border-radius: var(--radius-lg);
    text-decoration: none;
    color: inherit;
    transition: border-color 0.15s ease, transform 0.15s ease;
  }
  .related__card:hover {
    border-color: var(--accent-border);
    transform: translateY(-2px);
  }
  .related__cat {
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    color: var(--accent-text);
  }
  .related__card h3 {
    font-size: calc(var(--text-sm) * var(--font-scale));
    font-weight: 600;
    line-height: 1.4;
    color: var(--text-primary);
    margin: 0;
    /* Corregir herencia de h3 global */
    letter-spacing: -0.2px;
  }
  .related__cta {
    font-size: var(--text-xs);
    color: var(--accent);
    margin-top: auto;
  }

  /* ── Footer del sitio ───────────────────────────────────── */
  .site-footer { border-top: 0.5px solid var(--border-subtle); padding: var(--sp-lg) 0; margin-top: var(--sp-2xl); }
  .footer-inner { display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: var(--sp-md); padding-top: 0; padding-bottom: 0; }
</style>
