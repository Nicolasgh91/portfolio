---
import Layout from "../../../layouts/Layout.astro";
import Nav from "../../../components/Nav.astro";
import BlogCard from "../../../components/BlogCard.astro";
import TaxonomyFilter from "../../../components/TaxonomyFilter.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }) => !data.draft);

  // Extraer etiquetas únicas
  const tags = [...new Set(posts.flatMap((p) => p.data.tags))];

  return tags.map((tag) => ({
    params: { tag },
    props: {
      tag,
      posts: posts
        .filter((p) => p.data.tags.includes(tag))
        .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()),
    },
  }));
}

const { tag, posts } = Astro.props;

// Para el filtro lateral
const allPosts = await getCollection("blog", ({ data }) => !data.draft);
const allCategories = [...new Set(allPosts.map((p) => p.data.category))].sort();
const allTags = [...new Set(allPosts.flatMap((p) => p.data.tags))].sort();
---

<Layout
  title={`#${tag} — Blog técnico · Nicolás Hruszczak`}
  description={`Artículos etiquetados con ${tag}: arquitectura de software, IA aplicada y automatización para empresas.`}
>
  <Nav activePage="blog" />

  <main id="main-content">
    <div class="page-container">
      <section class="hero" aria-label={`Etiqueta: ${tag}`}>
        <div class="badge" data-en="Tag" data-es="Etiqueta">Etiqueta</div>
        <h1>#{tag}</h1>
        <p class="hero-sub">
          {posts.length} artículo{posts.length !== 1 ? "s" : ""} con esta etiqueta.
        </p>
      </section>

      <div class="reveal reveal--scale" style="--reveal-delay: 0ms">
        <TaxonomyFilter
          categories={allCategories}
          tags={allTags}
          activeTag={tag}
        />
      </div>

      <section class="section" aria-labelledby="posts-heading">
        <h2
          id="posts-heading"
          class="posts-section-title reveal reveal--scale"
          style="--reveal-delay: 0ms"
          data-en={`Articles tagged #${tag}`}
          data-es={`Artículos con #${tag}`}
        >
          Artículos con #{tag}
        </h2>
        <div class="posts-grid">
          {
            posts.map((post, i) => (
              <div
                class="reveal reveal--scale"
                style={`--reveal-delay: ${Math.min(i * 100, 600)}ms`}
              >
                <BlogCard post={post} />
              </div>
            ))
          }
        </div>
      </section>
    </div>
  </main>
</Layout>

<style>
  .posts-section-title {
    font-size: calc(var(--text-xl) * var(--font-scale));
    font-weight: 700;
    letter-spacing: -0.5px;
    margin-bottom: var(--sp-lg);
  }
  .posts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: var(--sp-md);
  }
</style>
