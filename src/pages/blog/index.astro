---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import BlogCard from '../../components/BlogCard.astro';
import TaxonomyFilter from '../../components/TaxonomyFilter.astro';
import { getCollection } from 'astro:content';

// Filtra donde draft NO es true
const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const posts = allPosts.sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()
);

const categories = [...new Set(posts.map((p) => p.data.category))].sort();
const tags = [...new Set(posts.flatMap((p) => p.data.tags))].sort();
---

<Layout
  title="Blog técnico — Nicolás Hruszczak"
  description="Artículos sobre arquitectura de software, inteligencia artificial aplicada y automatización para empresas. Perspectiva práctica, sin teoría vacía."
  ogImage="/og-desktop.png"
>
  <Nav activePage="blog" />

  <main id="main-content">
    <div class="page-container">

      <section class="hero" aria-label="Blog técnico">
        <div class="badge"
          data-en="Technical articles"
          data-es="Artículos técnicos"
        >Artículos técnicos</div>
        <h1
          data-en="Architecture, AI &amp; automation"
          data-es="Arquitectura, IA y automatización"
        >Arquitectura, IA y automatización</h1>
        <p class="hero-sub"
          data-en="Practical perspective on software, artificial intelligence and process optimization. No empty theory."
          data-es="Perspectiva práctica sobre software, inteligencia artificial y optimización de procesos. Sin teoría vacía."
        >Perspectiva práctica sobre software, inteligencia artificial y optimización de procesos. Sin teoría vacía.</p>
      </section>

      <TaxonomyFilter {categories} />

      <section class="section" aria-labelledby="posts-heading">
        <div class="section-header">
          <span class="label">{posts.length} artículo{posts.length !== 1 ? 's' : ''}</span>
          <h2 id="posts-heading" class="sr-only">Artículos</h2>
        </div>

        {posts.length === 0 ? (
          <p class="empty">Próximamente...</p>
        ) : (
          <div class="posts-grid">
            {posts.map((post) => <BlogCard post={post} />)}
          </div>
        )}
      </section>

      {tags.length > 0 && (
        <section class="section" aria-labelledby="blog-tags-heading">
          <div class="section-header">
            <h2 id="blog-tags-heading" class="label">Etiquetas</h2>
          </div>
          <div class="flex flex-wrap gap-2">
            {tags.map((tag) => (
              <a
                href={`/blog/etiqueta/${encodeURIComponent(tag)}`}
                class="inline-flex items-center rounded-full border border-[color:var(--border-subtle)] bg-[var(--bg-tertiary)]/50 px-3 py-1 text-xs text-[var(--text-secondary)] no-underline transition-all duration-200 hover:border-[color:var(--color-accent-400)]/30 hover:text-[var(--color-accent-400)]"
              >
                #{tag}
              </a>
            ))}
          </div>
        </section>
      )}

    </div>
  </main>

</Layout>

<style>
  .posts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: var(--sp-md);
  }
  .empty {
    color: var(--text-muted);
    text-align: center;
    padding: var(--sp-xl) 0;
  }
  /* Clase utilitaria para h2 accesible pero invisible */
  .sr-only {
    position: absolute;
    width: 1px; height: 1px;
    padding: 0; margin: -1px;
    overflow: hidden;
    clip: rect(0,0,0,0);
    white-space: nowrap;
    border: 0;
  }
</style>
