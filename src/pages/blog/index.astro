---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import BlogCard from '../../components/BlogCard.astro';
import TaxonomyFilter from '../../components/TaxonomyFilter.astro';
import { getCollection } from 'astro:content';

// Filtra donde draft NO es true
const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const posts = allPosts.sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()
);

const categories = [...new Set(posts.map((p) => p.data.category))].sort();
const tags = [...new Set(posts.flatMap((p) => p.data.tags))].sort();
---

<Layout
  title="Blog técnico — Nicolás Hruszczak"
  description="Artículos sobre arquitectura de software, inteligencia artificial aplicada y automatización para empresas. Perspectiva práctica, sin teoría vacía."
  ogImage="/og-desktop.png"
>
  <Nav activePage="blog" />

  <main id="main-content">
    <div class="page-container">

      <section class="hero" aria-label="Blog técnico">
        <div class="badge"
          data-en="Technical articles"
          data-es="Artículos técnicos"
        >Artículos técnicos</div>
        <h1
          data-en="Architecture, AI &amp; automation"
          data-es="Arquitectura, IA y automatización"
        >Arquitectura, IA y automatización</h1>
        <p class="hero-sub"
          data-en="Practical perspective on software, artificial intelligence and process optimization. No empty theory."
          data-es="Perspectiva práctica sobre software, inteligencia artificial y optimización de procesos. Sin teoría vacía."
        >Perspectiva práctica sobre software, inteligencia artificial y optimización de procesos. Sin teoría vacía.</p>
      </section>

      <TaxonomyFilter {categories} {tags} />

      <section class="section" aria-labelledby="posts-heading">
        <div class="section-header">
          <span class="label">{posts.length} artículo{posts.length !== 1 ? 's' : ''}</span>
          <h2 id="posts-heading" class="sr-only">Artículos</h2>
        </div>

        {posts.length === 0 ? (
          <p class="empty">Próximamente...</p>
        ) : (
          <div class="posts-grid">
            {posts.map((post) => <BlogCard post={post} />)}
          </div>
        )}
      </section>

    </div>
  </main>

  <footer class="site-footer">
    <div class="page-container footer-inner">
      <a href="/" style="font-family:var(--font-display);font-size:16px;font-weight:800;color:var(--text-muted);text-decoration:none">
        nh<span style="color:var(--accent)">.</span>
      </a>
      <div style="display:flex;gap:var(--sp-md)">
        <a href="/servicios" style="font-size:var(--text-xs);color:var(--text-muted)"
          data-en="Services" data-es="Servicios">Servicios</a>
        <a href="/talento" style="font-size:var(--text-xs);color:var(--text-muted)"
          data-en="Profile" data-es="Perfil">Perfil</a>
        <a href="mailto:comercial@escalatunegocioconia.com"
          style="font-size:var(--text-xs);color:var(--text-muted)">Contacto</a>
      </div>
    </div>
  </footer>
</Layout>

<style>
  .posts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: var(--sp-md);
  }
  .empty {
    color: var(--text-muted);
    text-align: center;
    padding: var(--sp-xl) 0;
  }
  /* Clase utilitaria para h2 accesible pero invisible */
  .sr-only {
    position: absolute;
    width: 1px; height: 1px;
    padding: 0; margin: -1px;
    overflow: hidden;
    clip: rect(0,0,0,0);
    white-space: nowrap;
    border: 0;
  }
  .site-footer { border-top: 0.5px solid var(--border-subtle); padding: var(--sp-lg) 0; margin-top: var(--sp-2xl); }
  .footer-inner { display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: var(--sp-md); padding-top: 0; padding-bottom: 0; }
</style>
