---
import Layout from "../../layouts/Layout.astro";
import Nav from "../../components/Nav.astro";
import ContactForm from "../../components/ContactForm.astro";
import { localeFromPathname } from "../../lib/locale-path";

const title =
  "Menú digital y landing desde ARS 20.000 — escalatunegocioconia.com";
const description =
  "Landing page indexable, formulario de contacto y WhatsApp directo. Ideal para viandas, pymes y profesionales que venden hoy por Instagram o PDF.";
const titleEn =
  "Digital menu and landing from ARS 20,000 — escalatunegocioconia.com";
const descriptionEn =
  "Indexable landing page, contact form and direct WhatsApp. Ideal for meal prep businesses, SMEs and professionals currently selling through Instagram or PDF.";
const isEnglish = localeFromPathname(Astro.url.pathname) === "en";
const templatesHref = isEnglish ? "/en/templates" : "/plantillas";
const servicesContactHref = isEnglish
  ? "/en/services#contacto"
  : "/servicios#contacto";
---

<Layout
  {title}
  {description}
  {titleEn}
  {descriptionEn}
  ogImage="/og-desktop.png"
>
  <Nav activePage="servicios" />

  <main id="main-content">
    <div class="page-container py-12">
      <article class="mx-auto max-w-2xl">
        <p
          class="mb-2 text-xs font-semibold uppercase tracking-wide text-[var(--text-muted)]"
        >
          {isEnglish ? "Offer · Tier 0" : "Oferta · Tier 0"}
        </p>
        <h1
          class="mb-4 font-display text-3xl font-extrabold tracking-tight text-[var(--text-primary)] md:text-4xl"
        >
          {
            isEnglish
              ? "Your digital menu or professional landing from "
              : "Tu menú digital o landing profesional desde "
          }
          <span class="text-[var(--accent)]">ARS 20.000</span>
        </h1>
        <p class="mb-8 text-base leading-relaxed text-[var(--text-secondary)]">
          {
            isEnglish
              ? "Replace the static PDF with a website Google can index. Includes a clear commercial structure, form and WhatsApp calls. The assistant in the lower corner answers inquiries 24/7 on this site; the same approach applies to your project."
              : "Reemplazá el PDF estático por una web que Google puede indexar. Incluye estructura comercial clara, formulario y llamados a WhatsApp. El asistente de la esquina inferior responde consultas 24/7 en este sitio; el mismo enfoque se aplica a tu proyecto."
          }
        </p>

        <ul
          class="mb-10 list-none space-y-3 text-sm text-[var(--text-secondary)]"
        >
          <li class="flex gap-2">
            <span class="text-[var(--accent)]" aria-hidden="true">✓</span>
            <span
              >{
                isEnglish
                  ? "Delivery in 1-2 weeks, deployed on Vercel."
                  : "Entrega en 1–2 semanas, deploy en Vercel."
              }</span
            >
          </li>
          <li class="flex gap-2">
            <span class="text-[var(--accent)]" aria-hidden="true">✓</span>
            <span
              >{
                isEnglish
                  ? "Designed to scale later with chatbot, cart or monthly SEO."
                  : "Pensado para escalar después con chatbot, carrito o SEO mensual."
              }</span
            >
          </li>
          <li class="flex gap-2">
            <span class="text-[var(--accent)]" aria-hidden="true">✓</span>
            <span
              >{
                isEnglish
                  ? "Free initial diagnosis to align scope."
                  : "Diagnóstico inicial sin costo para alinear alcance."
              }</span
            >
          </li>
        </ul>

        <p class="mb-4 text-sm text-[var(--text-muted)]">
          <a
            href={templatesHref}
            class="text-[var(--accent-text)] underline-offset-2 hover:underline"
          >
            {
              isEnglish
                ? "View templates in the catalog"
                : "Ver plantillas en el catálogo"
            }
          </a>
          ·
          <a
            href={servicesContactHref}
            class="text-[var(--accent-text)] underline-offset-2 hover:underline"
          >
            {
              isEnglish
                ? "Go to the Services form"
                : "Ir al formulario en Servicios"
            }
          </a>
        </p>
      </article>

      <section
        id="contacto"
        class="mx-auto mt-12 max-w-xl"
        aria-labelledby="oferta-contact-heading"
      >
        <h2
          id="oferta-contact-heading"
          class="mb-4 font-display text-xl font-bold text-[var(--text-primary)]"
        >
          {isEnglish ? "Request this offer" : "Solicitar esta oferta"}
        </h2>
        <ContactForm />
      </section>
    </div>
  </main>
</Layout>
