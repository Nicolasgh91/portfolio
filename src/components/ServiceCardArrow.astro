---
/**
 * Flecha "Ver servicio →" para las variantes de ServiceCard con href propio.
 * Pura markup sin props. Extraído de ServiceCard.astro (M-08).
 */
---

<span class="mt-1 inline-flex items-center gap-1 text-sm font-semibold text-[var(--accent)]">
  <span data-en="View service" data-es="Ver servicio">Ver servicio</span>
  <span class="arrow" aria-hidden="true">
    <svg
      width="14"
      height="14"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2.2"
      stroke-linecap="round"
      stroke-linejoin="round"
      class="shrink-0"
    >
      <path d="M5 12h14M13 6l6 6-6 6" />
    </svg>
  </span>
</span>
