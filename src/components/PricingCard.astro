---
import type { PricingPlan } from "../schemas";
import { localeFromPathname } from "../lib/locale-path";

interface Props {
  plan: PricingPlan;
  /** Para ordenar en grid (p. ej. destacado al centro en desktop) */
  orderClass?: string;
}

const { plan, orderClass = "" } = Astro.props;
const isEnglish = localeFromPathname(Astro.url.pathname) === "en";

const nameEs = plan.name;
const nameEn = plan.nameEn ?? plan.name;
const pitchEs = plan.pitch;
const pitchEn = plan.pitchEn ?? plan.pitch;
const featuresEn = plan.featuresEn ?? plan.features;

const isRecommended = plan.recommended;

const badgeEs = plan.recommendedLabel ?? "Recomendado";
const badgeEn = plan.recommendedLabelEn ?? "Recommended";
---

<article
  class:list={[
    "relative flex h-full flex-col overflow-visible rounded-[24px] p-8 transition-all duration-300",
    orderClass,
    isRecommended
      ? "bg-[var(--bg-surface-container-lowest)] -translate-y-2 shadow-[0_20px_48px_-24px_var(--accent-glow)] hover:-translate-y-3 hover:shadow-[0_26px_56px_-22px_var(--accent-glow)]"
      : "bg-[var(--bg-surface-container-low)] hover:-translate-y-0.5 hover:bg-[var(--bg-tertiary)]",
  ]}
  aria-label={isRecommended
    ? isEnglish
      ? `${nameEn} - recommended plan`
      : `${nameEs} - plan recomendado`
    : undefined}
>
  {
    isRecommended && (
      <div
        class="pointer-events-none absolute inset-[-2px] -z-[1] rounded-[26px] bg-[radial-gradient(circle_at_top,hsla(var(--accent-h),var(--accent-s),56%,0.22)_0%,transparent_62%)]"
        aria-hidden="true"
      />
    )
  }
  {
    isRecommended && (
      <div class="pointer-events-none absolute -top-3 left-0 right-0 z-[2] flex justify-center">
        <span
          class="whitespace-nowrap rounded-full bg-[var(--accent)] px-4 py-1 text-[11px] font-bold tracking-[0.3px] text-[var(--color-on-accent)]"
          data-es={badgeEs}
          data-en={badgeEn}
        >
          {isEnglish ? badgeEn : badgeEs}
        </span>
      </div>
    )
  }
  <div class:list={["mb-4", isRecommended && "mt-2"]}>
    <h3
      class="font-[family-name:var(--font-display)] text-xl font-semibold text-[var(--text-primary)]"
      data-es={nameEs}
      data-en={nameEn}
    >
      {isEnglish ? nameEn : nameEs}
    </h3>
    <p
      class="mt-2 min-h-[72px] text-sm leading-relaxed text-[var(--text-secondary)]"
      data-es={pitchEs}
      data-en={pitchEn}
    >
      {isEnglish ? pitchEn : pitchEs}
    </p>
  </div>
  {
    isRecommended && (
      <p class="sr-only" data-es="Plan recomendado" data-en="Recommended plan">
        {isEnglish ? "Recommended plan" : "Plan recomendado"}
      </p>
    )
  }
  <div
    class="mt-[19px] mb-6 h-px bg-[var(--border-subtle)] opacity-70"
    aria-hidden="true"
  >
  </div>
  <ul
    class="mb-6 flex flex-1 flex-col gap-0 text-sm text-[var(--text-secondary)]"
  >
    {
      plan.features.map((f, i) => (
        <li class="flex items-start gap-2.5 py-1.5 font-light">
          <span
            class="mt-0.5 flex h-4 w-4 min-w-[1rem] shrink-0 items-center justify-center rounded-full border border-[var(--accent-border)] bg-[var(--accent-bg)]"
            aria-hidden="true"
          >
            <svg
              width="10"
              height="8"
              viewBox="0 0 10 8"
              fill="none"
              xmlns="http://www.w3.org/2000/svg"
              class="text-[var(--accent)]"
              aria-hidden="true"
            >
              <path
                d="M1 3.5L3.8 6.5L9 1"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"
              />
            </svg>
          </span>
          <span data-es={f} data-en={featuresEn[i] ?? f}>
            {isEnglish ? (featuresEn[i] ?? f) : f}
          </span>
        </li>
      ))
    }
  </ul>
</article>
