<button
  type="button"
  data-back-to-top
  aria-label="Volver arriba"
  class="pointer-events-none fixed bottom-[28px] left-1/2 z-40 inline-flex h-[58px] w-[58px] -translate-x-1/2 items-center justify-center rounded-full border border-white/15 bg-black/55 text-white opacity-0 shadow-[0_8px_30px_rgba(0,0,0,0.35)] backdrop-blur-md transition hover:border-[color:var(--color-accent-400)]/40 hover:bg-black/65 max-[480px]:bottom-[20px]"
>
  <span aria-hidden="true" class="text-lg leading-none">↑</span>
</button>

<script>
  (() => {
    const button = document.querySelector('[data-back-to-top]');
    if (!(button instanceof HTMLButtonElement)) return;

    const threshold = 300;

    const syncVisibility = () => {
      const isVisible = window.scrollY > threshold;
      button.classList.toggle('opacity-0', !isVisible);
      button.classList.toggle('pointer-events-none', !isVisible);
    };

    button.addEventListener('click', () => {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });

    window.addEventListener('scroll', syncVisibility, { passive: true });
    syncVisibility();
  })();
</script>
