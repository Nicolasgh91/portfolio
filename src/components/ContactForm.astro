---
// Web3Forms contact form
// 1. Go to https://web3forms.com and enter your email
// 2. Copy the Access Key you receive
// 3. Replace YOUR_WEB3FORMS_ACCESS_KEY below with your actual key
//    (you can also store it in a .env file as PUBLIC_WEB3FORMS_KEY
//     and reference it as import.meta.env.PUBLIC_WEB3FORMS_KEY)
import { localeFromPathname } from "../lib/locale-path";

const WEB3FORMS_KEY =
  import.meta.env.PUBLIC_WEB3FORMS_KEY ?? "YOUR_WEB3FORMS_ACCESS_KEY";
const isEnglish = localeFromPathname(Astro.url.pathname) === "en";
---

<div
  class="rounded-[var(--radius-lg)] border-[0.5px] border-[var(--border-normal)] bg-[var(--bg-secondary)] p-[var(--sp-xl)] mt-[var(--sp-xl)]"
  role="form"
  aria-label={isEnglish ? "B2B contact form" : "Formulario de contacto B2B"}
>
  <h3
    class="mb-1.5"
    data-en="Evaluate your company's potential"
    data-es="Evaluar el potencial de su empresa"
  >
    {
      isEnglish
        ? "Evaluate your company's potential"
        : "Evaluar el potencial de su empresa"
    }
  </h3>
  <p
    class="mb-[var(--sp-lg)] text-[length:var(--text-sm)]"
    data-en="Complete the form to schedule a free diagnosis session."
    data-es="Complete el formulario para coordinar un diagnóstico sin costo."
  >
    {
      isEnglish
        ? "Complete the form to schedule a free diagnosis session."
        : "Complete el formulario para coordinar un diagnóstico sin costo."
    }
  </p>

  <form id="contact-form" novalidate>
    <!-- Honeypot anti-spam -->
    <input
      type="checkbox"
      name="botcheck"
      class="hidden"
      tabindex="-1"
      aria-hidden="true"
    />
    <input type="hidden" name="access_key" value={WEB3FORMS_KEY} />
    <input
      type="hidden"
      name="subject"
      data-en="New B2B inquiry — Portfolio"
      data-es="Nueva consulta B2B — Portfolio"
      value={isEnglish
        ? "New B2B inquiry — Portfolio"
        : "Nueva consulta B2B — Portfolio"}
    />
    <input type="hidden" name="from_name" value="Portfolio NH" />
    <input type="hidden" name="redirect" value="false" />

    <div class="grid grid-cols-1 gap-[var(--sp-md)] sm:grid-cols-2">
      <div class="flex flex-col gap-1.5">
        <label
          class="text-[length:var(--text-xs)] tracking-[0.2px] text-[var(--text-secondary)]"
          for="contact-name"
          data-en="Full name *"
          data-es="Nombre completo *"
        >
          {isEnglish ? "Full name *" : "Nombre completo *"}
        </label>
        <input
          type="text"
          id="contact-name"
          name="name"
          placeholder={isEnglish ? "Jane Smith" : "Juan García"}
          autocomplete="name"
          required
          aria-required="true"
        />
        <span
          class="field-error"
          id="name-error"
          role="alert"
          aria-live="polite"></span>
      </div>

      <div class="flex flex-col gap-1.5">
        <label
          class="text-[length:var(--text-xs)] tracking-[0.2px] text-[var(--text-secondary)]"
          for="contact-email"
          data-en="Work email *"
          data-es="Email de trabajo *"
        >
          {isEnglish ? "Work email *" : "Email de trabajo *"}
        </label>
        <input
          type="email"
          id="contact-email"
          name="email"
          placeholder={isEnglish ? "jane@mycompany.com" : "juan@miempresa.com"}
          autocomplete="email"
          required
          aria-required="true"
        />
        <span
          class="field-error"
          id="email-error"
          role="alert"
          aria-live="polite"></span>
      </div>

      <div class="flex flex-col gap-1.5">
        <label
          class="text-[length:var(--text-xs)] tracking-[0.2px] text-[var(--text-secondary)]"
          for="contact-company"
          data-en="Company"
          data-es="Empresa"
        >
          {isEnglish ? "Company" : "Empresa"}
        </label>
        <input
          type="text"
          id="contact-company"
          name="company"
          placeholder={isEnglish ? "My Company LLC" : "Mi Empresa S.A."}
          autocomplete="organization"
        />
      </div>

      <div class="flex flex-col gap-1.5">
        <label
          class="text-[length:var(--text-xs)] tracking-[0.2px] text-[var(--text-secondary)]"
          for="contact-metric"
          data-en="Expected success metric"
          data-es="Métrica de éxito esperada"
        >
          {isEnglish ? "Expected success metric" : "Métrica de éxito esperada"}
        </label>
        <select id="contact-metric" name="metric">
          <option
            value=""
            data-en="Select a metric..."
            data-es="Seleccionar métrica..."
            >{
              isEnglish ? "Select a metric..." : "Seleccionar métrica..."
            }</option
          >
          <option
            value="cost-reduction"
            data-en="Reduction of operational costs"
            data-es="Reducción de costos operativos"
            >{
              isEnglish
                ? "Reduction of operational costs"
                : "Reducción de costos operativos"
            }</option
          >
          <option
            value="automation"
            data-en="Process automation"
            data-es="Automatización de procesos manuales"
            >{
              isEnglish
                ? "Process automation"
                : "Automatización de procesos manuales"
            }</option
          >
          <option
            value="sales"
            data-en="Increased sales / leads"
            data-es="Aumento de ventas / leads"
            >{
              isEnglish
                ? "Increased sales / leads"
                : "Aumento de ventas / leads"
            }</option
          >
          <option
            value="visibility"
            data-en="Improved online visibility"
            data-es="Mejora de visibilidad online"
            >{
              isEnglish
                ? "Improved online visibility"
                : "Mejora de visibilidad online"
            }</option
          >
          <option
            value="centralization"
            data-en="Operations centralization"
            data-es="Centralización de operaciones"
            >{
              isEnglish
                ? "Operations centralization"
                : "Centralización de operaciones"
            }</option
          >
          <option value="other" data-en="Other" data-es="Otra métrica"
            >{isEnglish ? "Other" : "Otra métrica"}</option
          >
        </select>
      </div>

      <div class="flex flex-col gap-1.5 sm:col-span-2">
        <label
          class="text-[length:var(--text-xs)] tracking-[0.2px] text-[var(--text-secondary)]"
          for="contact-challenge"
          data-en="Main operational challenge to solve *"
          data-es="Desafío operativo principal a resolver *"
        >
          {
            isEnglish
              ? "Main operational challenge to solve *"
              : "Desafío operativo principal a resolver *"
          }
        </label>
        <textarea
          id="contact-challenge"
          name="challenge"
          rows="4"
          placeholder={isEnglish
            ? "Describe the problem or inefficiency you want to solve, including its current impact on your operations..."
            : "Describa el problema o ineficiencia que quiere resolver, mencionando el impacto actual en su operación..."}
          required
          aria-required="true"></textarea>
        <span
          class="field-error"
          id="challenge-error"
          role="alert"
          aria-live="polite"></span>
      </div>
    </div>

    <button
      type="submit"
      class="btn-primary btn-primary--lg w-full justify-center mt-[var(--sp-md)]"
      id="submit-btn"
      data-en="Send inquiry"
      data-es="Enviar consulta"
    >
      {isEnglish ? "Send inquiry" : "Enviar consulta"}
    </button>
  </form>
</div>

<!-- Snackbar — fuera del form-wrap, posicionado fixed -->
<div
  id="form-snackbar"
  class="snackbar"
  role="alert"
  aria-live="polite"
  aria-hidden="true"
>
  <span id="snackbar-icon" aria-hidden="true"></span>
  <span id="snackbar-text"></span>
  <button
    class="snackbar-close"
    id="snackbar-close"
    aria-label={isEnglish ? "Close notification" : "Cerrar notificación"}
    >✕</button
  >
</div>

<style>
  /* Estilos base de inputs: usan selectores de estado (focus, aria-invalid,
     placeholder) que no se pueden expresar como clases en el markup. Migrar
     a Tailwind acá requeriría data-attrs + variants; se mantiene scoped CSS. */
  input,
  textarea,
  select {
    background: var(--bg-tertiary);
    border: 0.5px solid var(--border-normal);
    border-radius: var(--radius-sm);
    padding: 10px 12px;
    color: var(--text-primary);
    font-family: var(--font-body);
    font-size: var(--text-sm);
    width: 100%;
    outline: none;
    transition: border-color 0.15s ease;
  }
  input:focus,
  textarea:focus,
  select:focus {
    border-color: var(--accent-border);
  }
  input::placeholder,
  textarea::placeholder {
    color: var(--text-muted);
  }
  input[aria-invalid="true"],
  textarea[aria-invalid="true"] {
    border-color: var(--color-danger);
  }

  .field-error {
    font-size: var(--text-xs);
    color: var(--color-danger);
    min-height: 16px;
  }

  /* ── Snackbar ─────────────────────────────────────────────── */
  /* El snackbar se mantiene en scoped CSS por el stack [aria-hidden],
     modificadores .success/.error y transiciones coordinadas (opacity +
     translate) que se escriben más limpio acá que como utilidades. */
  .snackbar {
    position: fixed;
    bottom: 32px;
    left: 50%;
    transform: translateX(-50%) translateY(16px);
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 13px 18px;
    border-radius: var(--radius-sm);
    font-size: var(--text-sm);
    font-family: var(--font-body);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.35);
    opacity: 0;
    pointer-events: none;
    transition:
      opacity 0.25s ease,
      transform 0.25s ease;
    z-index: 9999;
    white-space: nowrap;
    max-width: calc(100vw - 48px);
  }
  .snackbar[aria-hidden="false"] {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
    pointer-events: auto;
  }
  .snackbar.success {
    background: #1d9e75;
    color: #fff;
  }
  .snackbar.error {
    background: var(--color-danger);
    color: #fff;
  }
  .snackbar-close {
    background: none;
    border: none;
    color: inherit;
    cursor: pointer;
    opacity: 0.75;
    font-size: 14px;
    padding: 0 0 0 6px;
    line-height: 1;
    transition: opacity 0.15s;
  }
  .snackbar-close:hover {
    opacity: 1;
  }

  @media (max-width: 560px) {
    .snackbar {
      bottom: 20px;
      white-space: normal;
      text-align: left;
    }
  }
</style>

<script>
  const form = document.getElementById("contact-form") as HTMLFormElement;
  const submitBtn = document.getElementById("submit-btn") as HTMLButtonElement;
  const snackbar = document.getElementById("form-snackbar") as HTMLElement;
  const snackIcon = document.getElementById("snackbar-icon") as HTMLElement;
  const snackText = document.getElementById("snackbar-text") as HTMLElement;
  const snackClose = document.getElementById(
    "snackbar-close",
  ) as HTMLButtonElement;

  let dismissTimer: ReturnType<typeof setTimeout>;

  function showSnackbar(type: "success" | "error", isEN: boolean) {
    const messages = {
      success: {
        es: "Mensaje enviado. Me pondré en contacto en menos de 24 horas.",
        en: "Message sent. I'll be in touch within 24 hours.",
        icon: "✓",
      },
      error: {
        es: "Algo salió mal. Por favor intentá de nuevo o escribime directamente.",
        en: "Something went wrong. Please try again or write to me directly.",
        icon: "✕",
      },
    };

    const m = messages[type];
    snackbar.className = `snackbar ${type}`;
    snackIcon.textContent = m.icon;
    snackText.textContent = isEN ? m.en : m.es;
    snackbar.setAttribute("aria-hidden", "false");

    clearTimeout(dismissTimer);
    dismissTimer = setTimeout(hideSnackbar, 5000);
  }

  function hideSnackbar() {
    clearTimeout(dismissTimer);
    snackbar.setAttribute("aria-hidden", "true");
  }

  snackClose?.addEventListener("click", hideSnackbar);

  // ── Field validation ────────────────────────────────────────
  function setError(fieldId: string, errorId: string, msg: string) {
    const field = document.getElementById(fieldId) as
      | HTMLInputElement
      | HTMLTextAreaElement;
    const err = document.getElementById(errorId) as HTMLElement;
    if (field) field.setAttribute("aria-invalid", "true");
    if (err) err.textContent = msg;
  }
  function clearError(fieldId: string, errorId: string) {
    const field = document.getElementById(fieldId) as
      | HTMLInputElement
      | HTMLTextAreaElement;
    const err = document.getElementById(errorId) as HTMLElement;
    if (field) field.removeAttribute("aria-invalid");
    if (err) err.textContent = "";
  }

  function validateForm(): boolean {
    let valid = true;
    const name = (
      document.getElementById("contact-name") as HTMLInputElement
    )?.value.trim();
    const email = (
      document.getElementById("contact-email") as HTMLInputElement
    )?.value.trim();
    const challenge = (
      document.getElementById("contact-challenge") as HTMLTextAreaElement
    )?.value.trim();
    const isEN = document.documentElement.lang === "en";

    clearError("contact-name", "name-error");
    clearError("contact-email", "email-error");
    clearError("contact-challenge", "challenge-error");

    if (!name) {
      setError(
        "contact-name",
        "name-error",
        isEN ? "Name is required." : "El nombre es obligatorio.",
      );
      valid = false;
    }
    if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
      setError(
        "contact-email",
        "email-error",
        isEN ? "Enter a valid email." : "Ingresá un email válido.",
      );
      valid = false;
    }
    if (!challenge || challenge.length < 20) {
      setError(
        "contact-challenge",
        "challenge-error",
        isEN
          ? "Please describe your challenge (min. 20 characters)."
          : "Describí tu desafío (mínimo 20 caracteres).",
      );
      valid = false;
    }
    return valid;
  }

  // ── Submit ──────────────────────────────────────────────────
  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    if (!validateForm()) return;

    const isEN = document.documentElement.lang === "en";
    submitBtn.disabled = true;
    submitBtn.textContent = isEN ? "Sending..." : "Enviando...";
    hideSnackbar();

    try {
      const data = Object.fromEntries(new FormData(form));
      const res = await fetch("https://api.web3forms.com/submit", {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
          Accept: "application/json",
        },
        body: JSON.stringify(data),
      });
      const json = await res.json();

      if (json.success) {
        form.reset();
        showSnackbar("success", isEN);
      } else {
        throw new Error(json.message || "Error");
      }
    } catch {
      showSnackbar("error", isEN);
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = isEN
        ? (submitBtn.dataset.en ?? "Send inquiry")
        : (submitBtn.dataset.es ?? "Enviar consulta");
    }
  });
</script>
