---
// BlogCard.astro
// Renderiza miniatura de artículo con hover overlay-reveal
// Uso: <BlogCard post={post} />

import { Image } from "astro:assets";
import humanAi from "../assets/blog/human-ai.webp";
import satellite from "../assets/blog/satellite.webp";
import cloudServers from "../assets/blog/cloud-servers.webp";
import ogHuellaDelFuego from "../assets/open-graphs/og-huella-del-fuego.webp";
import thumbArquitecturaGranEscala from "../assets/blog/thumbnails/thumb-articulo-arquitectura-a-gran-escala.webp";
import thumbMicroservicies from "../assets/blog/thumbnails/thumb-microservicies.webp";
import { localeFromPathname } from "../lib/locale-path";

type CoverImageKey =
  | "human-ai"
  | "cloud-servers"
  | "satellite"
  | "huella-del-fuego"
  | "arquitectura-gran-escala"
  | "microservicios-urban-blueprint";

interface Props {
  post: {
    slug: string;
    data: {
      title: string;
      titleEn?: string;
      description: string;
      descriptionEn?: string;
      pubDate: Date;
      category: string;
      tags: string[];
      vertical?:
        | "alimentos"
        | "inmobiliaria"
        | "salud"
        | "ecommerce"
        | "transversal";
      readingTime?: number;
      coverImageKey?: CoverImageKey;
      coverAlt?: string;
    };
  };
}

const { post } = Astro.props;
const isEnglish = localeFromPathname(Astro.url.pathname) === "en";
const blogBaseHref = isEnglish ? "/en/blog" : "/blog";

const coverByKey: Record<CoverImageKey, typeof humanAi> = {
  "human-ai": humanAi,
  satellite,
  "cloud-servers": cloudServers,
  "huella-del-fuego": ogHuellaDelFuego,
  "arquitectura-gran-escala": thumbArquitecturaGranEscala,
  "microservicios-urban-blueprint": thumbMicroservicies,
};

const categoryCover = {
  arquitectura: humanAi,
  infraestructura: cloudServers,
  metodología: satellite,
} as const;

const fallbackCover =
  categoryCover[post.data.category as keyof typeof categoryCover] ?? humanAi;

const coverSrc = post.data.coverImageKey
  ? coverByKey[post.data.coverImageKey]
  : fallbackCover;

function formatDate(date: Date, locale: string): string {
  return date.toLocaleDateString(locale, {
    year: "numeric",
    month: "short",
    day: "numeric",
  });
}

const title = isEnglish
  ? (post.data.titleEn ?? post.data.title)
  : post.data.title;
const readLabel = isEnglish
  ? `Read article: ${title}`
  : `Leer artículo: ${title}`;
---

<article class="blog-card">
  <!-- ── IMAGEN ── -->
  <div class="blog-card__cover">
    <Image
      src={coverSrc}
      alt={post.data.coverAlt ?? title}
      width={640}
      height={360}
      loading="lazy"
      class="blog-card__img"
    />
  </div>

  <!-- ── OVERLAY (visible solo en hover) ── -->
  <div class="blog-card__overlay" aria-hidden="true"></div>

  <!-- ── Enlace de tarjeta completa con CTA flotante ── -->
  <a
    href={`${blogBaseHref}/${post.slug}`}
    class="blog-card__link"
    aria-label={readLabel}
  >
    <span class="blog-card__cta" aria-hidden="true">
      <span
        class="blog-card__cta-text"
        data-en="Read article"
        data-es="Leer artículo"
      >
        {isEnglish ? "Read article" : "Leer artículo"}
      </span>
      <span class="blog-card__cta-btn">
        <svg
          width="13"
          height="13"
          viewBox="0 0 24 24"
          fill="none"
          stroke="#111"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
        </svg>
      </span>
    </span>
  </a>

  <!-- ── CUERPO ── -->
  <div class="blog-card__body">
    <!-- Meta: fecha · tiempo de lectura -->
    <div class="blog-card__meta">
      <time datetime={post.data.pubDate.toISOString()} class="blog-card__date">
        {formatDate(post.data.pubDate, isEnglish ? "en-US" : "es-AR")}
      </time>

      {
        post.data.readingTime && (
          <>
            <span class="blog-card__sep" aria-hidden="true">
              &bull;
            </span>
            <span
              class="blog-card__time"
              data-en={`${post.data.readingTime} min read`}
              data-es={`${post.data.readingTime} min`}
            >
              <svg
                width="11"
                height="11"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                aria-hidden="true"
              >
                <circle cx="12" cy="12" r="10" />
                <path d="M12 6v6l4 2" />
              </svg>
              {isEnglish
                ? `${post.data.readingTime} min read`
                : `${post.data.readingTime} min`}
            </span>
          </>
        )
      }
    </div>

    <!-- Título -->
    <h3
      class="blog-card__title"
      data-en={post.data.titleEn ?? post.data.title}
      data-es={post.data.title}
    >
      {title}
    </h3>

    <!-- Divisor sutil -->
    <hr class="blog-card__divider" aria-hidden="true" />

    <!-- Descripción -->
    <p
      class="blog-card__desc"
      data-en={post.data.descriptionEn ?? post.data.description}
      data-es={post.data.description}
    >
      {
        isEnglish
          ? (post.data.descriptionEn ?? post.data.description)
          : post.data.description
      }
    </p>
  </div>
</article>

<style>
  /* ─────────────────────────────────────────
     CARD BASE
  ───────────────────────────────────────── */
  .blog-card {
    display: flex;
    flex-direction: column;
    height: 100%;
    position: relative;
    background-color: var(--bg-tertiary);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-lg);
    overflow: hidden;
    cursor: pointer;
    transition:
      transform 350ms var(--ease-out-expo),
      box-shadow 350ms var(--ease-out-expo);
  }

  /* ─────────────────────────────────────────
     HOVER — card completa
  ───────────────────────────────────────── */
  .blog-card:hover,
  .blog-card:focus-within {
    transform: translateY(-6px);
    box-shadow:
      0 24px 48px -10px hsla(var(--accent-h), var(--accent-s), 56%, 0.13),
      0 0 0 1px hsla(var(--accent-h), var(--accent-s), 56%, 0.1);
  }

  /* ─────────────────────────────────────────
     IMAGEN
  ───────────────────────────────────────── */
  .blog-card__cover {
    width: 100%;
    height: 11rem;
    overflow: hidden;
    flex-shrink: 0;
  }

  .blog-card__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 550ms var(--ease-out-expo);
  }

  .blog-card:hover .blog-card__img,
  .blog-card:focus-within .blog-card__img {
    transform: scale(1.07);
  }

  /* ─────────────────────────────────────────
     OVERLAY — gradiente desde abajo
  ───────────────────────────────────────── */
  .blog-card__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(0, 0, 0, 0.92) 0%,
      rgba(0, 0, 0, 0.45) 38%,
      transparent 68%
    );
    opacity: 0;
    transition: opacity 380ms ease;
    border-radius: 1rem;
    pointer-events: none;
  }

  .blog-card:hover .blog-card__overlay,
  .blog-card:focus-within .blog-card__overlay {
    opacity: 1;
  }

  /* ─────────────────────────────────────────
     CTA flotante
  ───────────────────────────────────────── */
  .blog-card__link {
    position: absolute;
    inset: 0;
    z-index: 4;
    border-radius: 1rem;
    color: inherit;
    text-decoration: none;
  }

  .blog-card__link:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: -4px;
  }

  .blog-card__cta {
    position: absolute;
    right: 20px;
    bottom: 20px;
    left: 20px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    opacity: 0;
    transform: translateY(10px);
    transition:
      opacity 300ms ease 60ms,
      transform 300ms ease 60ms;
  }

  .blog-card:hover .blog-card__cta,
  .blog-card:focus-within .blog-card__cta {
    opacity: 1;
    transform: translateY(0);
  }

  .blog-card__cta-text {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--accent);
  }

  .blog-card__cta-btn {
    width: 30px;
    height: 30px;
    border-radius: 50%;
    background: var(--color-accent-500);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: transform 220ms ease;
  }

  .blog-card:hover .blog-card__cta-btn,
  .blog-card:focus-within .blog-card__cta-btn {
    transform: translateX(3px);
  }

  /* ─────────────────────────────────────────
     CUERPO
  ───────────────────────────────────────── */
  .blog-card__body {
    padding: 20px 20px 22px;
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  /* ─────────────────────────────────────────
     META ROW
  ───────────────────────────────────────── */
  .blog-card__meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 6px;
    margin-bottom: 14px;
  }

  .blog-card__sep {
    color: var(--text-muted);
    font-size: 0.625rem;
  }

  .blog-card__date {
    font-size: 0.625rem;
    font-weight: 500;
    color: var(--text-secondary);
  }

  .blog-card__time {
    font-size: 0.625rem;
    font-weight: 500;
    color: var(--text-secondary);
    display: inline-flex;
    align-items: center;
    gap: 3px;
  }

  /* ─────────────────────────────────────────
     TÍTULO
  ───────────────────────────────────────── */
  .blog-card__title {
    font-size: 0.9375rem;
    font-weight: 700;
    color: var(--text-primary);
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin-bottom: 12px;
    transition: color 200ms ease;
  }

  .blog-card:hover .blog-card__title,
  .blog-card:focus-within .blog-card__title {
    color: var(--text-primary);
  }

  /* ─────────────────────────────────────────
     DIVISOR
  ───────────────────────────────────────── */
  .blog-card__divider {
    border: none;
    border-top: 1px solid var(--border-subtle);
    margin: 0 0 12px;
  }

  /* ─────────────────────────────────────────
     DESCRIPCIÓN
  ───────────────────────────────────────── */
  .blog-card__desc {
    font-size: 0.8125rem;
    color: var(--text-secondary);
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin-bottom: 16px;
    flex: 1;
  }
</style>
