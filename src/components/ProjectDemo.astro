---
// ProjectDemo.astro
// Contenedor de demo de proyecto con <video> (WebM/MP4).
// Nunca usar GIFs: pesan más, no se pueden pausar, consumen más CPU.
// Uso: <ProjectDemo src="/demos/huelladelfuego" title="Demo Huella del fuego en Argentina" />

interface Props {
  /** Ruta base sin extensión. Se genera <source> para .webm y .mp4 */
  src: string;
  /** Texto alternativo y título del video */
  title: string;
  /** Imagen de poster mientras carga (recomendado: WebP) */
  poster?: string;
  /** Ancho del contenedor en píxeles (default: 100%) */
  width?: number;
  /** Alto en píxeles (default: auto por aspect-ratio 16/9) */
  height?: number;
  /** Si el video debe reproducirse automáticamente en mute (default: true) */
  autoplay?: boolean;
}

const { src, title, poster, width, height, autoplay = true } = Astro.props;
---

<figure
  class="project-demo"
  style={width ? `max-width: ${width}px` : undefined}
>
  <video
    class="project-demo__video"
    {width}
    {height}
    poster={poster}
    autoplay={autoplay}
    muted
    loop
    playsinline
    aria-label={title}
    title={title}
  >
    <!-- WebM primero: mejor compresión en navegadores modernos -->
    <source src={`${src}.webm`} type="video/webm" />
    <!-- MP4 como fallback universal -->
    <source src={`${src}.mp4`} type="video/mp4" />
    <p>
      Tu navegador no soporta video HTML5. <a href={`${src}.mp4`}
        >Descargar video</a
      >.
    </p>
  </video>

  {title && <figcaption class="project-demo__caption">{title}</figcaption>}
</figure>

<style>
  .project-demo {
    width: 100%;
    border-radius: var(--radius-lg);
    overflow: hidden;
    border: 0.5px solid var(--border-normal);
    background: var(--bg-tertiary);
  }

  .project-demo__video {
    width: 100%;
    height: auto;
    aspect-ratio: 16 / 9;
    display: block;
    object-fit: cover;
  }

  .project-demo__caption {
    padding: var(--sp-sm) var(--sp-md);
    font-size: var(--text-xs);
    color: var(--text-muted);
    text-align: center;
    border-top: 0.5px solid var(--border-subtle);
  }
</style>
