---
import site from '../data/site.json';

const { author, social, stack } = site;
const year = new Date().getFullYear();

const navColumns = [
  {
    heading: 'Servicios',
    links: [
      { label: 'Desarrollo web',    href: '/servicios' },
      { label: 'SaaS y apps',       href: '/servicios' },
      { label: 'Chatbots e IA',     href: '/servicios' },
      { label: 'Automatización',    href: '/servicios' },
    ],
  },
  {
    heading: 'Recursos',
    links: [
      { label: 'Blog',              href: '/blog' },
      { label: 'Talento',           href: '/talento' },
    ],
  },
  {
    heading: 'Contacto',
    links: [
      { label: author.email,        href: `mailto:${author.email}` },
    ],
  },
];
---

<!-- FT-07: SiteNavigationElement structured data -->
<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "SiteNavigationElement",
  "name": ["Servicios", "Blog", "Talento", "Contacto"],
  "url": [
    `${author.siteUrl}/servicios`,
    `${author.siteUrl}/blog`,
    `${author.siteUrl}/talento`,
    `${author.siteUrl}#contacto`
  ]
})} />

<footer
  role="contentinfo"
  aria-label="Pie de página"
  style="background: var(--footer-bg); border-top: 0.5px solid var(--border-subtle);"
>
  <div class="page-container" style="padding-top: var(--sp-2xl); padding-bottom: var(--sp-xl);">

    <!-- ── Pre-footer CTA card ─────────────────────────────── -->
    <div
      class="relative overflow-hidden"
      style="background: var(--footer-card-bg); border: 0.5px solid var(--border-normal); border-radius: var(--radius-xl); padding: var(--sp-xl) var(--sp-xl); margin-bottom: var(--sp-2xl);"
    >
      <!-- Decorative glow -->
      <div
        aria-hidden="true"
        class="absolute -top-20 -right-20 rounded-full pointer-events-none"
        style="width: var(--footer-glow-size); height: var(--footer-glow-size); background: radial-gradient(circle, hsla(43, 96%, 56%, 0.18), transparent 70%);"
      ></div>

      <div class="relative" style="max-width: 560px;">
        <p class="label">¿Listo para el siguiente nivel?</p>
        <h2 style="font-family: var(--font-display); font-size: var(--text-2xl); font-weight: 800; letter-spacing: -1px; color: var(--text-primary); margin-bottom: var(--sp-sm);">
          Escalá tu negocio<br />con tecnología real
        </h2>
        <p style="color: var(--text-secondary); font-size: var(--text-base); margin-bottom: var(--sp-lg); line-height: 1.75;">
          Automatización, IA y software a medida. Sin burocracia, con resultados.
        </p>
        <a
          href="#contacto"
          class="btn-primary motion-safe:transition-all"
        >
          Hablemos →
        </a>
      </div>
    </div>

    <!-- ── Main grid ───────────────────────────────────────── -->
    <div
      class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4"
      style="gap: var(--footer-col-gap); margin-bottom: var(--sp-xl);"
    >

      <!-- Brand column -->
      <div class="sm:col-span-2 md:col-span-1">
        <div style="font-family: var(--font-display); font-size: 20px; font-weight: 800; color: var(--text-primary); margin-bottom: var(--sp-sm);">
          nh<span style="color: var(--accent);">.</span>
        </div>
        <p style="font-size: var(--text-xs); color: var(--text-muted); margin-bottom: var(--sp-md); line-height: 1.6;">
          Analista funcional<br />y desarrollador full stack.
        </p>

        <!-- Stack pills -->
        <div class="tags" style="margin-bottom: var(--sp-md);">
          {stack.map((tech) => (
            <span class="tag">{tech}</span>
          ))}
        </div>

        <!-- Social icons -->
        <div style="display: flex; gap: var(--sp-sm); flex-wrap: wrap;">
          <a
            href={social.github}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Perfil en GitHub"
            style="font-size: var(--text-xs); color: var(--text-muted);"
            class="motion-safe:transition-colors hover:text-[var(--accent-text)]"
          >GitHub</a>
          <a
            href={social.linkedin}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Perfil en LinkedIn"
            style="font-size: var(--text-xs); color: var(--text-muted);"
            class="motion-safe:transition-colors hover:text-[var(--accent-text)]"
          >LinkedIn</a>
          <a
            href={social.twitter}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Perfil en X / Twitter"
            style="font-size: var(--text-xs); color: var(--text-muted);"
            class="motion-safe:transition-colors hover:text-[var(--accent-text)]"
          >X / Twitter</a>
          <a
            href={social.instagram}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Perfil en Instagram"
            style="font-size: var(--text-xs); color: var(--text-muted);"
            class="motion-safe:transition-colors hover:text-[var(--accent-text)]"
          >Instagram</a>
        </div>
      </div>

      <!-- Nav columns -->
      {navColumns.map((col) => (
        <div>
          <p style="font-family: var(--font-body); font-size: var(--text-xs); font-weight: 600; letter-spacing: 1.5px; text-transform: uppercase; color: var(--text-muted); margin-bottom: var(--sp-md);">
            {col.heading}
          </p>
          <ul style="list-style: none; display: flex; flex-direction: column; gap: var(--sp-sm);">
            {col.links.map((link) => (
              <li>
                <a
                  href={link.href}
                  style="font-size: var(--text-sm); color: var(--text-secondary);"
                  class="motion-safe:transition-colors hover:text-[var(--text-primary)]"
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}

    </div>

    <!-- ── Bottom bar ──────────────────────────────────────── -->
    <div class="divider"></div>
    <div style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: var(--sp-sm);">
      <p style="font-size: var(--text-xs); color: var(--text-muted); margin: 0;">
        © {year} {author.name}. Todos los derechos reservados.
      </p>
      <p style="font-size: var(--text-xs); color: var(--text-muted); margin: 0;">
        Hecho con <a href="https://astro.build" target="_blank" rel="noopener noreferrer" aria-label="Sitio web de Astro" style="color: var(--text-muted);">Astro</a>
      </p>
    </div>

  </div>
</footer>
