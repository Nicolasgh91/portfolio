---
import { getCollection } from 'astro:content';
import site from '../data/site.json';
import { serviceAnchorId } from '../lib/service-anchor-id';
import { localeFromPathname } from '../lib/locale-path';
import FooterColumnHeader from './FooterColumnHeader.astro';
import FooterPill from './FooterPill.astro';

const { author, social } = site;
const year = new Date().getFullYear();
const isEnglish = localeFromPathname(Astro.url.pathname) === 'en';
const servicesHref = isEnglish ? '/en/services' : '/servicios';
const blogHref = isEnglish ? '/en/blog' : '/blog';

// Dynamic services — sorted by `order` field
const services = (await getCollection('services'))
  .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));

// Dynamic blog posts — published only, newest first, up to 6
const blogPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 6);
---

<!-- FT-07: SiteNavigationElement structured data -->
<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "SiteNavigationElement",
  "name": [
    ...services.map(s => s.data.title),
    "Diagnóstico gratuito",
    ...blogPosts.map(p => p.data.title),
    "Email",
    "Agendar reunión"
  ],
  "url": [
    ...services.map(s => `${author.siteUrl}${servicesHref}#${serviceAnchorId(s.slug)}`),
    `${author.siteUrl}${servicesHref}#contacto`,
    ...blogPosts.map(p => `${author.siteUrl}${blogHref}/${p.slug}`),
    `mailto:${author.email}`,
    `${author.siteUrl}${servicesHref}#contacto`
  ]
})} />

<footer
  role="contentinfo"
  aria-label="Pie de página"
  class="bg-[var(--footer-bg)] border-t-[0.5px] border-[var(--border-subtle)]"
>
  <div class="mx-auto w-full max-w-7xl px-6 pt-[var(--sp-2xl)] pb-[var(--sp-xl)]">

    <!-- ── Pre-footer CTA card ─────────────────────────────── -->
    <div
      class="relative overflow-hidden bg-[var(--footer-card-bg)] border-[0.5px] border-[var(--border-normal)] rounded-[var(--radius-xl)] px-[var(--sp-xl)] py-[var(--sp-xl)] mb-[var(--sp-2xl)]"
    >
      <!-- Decorative glow -->
      <div aria-hidden="true" class="footer-glow"></div>

      <div class="relative max-w-[560px]">
        <p class="label">¿Listo para empezar?</p>
        <h2
          class="font-[family-name:var(--font-display)] text-[length:var(--text-2xl)] font-extrabold tracking-[-1px] text-[var(--text-primary)] mb-[var(--sp-sm)]"
        >
          Convertí tu operación en una ventaja competitiva.
        </h2>
        <p
          class="text-[length:var(--text-base)] leading-[1.75] text-[var(--text-secondary)] mb-[var(--sp-lg)]"
        >
          30 minutos. Sin compromiso. Te decimos exactamente dónde está la pérdida y cómo resolverla.
        </p>
        <a href={`${servicesHref}#contacto`} class="btn-primary btn-bounce">
          <span data-es>Agenda una reunión</span>
          <span data-en class="hidden">Book a meeting</span>
          <span class="arrow" aria-hidden="true">→</span>
        </a>
      </div>
    </div>

    <!-- ── Main grid ───────────────────────────────────────── -->
    <div class="footer-grid">

      <!-- Brand column -->
      <div class="footer-brand">
        <div
          class="font-[family-name:var(--font-display)] text-[20px] font-extrabold text-[var(--text-primary)] mb-[var(--sp-sm)]"
        >
          nh<span class="text-[var(--accent)]">.</span>
        </div>
        <p
          class="text-[length:var(--text-xs)] leading-[1.6] text-[var(--text-muted)] mb-[var(--sp-md)]"
        >
          Analista funcional<br />y desarrollador full stack.
        </p>

        <!-- Social icons -->
        <div class="flex items-center gap-[var(--sp-sm)]">
          <!-- GitHub -->
          <a
            href={social.github}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Perfil en GitHub"
            class="social-icon-link social-icon-link--brand-gh"
          >
            <svg aria-hidden="true" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 2C6.477 2 2 6.477 2 12c0 4.418 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.009-.868-.013-1.703-2.782.604-3.369-1.34-3.369-1.34-.454-1.156-1.11-1.463-1.11-1.463-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0 1 12 6.836c.85.004 1.705.114 2.504.337 1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.202 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.138 20.163 22 16.418 22 12c0-5.523-4.477-10-10-10z"/>
            </svg>
          </a>
          <!-- LinkedIn -->
          <a
            href={social.linkedin}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Perfil en LinkedIn"
            class="social-icon-link social-icon-link--brand-li"
          >
            <svg aria-hidden="true" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </a>
          <!-- X / Twitter -->
          <a
            href={social.twitter}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Perfil en X / Twitter"
            class="social-icon-link social-icon-link--brand-x"
          >
            <svg aria-hidden="true" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.738l7.73-8.835L1.254 2.25H8.08l4.713 5.892zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
            </svg>
          </a>
          <!-- Instagram -->
          <a
            href={social.instagram}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Perfil en Instagram"
            class="social-icon-link social-icon-link--brand-ig"
          >
            <svg aria-hidden="true" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Servicios column (dynamic) -->
      <div>
        <FooterColumnHeader label="Servicios" />
        <ul class="list-none flex flex-col gap-[var(--sp-sm)]">
          {services.map((svc) => (
            <li>
              <a
                href={svc.data.href ?? `${servicesHref}#${serviceAnchorId(svc.slug)}`}
                class="footer-link"
              >
                {svc.data.title}
              </a>
            </li>
          ))}
          <li>
            <a
              href={`${servicesHref}#contacto`}
              class="footer-link inline-flex items-center gap-[var(--sp-xs)]"
            >
              Diagnóstico gratuito
              <FooterPill label="Gratis" />
            </a>
          </li>
        </ul>
      </div>

      <!-- Recursos column (dynamic from blog) -->
      <div>
        <FooterColumnHeader label="Recursos" />
        <ul class="list-none flex flex-col gap-[var(--sp-sm)]">
          {blogPosts.map((post, i) => (
            <li>
              <a
                href={`${blogHref}/${post.slug}`}
                class="footer-link inline-flex items-center gap-[var(--sp-xs)]"
              >
                {post.data.title}
                {i === 0 && <FooterPill label="Nuevo" />}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contacto column (static) -->
      <div>
        <FooterColumnHeader label="Contacto" />
        <ul class="list-none flex flex-col gap-[var(--sp-sm)]">
          <li>
            <a
              href={`mailto:${author.email}`}
              class="footer-link"
            >
              {author.email}
            </a>
          </li>
          {author.whatsapp && (
            <li>
              <a
                href={author.whatsapp}
                target="_blank"
                rel="noopener noreferrer"
                class="footer-link"
              >
                WhatsApp
              </a>
            </li>
          )}
          <li>
            <a
              href={`${servicesHref}#contacto`}
              class="footer-link"
            >
              Agendar reunión
            </a>
          </li>
          <li>
            <span class="text-[length:var(--text-sm)] text-[var(--text-muted)]">
              Buenos Aires, AR
            </span>
          </li>
        </ul>
      </div>

    </div>

    <!-- ── Bottom bar ──────────────────────────────────────── -->
    <div class="divider"></div>
    <div class="footer-bottom">
      <p class="text-[length:var(--text-xs)] text-[var(--text-muted)] m-0">
        © {year} {author.name}. Todos los derechos reservados.
      </p>
    </div>

  </div>
</footer>

<style>
  /* ── Footer grid ──────────────────────────────────────── */
  /* Multi-breakpoint grid: mantener en scoped CSS porque expresar
     `.footer-brand { grid-column: span 2 }` como utilidad Tailwind
     requeriría classes inline dependientes del viewport. */
  .footer-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--footer-col-gap);
    margin-bottom: var(--sp-xl);
  }
  @media (min-width: 640px) {
    .footer-grid { grid-template-columns: repeat(2, 1fr); }
    .footer-brand { grid-column: span 2; }
  }
  @media (min-width: 768px) {
    .footer-grid { grid-template-columns: repeat(4, 1fr); }
    .footer-brand { grid-column: span 1; }
  }

  /* ── CTA decorative glow ──────────────────────────────── */
  /* radial-gradient no se expresa limpiamente como utilidad. */
  .footer-glow {
    position: absolute;
    top: -80px;
    right: -80px;
    border-radius: 9999px;
    pointer-events: none;
    width: var(--footer-glow-size);
    height: var(--footer-glow-size);
    background: radial-gradient(circle, hsla(43, 96%, 56%, 0.18), transparent 70%);
  }

  /* ── Nav link hover ───────────────────────────────────── */
  /* prefers-reduced-motion gate sobre una transition: vive acá. */
  .footer-link {
    font-size: var(--text-sm);
    color: var(--text-secondary);
  }
  .footer-link:hover { color: var(--text-primary); }

  @media (prefers-reduced-motion: no-preference) {
    .footer-link { transition: color 150ms ease; }
  }

  /* ── Bottom bar ───────────────────────────────────────── */
  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--sp-sm);
  }
</style>
