---
interface Props {
  lang: "es" | "en";
  articleSelector?: string;
  audioSrc?: string;
}

const { lang, articleSelector = "article", audioSrc } = Astro.props;
const speechLang = lang === "es" ? "es-AR" : "en-US";
const listenLabel = lang === "es" ? "Escuchar" : "Listen";
const pauseLabel = lang === "es" ? "Pausar" : "Pause";
const resumeLabel = lang === "es" ? "Reanudar" : "Resume";
const speedLabel = lang === "es" ? "Cambiar velocidad" : "Change speed";
const progressLabel =
  lang === "es" ? "Progreso de reproducción" : "Playback progress";
const playerTooltipClass =
  "pointer-events-none absolute bottom-full right-0 z-20 mb-2 whitespace-nowrap rounded-md border border-[color:var(--border-subtle)] bg-[var(--bg-tertiary)] px-2 py-1 text-xs font-medium text-[var(--text-primary)] opacity-0 shadow-lg transition-opacity group-hover:opacity-100";
---

<div
  data-article-player
  data-lang={speechLang}
  data-article-selector={articleSelector}
  data-audio-src={audioSrc}
  data-label-listen={listenLabel}
  data-label-pause={pauseLabel}
  data-label-resume={resumeLabel}
  data-label-progress={progressLabel}
  hidden
  class="ml-auto inline-flex min-w-0 shrink items-center gap-1 text-[var(--text-secondary)] sm:gap-1.5"
>
  <span data-tooltip-root class="group relative inline-flex">
    <button
      type="button"
      data-article-player-toggle
      aria-label={listenLabel}
      class="inline-flex h-8 w-8 shrink-0 items-center justify-center rounded-lg border-0 bg-transparent p-0 text-[var(--text-secondary)] transition-colors hover:text-[var(--text-primary)] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--accent)] sm:h-9 sm:w-9"
    >
      <span data-article-player-play-icon aria-hidden="true">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <circle cx="12" cy="12" r="10"></circle>
          <polygon points="10,8 16,12 10,16" fill="currentColor" stroke="none"
          ></polygon>
        </svg>
      </span>
      <span data-article-player-pause-icon aria-hidden="true" hidden>
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <circle cx="12" cy="12" r="10"></circle>
          <line x1="10" y1="9" x2="10" y2="15"></line>
          <line x1="14" y1="9" x2="14" y2="15"></line>
        </svg>
      </span>
    </button>
    <span
      data-article-player-tooltip
      data-tooltip-content
      class={playerTooltipClass}
      aria-hidden="true">{listenLabel}</span
    >
  </span>

  <span
    data-article-player-progress-wrap
    class="inline-flex min-w-0 shrink items-center gap-1.5 sm:gap-2"
    hidden
  >
    <input
      data-article-player-progress
      type="range"
      min="0"
      max="100"
      step="0.1"
      value="0"
      aria-label={progressLabel}
      class="h-1.5 w-12 min-w-0 shrink cursor-pointer rounded-full border border-[color:var(--accent-border)] bg-[var(--accent-bg)] accent-[var(--accent)] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-[var(--accent)] sm:w-40"
      hidden
    />
    <span
      data-article-player-progress-meter
      role="progressbar"
      aria-label={progressLabel}
      aria-valuemin="0"
      aria-valuemax="100"
      aria-valuenow="0"
      class="h-1.5 w-12 min-w-0 shrink overflow-hidden rounded-full border border-[color:var(--accent-border)] bg-[var(--accent-bg)] sm:w-40"
      hidden
    >
      <span
        data-article-player-progress-fill
        class="block h-full w-0 rounded-full bg-[var(--accent)]"></span>
    </span>
    <span
      data-article-player-progress-time
      class="hidden min-w-[4.5rem] text-right text-[10px] tabular-nums text-[var(--text-muted)] sm:inline"
      hidden>0:00 / 0:00</span
    >
  </span>

  <span
    data-article-player-rate-wrap
    data-tooltip-root
    class="group relative inline-flex shrink-0"
    hidden
  >
    <button
      type="button"
      data-article-player-rate
      aria-label={speedLabel}
      class="cursor-pointer border-0 bg-transparent p-0 text-xs text-[var(--text-muted)] transition-colors hover:text-[var(--text-secondary)] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--accent)]"
    >
      <span data-article-player-rate-label>1x</span>
    </button>
    <span data-tooltip-content class={playerTooltipClass} aria-hidden="true"
      >{speedLabel}</span
    >
  </span>
</div>

<script>
  type PlayerState = "idle" | "playing" | "paused";

  const rateOptions = [1, 1.2, 0.85] as const;

  const getPlayerLabel = (
    root: HTMLElement,
    key: "listen" | "pause" | "resume",
  ) => root.dataset[`label${key[0].toUpperCase()}${key.slice(1)}`] ?? "";

  const formatTime = (seconds: number) => {
    if (!Number.isFinite(seconds) || seconds < 0) return "0:00";

    const roundedSeconds = Math.floor(seconds);
    const minutes = Math.floor(roundedSeconds / 60);
    const remainingSeconds = roundedSeconds % 60;

    return `${minutes}:${String(remainingSeconds).padStart(2, "0")}`;
  };

  const getVoicesForLang = (lang: string) => {
    const voices = window.speechSynthesis.getVoices();
    const langPrefix = lang.slice(0, 2).toLowerCase();
    return (
      voices.find((voice) => voice.lang.toLowerCase() === lang.toLowerCase()) ??
      voices.find((voice) => voice.lang.toLowerCase().startsWith(langPrefix)) ??
      null
    );
  };

  const waitForVoices = (
    lang: string,
    callback: (voice: SpeechSynthesisVoice | null) => void,
  ) => {
    const voice = getVoicesForLang(lang);
    if (voice || window.speechSynthesis.getVoices().length > 0) {
      callback(voice);
      return;
    }

    const onVoicesChanged = () => {
      window.speechSynthesis.removeEventListener(
        "voiceschanged",
        onVoicesChanged,
      );
      callback(getVoicesForLang(lang));
    };

    window.speechSynthesis.addEventListener("voiceschanged", onVoicesChanged, {
      once: true,
    });
  };

  const getArticleText = (selector: string) => {
    const article = document.querySelector(selector);
    if (!(article instanceof HTMLElement)) return "";

    const clone = article.cloneNode(true);
    if (!(clone instanceof HTMLElement)) return "";

    clone
      .querySelectorAll("pre, code, table, figcaption")
      .forEach((node) => node.remove());

    return (clone.textContent ?? "").replace(/\s+/g, " ").trim();
  };

  const chunkText = (text: string, wordsPerChunk = 200) => {
    const words = text.split(/\s+/).filter(Boolean);
    const chunks: string[] = [];

    for (let index = 0; index < words.length; index += wordsPerChunk) {
      chunks.push(words.slice(index, index + wordsPerChunk).join(" "));
    }

    return chunks;
  };

  const initArticlePlayer = (root: HTMLElement) => {
    if (root.dataset.articlePlayerReady === "true") return;
    root.dataset.articlePlayerReady = "true";

    const toggle = root.querySelector("[data-article-player-toggle]");
    const toggleTooltip = root.querySelector("[data-article-player-tooltip]");
    const playIcon = root.querySelector("[data-article-player-play-icon]");
    const pauseIcon = root.querySelector("[data-article-player-pause-icon]");
    const progressWrap = root.querySelector(
      "[data-article-player-progress-wrap]",
    );
    const progressInput = root.querySelector("[data-article-player-progress]");
    const progressMeter = root.querySelector(
      "[data-article-player-progress-meter]",
    );
    const progressFill = root.querySelector(
      "[data-article-player-progress-fill]",
    );
    const progressTime = root.querySelector(
      "[data-article-player-progress-time]",
    );
    const rateWrap = root.querySelector("[data-article-player-rate-wrap]");
    const rateButton = root.querySelector("[data-article-player-rate]");
    const rateLabel = root.querySelector("[data-article-player-rate-label]");

    if (
      !(toggle instanceof HTMLButtonElement) ||
      !(toggleTooltip instanceof HTMLElement) ||
      !(playIcon instanceof HTMLElement) ||
      !(pauseIcon instanceof HTMLElement) ||
      !(progressWrap instanceof HTMLElement) ||
      !(progressInput instanceof HTMLInputElement) ||
      !(progressMeter instanceof HTMLElement) ||
      !(progressFill instanceof HTMLElement) ||
      !(progressTime instanceof HTMLElement) ||
      !(rateWrap instanceof HTMLElement) ||
      !(rateButton instanceof HTMLButtonElement) ||
      !(rateLabel instanceof HTMLElement)
    )
      return;

    const lang = root.dataset.lang ?? "es-AR";
    const selector = root.dataset.articleSelector ?? "article";
    const audioSrc = root.dataset.audioSrc;
    let state: PlayerState = "idle";
    let chunks: string[] = [];
    let chunkIndex = 0;
    let rateIndex = 0;
    let activeVoice: SpeechSynthesisVoice | null = null;
    let audio: HTMLAudioElement | null = null;

    const setProgressPercent = (percentage: number) => {
      const progress = Number.isFinite(percentage)
        ? Math.min(100, Math.max(0, percentage))
        : 0;

      progressInput.value = String(progress);
      progressMeter.setAttribute("aria-valuenow", String(Math.round(progress)));
      progressFill.style.width = `${progress}%`;
    };

    const setAudioProgress = () => {
      const activeAudio = audio;
      if (!activeAudio || !Number.isFinite(activeAudio.duration)) {
        setProgressPercent(0);
        progressTime.hidden = true;
        return;
      }

      const progress = (activeAudio.currentTime / activeAudio.duration) * 100;
      setProgressPercent(progress);
      progressTime.hidden = false;
      progressTime.textContent = `${formatTime(activeAudio.currentTime)} / ${formatTime(activeAudio.duration)}`;
    };

    const setProgressMode = (mode: "audio" | "speech" | "hidden") => {
      progressWrap.hidden = mode === "hidden";
      progressInput.hidden = mode !== "audio";
      progressMeter.hidden = mode !== "speech";
      progressInput.disabled = mode !== "audio";
      if (mode !== "audio") progressTime.hidden = true;
    };

    const updateSpeechProgress = () => {
      if (chunks.length === 0) {
        setProgressPercent(0);
        return;
      }

      setProgressPercent((chunkIndex / chunks.length) * 100);
    };

    root.querySelectorAll("[data-tooltip-root]").forEach((tooltipRoot) => {
      const tooltip = tooltipRoot.querySelector("[data-tooltip-content]");
      if (!(tooltip instanceof HTMLElement)) return;

      tooltipRoot.addEventListener("click", () => {
        tooltip.hidden = true;
      });

      tooltipRoot.addEventListener("mouseleave", () => {
        tooltip.hidden = false;
      });
    });

    const setState = (nextState: PlayerState) => {
      state = nextState;
      rateWrap.hidden = state !== "playing";
      playIcon.hidden = state === "playing";
      pauseIcon.hidden = state !== "playing";

      const label =
        state === "playing"
          ? getPlayerLabel(root, "pause")
          : state === "paused"
            ? getPlayerLabel(root, "resume")
            : getPlayerLabel(root, "listen");

      toggle.setAttribute("aria-label", label);
      toggleTooltip.textContent = label;
    };

    const getAudio = () => {
      if (!audioSrc) return null;
      if (!audio) {
        audio = new Audio(audioSrc);
        audio.preload = "metadata";
        audio.addEventListener("loadedmetadata", setAudioProgress);
        audio.addEventListener("durationchange", setAudioProgress);
        audio.addEventListener("timeupdate", setAudioProgress);
        audio.addEventListener("ended", () => {
          setProgressPercent(100);
          setState("idle");
        });
        audio.addEventListener("error", () => {
          setProgressPercent(0);
          setState("idle");
        });
      }
      return audio;
    };

    if (audioSrc) setProgressMode("audio");

    const cancel = () => {
      if ("speechSynthesis" in window) window.speechSynthesis.cancel();
      if (audio) {
        audio.pause();
        audio.currentTime = 0;
      }
      chunks = [];
      chunkIndex = 0;
      setProgressPercent(0);
      if (!audioSrc) setProgressMode("hidden");
      if (audioSrc) setAudioProgress();
      setState("idle");
    };

    const speakCurrentChunk = () => {
      const text = chunks[chunkIndex];
      if (!text) {
        cancel();
        return;
      }

      const utterance = new SpeechSynthesisUtterance(text);
      utterance.lang = lang;
      utterance.rate = rateOptions[rateIndex];
      if (activeVoice) utterance.voice = activeVoice;
      utterance.onend = () => {
        if (state !== "playing") return;
        chunkIndex += 1;
        updateSpeechProgress();
        if (chunkIndex >= chunks.length) {
          cancel();
          return;
        }
        speakCurrentChunk();
      };
      utterance.onerror = cancel;

      window.speechSynthesis.speak(utterance);
      setState("playing");
    };

    const startSpeech = () => {
      const text = getArticleText(selector);
      chunks = chunkText(text);
      chunkIndex = 0;
      if (chunks.length === 0) return;
      setProgressMode("speech");
      updateSpeechProgress();

      waitForVoices(lang, (voice) => {
        activeVoice = voice;
        speakCurrentChunk();
      });
    };

    const startAudio = async () => {
      const activeAudio = getAudio();
      if (!activeAudio) return;

      activeAudio.playbackRate = rateOptions[rateIndex];
      if (
        activeAudio.ended ||
        (Number.isFinite(activeAudio.duration) &&
          activeAudio.currentTime >= activeAudio.duration)
      ) {
        activeAudio.currentTime = 0;
      }
      setProgressMode("audio");
      setAudioProgress();

      try {
        await activeAudio.play();
        setState("playing");
      } catch {
        setState("idle");
      }
    };

    toggle.addEventListener("click", async () => {
      if (state === "playing") {
        if (audioSrc) {
          getAudio()?.pause();
        } else {
          window.speechSynthesis.pause();
        }
        setState("paused");
        return;
      }

      if (state === "paused") {
        if (audioSrc) {
          await startAudio();
        } else {
          window.speechSynthesis.resume();
          setState("playing");
        }
        return;
      }

      if (audioSrc) {
        await startAudio();
      } else {
        startSpeech();
      }
    });

    rateButton.addEventListener("click", () => {
      rateIndex = (rateIndex + 1) % rateOptions.length;
      rateLabel.textContent = `${rateOptions[rateIndex]}x`;
      const activeAudio = getAudio();
      if (activeAudio) activeAudio.playbackRate = rateOptions[rateIndex];
    });

    progressInput.addEventListener("input", () => {
      const activeAudio = getAudio();
      if (!activeAudio || !Number.isFinite(activeAudio.duration)) return;

      activeAudio.currentTime =
        (Number(progressInput.value) / 100) * activeAudio.duration;
      setAudioProgress();
    });

    window.addEventListener("beforeunload", cancel, { once: true });
  };

  const supportsSpeech =
    "speechSynthesis" in window && "SpeechSynthesisUtterance" in window;
  const players = Array.from(
    document.querySelectorAll("[data-article-player]"),
  ).filter(
    (root): root is HTMLElement =>
      root instanceof HTMLElement &&
      (Boolean(root.dataset.audioSrc) || supportsSpeech),
  );

  if (players.length > 0) {
    if ("IntersectionObserver" in window) {
      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (!(entry.target instanceof HTMLElement) || !entry.isIntersecting)
            return;

          initArticlePlayer(entry.target);
          observer.unobserve(entry.target);
        });
      });

      players.forEach((player) => {
        player.hidden = false;
        observer.observe(player);
      });
    } else {
      players.forEach((player) => {
        player.hidden = false;
        initArticlePlayer(player);
      });
    }
  }
</script>
