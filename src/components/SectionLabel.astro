---
interface Props {
  text: string;
  textEn: string;
  colorClass?: string;
}
import { localeFromPathname } from "../lib/locale-path";

const { text, textEn, colorClass = "text-orange-400" } = Astro.props;
const isEnglish = localeFromPathname(Astro.url.pathname) === "en";
---

<span
  class:list={["block text-xs font-bold uppercase tracking-widest", colorClass]}
>
  {isEnglish ? textEn : text}
</span>
