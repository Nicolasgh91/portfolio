---
const tableProps = Astro.props;
---

<div
  class="group/table my-8 overflow-x-auto rounded-xl border border-[color:var(--border-subtle)] bg-[var(--bg-secondary)]/30"
  data-table-wrapper
>
  <table
    {...tableProps}
    class:list={[
      "w-full min-w-[620px] text-left text-sm text-[var(--text-secondary)]",
      tableProps.class,
    ]}
  >
    <slot />
  </table>
</div>
