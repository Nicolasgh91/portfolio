---
/**
 * FAQ con microdata FAQPage, acordeón nativo e i18n (data-en / data-es).
 * Tags de categoría solo si hay más entradas que FAQ_TAG_THRESHOLD (configurable).
 */
export interface FaqItem {
  order: number;
  category: 'proceso' | 'comercial' | 'tecnico' | 'soporte';
  question: string;
  questionEn: string;
  answer: string;
  answerEn: string;
  highlight?: string;
  highlightEn?: string;
}

interface Props {
  entries: FaqItem[];
  /** Destino del CTA lateral (p. ej. #contacto en /servicios). */
  ctaHref?: string;
}

const { entries, ctaHref = '#contacto' } = Astro.props;

/** Umbral para mostrar tags de categoría; ajustable si el producto lo requiere. */
const FAQ_TAG_THRESHOLD = 8;
const showTags = entries.length > FAQ_TAG_THRESHOLD;

const categoryLabel = {
  proceso: { es: 'Proceso', en: 'Process' },
  comercial: { es: 'Comercial', en: 'Commercial' },
  tecnico: { es: 'Técnico', en: 'Technical' },
  soporte: { es: 'Soporte', en: 'Support' },
} as const;

const categoryTagClass: Record<FaqItem['category'], string> = {
  proceso:
    'border-[var(--accent-border)] bg-[hsla(var(--accent-h),var(--accent-s),56%,0.1)] text-[var(--accent)]',
  comercial:
    'border-[hsla(152,43%,55%,0.25)] bg-[hsla(152,43%,55%,0.1)] text-[var(--color-success)]',
  tecnico: 'border-[hsla(258,60%,70%,0.25)] bg-[hsla(258,60%,70%,0.1)] text-[hsl(258,55%,72%)]',
  soporte: 'border-[hsla(199,70%,60%,0.25)] bg-[hsla(199,70%,60%,0.1)] text-[hsl(199,75%,68%)]',
};
---

<div class="mt-10 rounded-2xl border border-[var(--border-normal)] bg-[var(--bg-secondary)] p-8 md:p-10">
  <div class="mb-10 grid gap-10 md:grid-cols-2 md:items-start">
    <div>
      <p
        class="mb-2 text-[11px] font-medium uppercase tracking-[0.18em] text-[var(--accent)]"
        data-en="FAQ"
        data-es="Preguntas frecuentes"
      >
        Preguntas frecuentes
      </p>
      <h2
        id="faq-heading"
        class="mb-3 font-[family-name:var(--font-display)] text-2xl font-extrabold leading-tight tracking-tight text-[var(--text-primary)] md:text-[2rem]"
        data-en="Everything you need to know before you get started"
        data-es="Todo lo que necesitás saber antes de arrancar"
      >
        Todo lo que necesitás saber antes de arrancar
      </h2>
      <p
        class="m-0 text-sm leading-relaxed text-[var(--text-muted)]"
        data-en="We answer the questions that come up most before a first meeting. If yours isn't listed here, the free diagnosis has no cost or obligation."
        data-es="Respondemos las dudas que más aparecen antes de una primera reunión. Si no encontrás lo que buscás, el diagnóstico gratuito no tiene costo ni compromiso."
      >
        Respondemos las dudas que más aparecen antes de una primera reunión. Si no encontrás lo que buscás, el diagnóstico
        gratuito no tiene costo ni compromiso.
      </p>
    </div>
    <div
      class="flex flex-col gap-4 rounded-[14px] border border-[var(--border-normal)] bg-[var(--bg-tertiary)] p-7"
    >
      <p
        class="m-0 font-[family-name:var(--font-display)] text-lg font-bold leading-snug text-[var(--text-primary)]"
        data-en="Have a question that isn't listed here?"
        data-es="¿Tenés una duda que no está acá?"
      >
        ¿Tenés una duda que no está acá?
      </p>
      <p
        class="m-0 text-[13px] leading-relaxed text-[var(--text-muted)]"
        data-en="Book a free 30-minute diagnosis. We'll review your operation and tell you whether working together makes sense."
        data-es="Agendá un diagnóstico gratuito de 30 minutos. Analizamos tu operación y te decimos si tiene sentido trabajar juntos."
      >
        Agendá un diagnóstico gratuito de 30 minutos. Analizamos tu operación y te decimos si tiene sentido trabajar juntos.
      </p>
      <a
        href={ctaHref}
        class="inline-flex w-fit items-center rounded-lg bg-[var(--accent)] px-5 py-2.5 text-[13px] font-medium text-[var(--color-on-accent)] transition-opacity hover:opacity-90 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--accent)]"
        data-en="Book free diagnosis →"
        data-es="Agendar diagnóstico gratis →"
      >
        Agendar diagnóstico gratis →
      </a>
    </div>
  </div>

  <div class="flex flex-col gap-0.5" itemscope itemtype="https://schema.org/FAQPage">
    {
      entries.map((item, index) => (
        <details
          class="group overflow-hidden rounded-xl border border-[var(--border-subtle)] bg-[var(--bg-tertiary)] open:border-[var(--accent-border)] open:bg-[var(--bg-secondary)]"
          {...(index === 0 ? { open: true } : {})}
          itemscope
          itemprop="mainEntity"
          itemtype="https://schema.org/Question"
        >
          <summary class="flex cursor-pointer list-none items-center justify-between gap-4 px-5 py-5 text-left [&::-webkit-details-marker]:hidden">
            <span class="flex min-w-0 flex-1 items-center gap-3.5">
              {showTags && (
                <span
                  class:list={[
                    'inline-flex shrink-0 rounded-md border px-2 py-0.5 text-[10px] font-medium md:inline-flex',
                    categoryTagClass[item.category],
                  ]}
                  data-en={categoryLabel[item.category].en}
                  data-es={categoryLabel[item.category].es}
                >
                  {categoryLabel[item.category].es}
                </span>
              )}
              <span
                class="text-[15px] font-medium leading-snug text-[var(--text-secondary)] group-open:text-[var(--text-primary)]"
                itemprop="name"
                data-en={item.questionEn}
                data-es={item.question}
              >
                {item.question}
              </span>
            </span>
            <span
              class="flex h-[22px] w-[22px] shrink-0 items-center justify-center rounded-full border border-[var(--border-normal)] bg-[var(--bg-secondary)] text-base leading-none text-[var(--accent)] transition-transform duration-200 group-open:rotate-45 group-open:border-[var(--accent)] group-open:bg-[var(--accent)] group-open:text-[var(--color-on-accent)]"
              aria-hidden="true"
            >
              +
            </span>
          </summary>
          <div itemscope itemprop="acceptedAnswer" itemtype="https://schema.org/Answer">
            <div class="px-5 pb-5 pt-0 md:pl-5">
              <p
                class="m-0 text-sm leading-relaxed text-[var(--text-secondary)]"
                itemprop="text"
                data-en={item.answerEn}
                data-es={item.answer}
              >
                {item.answer}
              </p>
            </div>
          </div>
        </details>
      ))
    }
  </div>
</div>
