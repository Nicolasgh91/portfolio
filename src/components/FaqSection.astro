---
/**
 * FAQ con i18n (data-en / data-es). JSON-LD FAQPage debe inyectarse en la página (`buildFaqPageJsonLd`).
 * Modo native: `<details>`; modo animated: acordeón con grid 0fr/1fr + script acotado por id.
 */
import {
  FAQ_TAG_THRESHOLD,
  FAQ_CATEGORY_LABEL,
  FAQ_CATEGORY_CLASS,
  type FaqCategory,
} from "../lib/faq-taxonomy";
import { localeFromPathname } from "../lib/locale-path";

export interface FaqItem {
  order: number;
  category: FaqCategory;
  question: string;
  questionEn: string;
  answer: string;
  answerEn: string;
  highlight?: string;
  highlightEn?: string;
}

interface Props {
  entries: FaqItem[];
  /** Destino del CTA lateral (p. ej. #contacto en /servicios). */
  ctaHref?: string;
  /** Si es false, oculta el bloque lateral con CTA (p. ej. catálogo de landings sin duplicar conversión). */
  showSidebarCta?: boolean;
  eyebrowEs?: string;
  eyebrowEn?: string;
  headingEs?: string;
  headingEn?: string;
  introEs?: string;
  introEn?: string;
  /** Clases extra en el contenedor (p. ej. `mt-0` cuando el padre ya define separación). */
  class?: string;
  /** `native`: `<details>`; `animated`: botones + grid + JS (solo un panel abierto). */
  accordionStyle?: "native" | "animated";
  /** Id del contenedor del listado en modo animated (scope del script). */
  faqAnimatedRootId?: string;
  /**
   * `darkBand`: paleta fija para bloques sobre fondos oscuros (p. ej. /servicios sobre slate-950);
   * evita depender de `html.light` donde los tokens claros romperían el contraste.
   * `animated` no soporta `darkBand` (caso de uso exclusivo de plantillas).
   */
  variant?: "default" | "darkBand";
}

const {
  entries,
  ctaHref = "#contacto",
  showSidebarCta = true,
  eyebrowEs = "Preguntas frecuentes",
  eyebrowEn = "FAQ",
  headingEs = "Todo lo que necesitás saber antes de arrancar",
  headingEn = "Everything you need to know before you get started",
  introEs = "Respondemos las dudas que más aparecen antes de una primera reunión. Si no encontrás lo que buscás, el diagnóstico gratuito no tiene costo ni compromiso.",
  introEn = "We answer the questions that come up most before a first meeting. If yours isn't listed here, the free diagnosis has no cost or obligation.",
  class: rootClass = "",
  accordionStyle = "native",
  faqAnimatedRootId = "faq-animated-root",
  variant = "default",
} = Astro.props;

const isDarkBand = variant === "darkBand";

const showTags = entries.length > FAQ_TAG_THRESHOLD;
const categoryLabel = FAQ_CATEGORY_LABEL;
const categoryTagClass = FAQ_CATEGORY_CLASS;
const isEnglish = localeFromPathname(Astro.url.pathname) === "en";

const categoryTagClassDark: Record<FaqItem["category"], string> = {
  proceso: "border-orange-400/35 bg-orange-500/10 text-orange-300",
  comercial: "border-emerald-400/30 bg-emerald-500/10 text-emerald-300",
  tecnico: "border-violet-400/30 bg-violet-500/10 text-violet-200",
  soporte: "border-sky-400/30 bg-sky-500/10 text-sky-200",
};
---

<div
  class:list={[
    "mt-10 rounded-2xl p-8 md:p-10",
    isDarkBand
      ? "border-2 border-orange-500/40 bg-slate-900/95 shadow-lg shadow-black/20"
      : "border border-[var(--border-normal)] bg-[var(--bg-secondary)]",
    rootClass,
  ]}
>
  <div
    class:list={[
      "mb-10 grid gap-10 md:items-start",
      showSidebarCta ? "md:grid-cols-2" : "md:grid-cols-1",
    ]}
  >
    <div>
      <p
        class:list={[
          "mb-2 text-[11px] font-medium uppercase tracking-[0.18em]",
          isDarkBand ? "text-orange-400" : "text-[var(--accent)]",
        ]}
        data-en={eyebrowEn}
        data-es={eyebrowEs}
      >
        {isEnglish ? eyebrowEn : eyebrowEs}
      </p>
      <h2
        id="faq-heading"
        class:list={[
          "mb-3 font-[family-name:var(--font-display)] text-2xl font-extrabold leading-tight tracking-tight md:text-[2rem]",
          isDarkBand ? "text-white" : "text-[var(--text-primary)]",
        ]}
        data-en={headingEn}
        data-es={headingEs}
      >
        {isEnglish ? headingEn : headingEs}
      </h2>
      <p
        class:list={[
          "m-0 text-sm leading-relaxed",
          isDarkBand ? "text-slate-300" : "text-[var(--text-muted)]",
        ]}
        data-en={introEn}
        data-es={introEs}
      >
        {isEnglish ? introEn : introEs}
      </p>
    </div>
    {
      showSidebarCta && (
        <div
          class:list={[
            "flex flex-col gap-4 rounded-[14px] border p-7",
            isDarkBand
              ? "border-white/10 bg-slate-950/80"
              : "border-[var(--border-normal)] bg-[var(--bg-tertiary)]",
          ]}
        >
          <p
            class:list={[
              "m-0 font-[family-name:var(--font-display)] text-lg font-bold leading-snug",
              isDarkBand ? "text-white" : "text-[var(--text-primary)]",
            ]}
            data-en="Have a question that isn't listed here?"
            data-es="¿Tenés una duda que no está acá?"
          >
            {isEnglish
              ? "Have a question that isn't listed here?"
              : "¿Tenés una duda que no está acá?"}
          </p>
          <p
            class:list={[
              "m-0 text-[13px] leading-relaxed",
              isDarkBand ? "text-slate-300" : "text-[var(--text-muted)]",
            ]}
            data-en="Book a free 30-minute diagnosis. We'll review your operation and tell you whether working together makes sense."
            data-es="Agendá un diagnóstico gratuito de 30 minutos. Analizamos tu operación y te decimos si tiene sentido trabajar juntos."
          >
            {isEnglish
              ? "Book a free 30-minute diagnosis. We'll review your operation and tell you whether working together makes sense."
              : "Agendá un diagnóstico gratuito de 30 minutos. Analizamos tu operación y te decimos si tiene sentido trabajar juntos."}
          </p>
          <a href={ctaHref} class="btn-primary btn-bounce w-fit font-medium">
            <span data-es data-en="Book free diagnosis">
              {isEnglish ? "Book free diagnosis" : "Agendar diagnóstico gratis"}
            </span>
            <span class="arrow" aria-hidden="true">
              →
            </span>
          </a>
        </div>
      )
    }
  </div>

  {
    accordionStyle === "native" ? (
      <div class="flex flex-col gap-0.5">
        {entries.map((item, index) => (
          <details
            class:list={[
              "faq-item faq-item--native group overflow-hidden rounded-xl border",
              isDarkBand
                ? "border-white/10 bg-slate-950/70 open:border-orange-500/45 open:bg-slate-900/90"
                : "border-[var(--border-subtle)] bg-[var(--bg-tertiary)] open:border-[var(--accent-border)] open:bg-[var(--bg-secondary)]",
            ]}
            {...(index === 0 ? { open: true } : {})}
          >
            <summary>
              <span class="flex min-w-0 flex-1 items-center gap-3.5">
                {showTags && (
                  <span
                    class:list={[
                      "inline-flex shrink-0 rounded-md border px-2 py-0.5 text-[10px] font-medium md:inline-flex",
                      isDarkBand
                        ? categoryTagClassDark[item.category]
                        : categoryTagClass[item.category],
                    ]}
                    data-en={categoryLabel[item.category].en}
                    data-es={categoryLabel[item.category].es}
                  >
                    {categoryLabel[item.category][isEnglish ? "en" : "es"]}
                  </span>
                )}
                <span
                  class:list={[
                    "text-[15px] font-medium leading-snug",
                    isDarkBand
                      ? "text-slate-200 group-open:text-orange-400"
                      : "text-[var(--text-secondary)] group-open:text-[var(--accent)]",
                  ]}
                  data-en={item.questionEn}
                  data-es={item.question}
                >
                  {isEnglish ? item.questionEn : item.question}
                </span>
              </span>
              <span
                class:list={[
                  "flex h-[22px] w-[22px] shrink-0 items-center justify-center rounded-full border text-base leading-none transition-transform duration-200 group-open:rotate-45",
                  isDarkBand
                    ? "border-white/20 bg-slate-900 text-orange-400 group-open:border-orange-400 group-open:bg-orange-400 group-open:text-[var(--color-on-accent)]"
                    : "border-[var(--border-normal)] bg-[var(--bg-secondary)] text-[var(--accent)] group-open:border-[var(--accent)] group-open:bg-[var(--accent)] group-open:text-[var(--color-on-accent)]",
                ]}
                aria-hidden="true"
              >
                +
              </span>
            </summary>
            <div>
              <div class="px-5 pb-5 pt-0 md:pl-5">
                <p
                  class:list={[
                    "m-0 text-sm leading-relaxed",
                    isDarkBand
                      ? "text-slate-300"
                      : "text-[var(--text-secondary)]",
                  ]}
                  data-en={item.answerEn}
                  data-es={item.answer}
                >
                  {isEnglish ? item.answerEn : item.answer}
                </p>
              </div>
            </div>
          </details>
        ))}
      </div>
    ) : (
      <div
        id={faqAnimatedRootId}
        data-faq-animated-root
        class="faq-animated-root flex flex-col"
      >
        {entries.map((item, index) => (
          <div
            class:list={[
              "faq-item faq-item--animated border-b border-white/[0.07] py-6 first:pt-0 last:border-b-0",
              { open: index === 0 },
            ]}
          >
            <button
              type="button"
              class="faq-q flex w-full cursor-pointer items-start justify-between gap-5 border-0 bg-transparent text-left text-lg font-semibold text-[var(--text-primary)]"
              aria-expanded={index === 0 ? "true" : "false"}
            >
              <span
                class="min-w-0 flex-1"
                data-en={item.questionEn}
                data-es={item.question}
              >
                {isEnglish ? item.questionEn : item.question}
              </span>
              <span class="faq-icon shrink-0" aria-hidden="true">
                +
              </span>
            </button>
            <div class="faq-answer-panel">
              <div class="min-h-0 overflow-hidden">
                <div>
                  <p
                    class="max-w-[680px] pt-4 text-sm font-light leading-relaxed text-[var(--text-secondary)]"
                    data-en={item.answerEn}
                    data-es={item.answer}
                  >
                    {isEnglish ? item.answerEn : item.answer}
                  </p>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    )
  }
</div>

<script>
  // CSP-005: sin `is:inline`/`define:vars`; cada FAQ animada resuelve su
  // raíz via `data-faq-animated-root` para que Astro pueda empaquetar el
  // script como archivo externo (CSP script-src 'self').
  document.querySelectorAll("[data-faq-animated-root]").forEach((root) => {
    const syncAria = () => {
      root.querySelectorAll(".faq-item--animated").forEach((item) => {
        const btn = item.querySelector(".faq-q");
        if (btn)
          btn.setAttribute(
            "aria-expanded",
            item.classList.contains("open") ? "true" : "false",
          );
      });
    };
    root.querySelectorAll(".faq-q").forEach((btn) => {
      btn.addEventListener("click", () => {
        const item = btn.closest(".faq-item--animated");
        if (!item || !root.contains(item)) return;
        const wasOpen = item.classList.contains("open");
        root.querySelectorAll(".faq-item--animated").forEach((i) => {
          i.classList.remove("open");
        });
        if (!wasOpen) item.classList.add("open");
        syncAria();
      });
    });
    syncAria();
  });
</script>
