---
/**
 * FAQ con i18n (data-en / data-es). JSON-LD FAQPage debe inyectarse en la página (`buildFaqPageJsonLd`).
 * Modo native: `<details>`; modo animated: acordeón con grid 0fr/1fr + script acotado por id.
 */
export interface FaqItem {
  order: number;
  category: 'proceso' | 'comercial' | 'tecnico' | 'soporte';
  question: string;
  questionEn: string;
  answer: string;
  answerEn: string;
  highlight?: string;
  highlightEn?: string;
}

interface Props {
  entries: FaqItem[];
  /** Destino del CTA lateral (p. ej. #contacto en /servicios). */
  ctaHref?: string;
  /** Si es false, oculta el bloque lateral con CTA (p. ej. catálogo de landings sin duplicar conversión). */
  showSidebarCta?: boolean;
  eyebrowEs?: string;
  eyebrowEn?: string;
  headingEs?: string;
  headingEn?: string;
  introEs?: string;
  introEn?: string;
  /** Clases extra en el contenedor (p. ej. `mt-0` cuando el padre ya define separación). */
  class?: string;
  /** `native`: `<details>`; `animated`: botones + grid + JS (solo un panel abierto). */
  accordionStyle?: 'native' | 'animated';
  /** Id del contenedor del listado en modo animated (scope del script). */
  faqAnimatedRootId?: string;
}

const {
  entries,
  ctaHref = '#contacto',
  showSidebarCta = true,
  eyebrowEs = 'Preguntas frecuentes',
  eyebrowEn = 'FAQ',
  headingEs = 'Todo lo que necesitás saber antes de arrancar',
  headingEn = 'Everything you need to know before you get started',
  introEs =
    'Respondemos las dudas que más aparecen antes de una primera reunión. Si no encontrás lo que buscás, el diagnóstico gratuito no tiene costo ni compromiso.',
  introEn =
    "We answer the questions that come up most before a first meeting. If yours isn't listed here, the free diagnosis has no cost or obligation.",
  class: rootClass = '',
  accordionStyle = 'native',
  faqAnimatedRootId = 'faq-animated-root',
} = Astro.props;

/** Umbral para mostrar tags de categoría; ajustable si el producto lo requiere. */
const FAQ_TAG_THRESHOLD = 8;
const showTags = entries.length > FAQ_TAG_THRESHOLD;

const categoryLabel = {
  proceso: { es: 'Proceso', en: 'Process' },
  comercial: { es: 'Comercial', en: 'Commercial' },
  tecnico: { es: 'Técnico', en: 'Technical' },
  soporte: { es: 'Soporte', en: 'Support' },
} as const;

const categoryTagClass: Record<FaqItem['category'], string> = {
  proceso:
    'border-[var(--accent-border)] bg-[hsla(var(--accent-h),var(--accent-s),56%,0.1)] text-[var(--accent)]',
  comercial:
    'border-[hsla(152,43%,55%,0.25)] bg-[hsla(152,43%,55%,0.1)] text-[var(--color-success)]',
  tecnico: 'border-[hsla(258,60%,70%,0.25)] bg-[hsla(258,60%,70%,0.1)] text-[hsl(258,55%,72%)]',
  soporte: 'border-[hsla(199,70%,60%,0.25)] bg-[hsla(199,70%,60%,0.1)] text-[hsl(199,75%,68%)]',
};
---

<div class:list={['mt-10 rounded-2xl border border-[var(--border-normal)] bg-[var(--bg-secondary)] p-8 md:p-10', rootClass]}>
  <div
    class:list={[
      'mb-10 grid gap-10 md:items-start',
      showSidebarCta ? 'md:grid-cols-2' : 'md:grid-cols-1',
    ]}
  >
    <div>
      <p
        class="mb-2 text-[11px] font-medium uppercase tracking-[0.18em] text-[var(--accent)]"
        data-en={eyebrowEn}
        data-es={eyebrowEs}
      >
        {eyebrowEs}
      </p>
      <h2
        id="faq-heading"
        class="mb-3 font-[family-name:var(--font-display)] text-2xl font-extrabold leading-tight tracking-tight text-[var(--text-primary)] md:text-[2rem]"
        data-en={headingEn}
        data-es={headingEs}
      >
        {headingEs}
      </h2>
      <p
        class="m-0 text-sm leading-relaxed text-[var(--text-muted)]"
        data-en={introEn}
        data-es={introEs}
      >
        {introEs}
      </p>
    </div>
    {
      showSidebarCta && (
        <div class="flex flex-col gap-4 rounded-[14px] border border-[var(--border-normal)] bg-[var(--bg-tertiary)] p-7">
          <p
            class="m-0 font-[family-name:var(--font-display)] text-lg font-bold leading-snug text-[var(--text-primary)]"
            data-en="Have a question that isn't listed here?"
            data-es="¿Tenés una duda que no está acá?"
          >
            ¿Tenés una duda que no está acá?
          </p>
          <p
            class="m-0 text-[13px] leading-relaxed text-[var(--text-muted)]"
            data-en="Book a free 30-minute diagnosis. We'll review your operation and tell you whether working together makes sense."
            data-es="Agendá un diagnóstico gratuito de 30 minutos. Analizamos tu operación y te decimos si tiene sentido trabajar juntos."
          >
            Agendá un diagnóstico gratuito de 30 minutos. Analizamos tu operación y te decimos si tiene sentido trabajar
            juntos.
          </p>
          <a href={ctaHref} class="btn-primary btn-bounce w-fit font-medium">
            <span data-es>Agendar diagnóstico gratis</span>
            <span data-en class="hidden">Book free diagnosis</span>
            <span class="arrow" aria-hidden="true">→</span>
          </a>
        </div>
      )
    }
  </div>

  {
    accordionStyle === 'native' ? (
      <div class="flex flex-col gap-0.5">
        {entries.map((item, index) => (
          <details
            class="faq-item faq-item--native group overflow-hidden rounded-xl border border-[var(--border-subtle)] bg-[var(--bg-tertiary)] open:border-[var(--accent-border)] open:bg-[var(--bg-secondary)]"
            {...(index === 0 ? { open: true } : {})}
          >
            <summary>
              <span class="flex min-w-0 flex-1 items-center gap-3.5">
                {showTags && (
                  <span
                    class:list={[
                      'inline-flex shrink-0 rounded-md border px-2 py-0.5 text-[10px] font-medium md:inline-flex',
                      categoryTagClass[item.category],
                    ]}
                    data-en={categoryLabel[item.category].en}
                    data-es={categoryLabel[item.category].es}
                  >
                    {categoryLabel[item.category].es}
                  </span>
                )}
                <span
                  class="text-[15px] font-medium leading-snug text-[var(--text-secondary)] group-open:text-[var(--accent)]"
                  data-en={item.questionEn}
                  data-es={item.question}
                >
                  {item.question}
                </span>
              </span>
              <span
                class="flex h-[22px] w-[22px] shrink-0 items-center justify-center rounded-full border border-[var(--border-normal)] bg-[var(--bg-secondary)] text-base leading-none text-[var(--accent)] transition-transform duration-200 group-open:rotate-45 group-open:border-[var(--accent)] group-open:bg-[var(--accent)] group-open:text-[var(--color-on-accent)]"
                aria-hidden="true"
              >
                +
              </span>
            </summary>
            <div>
              <div class="px-5 pb-5 pt-0 md:pl-5">
                <p
                  class="m-0 text-sm leading-relaxed text-[var(--text-secondary)]"
                  data-en={item.answerEn}
                  data-es={item.answer}
                >
                  {item.answer}
                </p>
              </div>
            </div>
          </details>
        ))}
      </div>
    ) : (
      <div id={faqAnimatedRootId} class="faq-animated-root flex flex-col">
        {entries.map((item, index) => (
          <div
            class:list={[
              'faq-item faq-item--animated border-b border-white/[0.07] py-6 first:pt-0 last:border-b-0',
              { open: index === 0 },
            ]}
          >
            <button
              type="button"
              class="faq-q flex w-full cursor-pointer items-start justify-between gap-5 border-0 bg-transparent text-left text-lg font-semibold text-[var(--text-primary)]"
              aria-expanded={index === 0 ? 'true' : 'false'}
            >
              <span class="min-w-0 flex-1" data-en={item.questionEn} data-es={item.question}>
                {item.question}
              </span>
              <span class="faq-icon shrink-0" aria-hidden="true">
                +
              </span>
            </button>
            <div class="faq-answer-panel">
              <div class="min-h-0 overflow-hidden">
                <div>
                  <p
                    class="max-w-[680px] pt-4 text-sm font-light leading-relaxed text-[var(--text-secondary)]"
                    data-en={item.answerEn}
                    data-es={item.answer}
                  >
                    {item.answer}
                  </p>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    )
  }
</div>

{
  accordionStyle === 'animated' && (
    <script is:inline define:vars={{ faqAnimatedRootId }}>
      (function () {
        var root = document.getElementById(faqAnimatedRootId);
        if (!root) return;
        function syncAria() {
          root.querySelectorAll('.faq-item--animated').forEach(function (item) {
            var btn = item.querySelector('.faq-q');
            if (btn)
              btn.setAttribute('aria-expanded', item.classList.contains('open') ? 'true' : 'false');
          });
        }
        root.querySelectorAll('.faq-q').forEach(function (btn) {
          btn.addEventListener('click', function () {
            var item = btn.closest('.faq-item--animated');
            if (!item || !root.contains(item)) return;
            var wasOpen = item.classList.contains('open');
            root.querySelectorAll('.faq-item--animated').forEach(function (i) {
              i.classList.remove('open');
            });
            if (!wasOpen) item.classList.add('open');
            syncAria();
          });
        });
        syncAria();
      })();
    </script>
  )
}
