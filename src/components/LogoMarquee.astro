---
/**
 * Carrusel de marcas/stack; SVG vía `?raw` + `set:html`, color vía `currentColor` en el root del SVG.
 * Pausa en hover. Sin `<Image>` (raster); ver docs/componentes/LogoMarquee.md.
 */
import astroSvg from "../assets/marquee/astro.svg?raw";
import reactSvg from "../assets/marquee/react.svg?raw";
import typescriptSvg from "../assets/marquee/typescript.svg?raw";
import tailwindSvg from "../assets/marquee/tailwind.svg?raw";
import vercelSvg from "../assets/marquee/vercel.svg?raw";
import pythonSvg from "../assets/marquee/python.svg?raw";
import nodejsSvg from "../assets/marquee/nodejs.svg?raw";
import supabaseSvg from "../assets/marquee/supabase.svg?raw";
import { localeFromPathname } from "../lib/locale-path";

/** Orden alineado a roadmap RD-3.3 (monocromo + filtro tipo SquareBlack). */
const logoSvgs = [
  astroSvg,
  reactSvg,
  typescriptSvg,
  tailwindSvg,
  vercelSvg,
  supabaseSvg,
  pythonSvg,
  nodejsSvg,
] as const;

const SVG_DENY =
  /<script|on\w+\s*=|javascript:|<foreignObject|<embed|<object|<iframe/i;
for (const svg of logoSvgs) {
  if (SVG_DENY.test(svg)) {
    throw new Error(
      "Marquee SVG contains potentially dangerous content. Aborting build.",
    );
  }
}

const logoSlotClass = "logo-marquee__slot";
const isEnglish = localeFromPathname(Astro.url.pathname) === "en";
---

<div
  class="logo-marquee--accent overflow-hidden rounded-2xl px-5 py-10 md:px-8 md:py-16"
>
  <div
    class="mx-auto mb-8 flex max-w-7xl flex-col gap-4 sm:flex-row sm:items-center sm:justify-between md:mb-10"
  >
    <p
      class="text-center text-xs font-bold uppercase tracking-widest sm:text-left"
    >
      {isEnglish ? "Stack & tools" : "Stack y herramientas"}
    </p>
    <p
      class="text-center text-[0.65rem] font-bold uppercase tracking-[0.2em] sm:text-right"
    >
      {isEnglish ? "Core stack" : "Stack principal"}
    </p>
  </div>

  <ul
    class="hidden list-none flex-wrap items-center justify-center gap-x-12 gap-y-8 motion-reduce:flex"
    aria-label="Stack y herramientas"
  >
    {logoSvgs.map((svg) => <li class={logoSlotClass} set:html={svg} />)}
  </ul>

  <div
    class="flex w-max max-w-full animate-marqueeScroll hover:[animation-play-state:paused] motion-reduce:hidden"
    aria-hidden="true"
  >
    {
      [0, 1].map(() => (
        <div class="flex shrink-0 items-center gap-12 pr-12 md:gap-16 md:pr-16">
          {logoSvgs.map((svg) => (
            <span class={logoSlotClass} set:html={svg} />
          ))}
        </div>
      ))
    }
  </div>
</div>
