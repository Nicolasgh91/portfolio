---
/**
 * Hero de página: imagen fullscreen + capas (gradiente, ruido, glow) y copy en columna única.
 * Reutilizable en rutas que no usen el mock de dashboard de la home.
 */
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import SectionLabel from "./SectionLabel.astro";

interface Props {
  image: ImageMetadata;
  alt: string;
  imageWidth: number;
  imageHeight: number;
  headingId: string;
  /** Rótulo superior (ES); si se omite label y labelEn, no hay SectionLabel. */
  labelText?: string;
  labelTextEn?: string;
}

const {
  image,
  alt,
  imageWidth,
  imageHeight,
  headingId,
  labelText,
  labelTextEn,
} = Astro.props;

const showLabel = Boolean(labelText?.trim() || labelTextEn?.trim());
const labelEs = (labelText ?? labelTextEn ?? "").trim();
const labelEn = (labelTextEn ?? labelText ?? "").trim();

const heroNoiseBg =
  'url("data:image/svg+xml,%3Csvg%20viewBox%3D%220%200%20200%20200%22%20xmlns%3D%22http%3A//www.w3.org/2000/svg%22%3E%3Cfilter%20id%3D%22n%22%3E%3CfeTurbulence%20type%3D%22fractalNoise%22%20baseFrequency%3D%220.9%22%20numOctaves%3D%224%22%20stitchTiles%3D%22stitch%22/%3E%3C/filter%3E%3Crect%20width%3D%22100%25%22%20height%3D%22100%25%22%20filter%3D%22url(%23n)%22%20opacity%3D%220.04%22/%3E%3C/svg%3E")';
---

<section
  class="section-dark relative min-h-screen overflow-hidden bg-slate-950"
  aria-labelledby={headingId}
>
  <div class="pointer-events-none absolute inset-0 z-0">
    <Image
      src={image}
      alt={alt}
      width={imageWidth}
      height={imageHeight}
      widths={[640, 768, 1024, 1280, 1536]}
      sizes="100vw"
      loading="eager"
      fetchpriority="high"
      decoding="async"
      class="h-full min-h-full w-full object-cover opacity-[0.28]"
    />
  </div>
  <div
    class="pointer-events-none absolute inset-0 z-[1] bg-gradient-to-b from-slate-950/90 via-slate-950/82 to-slate-950"
    aria-hidden="true"
  >
  </div>
  <div
    class="pointer-events-none absolute inset-x-0 bottom-0 z-[1] h-[58%] bg-gradient-to-t from-slate-950 from-35% via-slate-950/92 to-transparent"
    aria-hidden="true"
  >
  </div>
  <div
    class="pointer-events-none absolute inset-0 z-[2] opacity-[0.35] motion-reduce:hidden"
    aria-hidden="true"
    style={`background-image:${heroNoiseBg}`}
  >
  </div>
  <div
    class="hero-glow pointer-events-none absolute -top-28 left-1/2 z-[2] h-[400px] w-[600px] -translate-x-1/2 motion-reduce:hidden"
    aria-hidden="true"
    style="background: radial-gradient(ellipse, hsla(var(--accent-h), var(--accent-s), 56%, 0.12) 0%, transparent 70%);"
  >
  </div>

  <div
    class="relative z-10 mx-auto flex min-h-[calc(100vh-4rem)] max-w-7xl flex-col justify-center px-6 py-16 md:py-24"
  >
    <div class="w-full max-w-5xl" aria-label="Propuesta de valor">
      {
        showLabel && (
          <SectionLabel
            text={labelEs}
            textEn={labelEn}
            colorClass="text-[var(--accent-text)]"
          />
        )
      }
      <h1
        id={headingId}
        class="mt-3 font-display font-extrabold tracking-tight text-white"
        style="font-size: var(--text-5xl);"
      >
        <slot name="heading" />
      </h1>
      <div class="mt-6 max-w-5xl text-base leading-relaxed text-slate-300">
        <slot />
      </div>
    </div>
  </div>
</section>
