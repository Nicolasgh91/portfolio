---
/**
 * Contenedor de sección con color blocking; `tone` aplica texto fijo (no invierte con html.dark).
 */
interface Props {
  bg?: string;
  padding?: string;
  maxWidth?: string;
  /** default: hereda tema; dark: .section-dark; accent: .section-accent (CTA naranja). */
  tone?: 'default' | 'dark' | 'accent';
  id?: string;
  class?: string;
  innerClass?: string;
  /** Scroll-reveal Alt B (solo /, /servicios, /talento; ver Layout + docs/scroll-reveal.md). */
  revealAlt?: boolean;
}

const {
  bg = 'bg-white',
  padding = 'py-24 md:py-32',
  maxWidth = 'max-w-7xl',
  tone = 'default',
  id,
  class: className = '',
  innerClass = '',
  revealAlt = false,
} = Astro.props;

const toneClass = tone === 'dark' ? 'section-dark' : tone === 'accent' ? 'section-accent' : '';
const altRevealClass = revealAlt ? 'opacity-0 translate-y-4 transition-all duration-700' : '';
---

<section
  class:list={[bg, padding, 'w-full', toneClass, altRevealClass, className]}
  id={id}
  {...(revealAlt ? { 'data-alt-reveal': true } : {})}
>
  <div class:list={['mx-auto', 'w-full', 'px-6', maxWidth, innerClass]}>
    <slot />
  </div>
</section>
