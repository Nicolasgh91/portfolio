---
/**
 * Contenedor de sección con color blocking.
 * `tone="default"`: fondo vía tokens (`:root` / `:root.light` en tokens.css), p. ej. `var(--bg-primary)`.
 * `tone="dark"` | `tone="accent"`: `.section-dark` / `.section-accent` (texto fijo), sin seguir el toggle de tema.
 */
interface Props {
  bg?: string;
  padding?: string;
  maxWidth?: string;
  /** default: superficie primaria tokenizada; `dark`/`accent`: bloques fijos. */
  tone?: "default" | "dark" | "accent";
  id?: string;
  class?: string;
  innerClass?: string;
  /** Scroll-reveal Alt B (solo /, /servicios, /talento; ver Layout + docs/scroll-reveal.md). */
  revealAlt?: boolean;
  /** Stagger RD-4.1: `Math.min(i * 100, 600)` ms en `transition-delay` (solo con `revealAlt`). */
  revealDelayMs?: number;
}

const {
  bg = "bg-[var(--bg-primary)]",
  padding = "py-24 md:py-32",
  maxWidth = "max-w-7xl",
  tone = "default",
  id,
  class: className = "",
  innerClass = "",
  revealAlt = false,
  revealDelayMs,
} = Astro.props;

const toneClass =
  tone === "dark" ? "section-dark" : tone === "accent" ? "section-accent" : "";
const altRevealClass = revealAlt
  ? "opacity-0 translate-y-4 transition-[opacity,transform] duration-700"
  : "";
const sectionStyle =
  revealAlt && revealDelayMs != null
    ? { transitionDelay: `${revealDelayMs}ms` }
    : undefined;
---

<section
  class:list={[bg, padding, "w-full", toneClass, altRevealClass, className]}
  id={id}
  style={sectionStyle}
  {...revealAlt ? { "data-alt-reveal": true } : {}}
>
  <div class:list={["mx-auto", "w-full", "px-6", maxWidth, innerClass]}>
    <slot />
  </div>
</section>
