---
import { Image } from 'astro:assets';

interface Props {
  src: string;
  alt: string;
  totalPages: number;
  class?: string;
}

const { src, alt, totalPages, class: className } = Astro.props;

const slideModules = import.meta.glob('../assets/slides/**/slide-*.webp', { eager: true });
const folderNeedle = `/slides/${src}/`;

const orderedSlides = Object.entries(slideModules)
  .filter(([path]) => path.includes(folderNeedle))
  .map(([path, mod]) => {
    const match = path.match(/slide-(\d+)\.webp$/);
    return {
      path,
      page: match ? Number.parseInt(match[1], 10) : Number.POSITIVE_INFINITY,
      image: (mod as { default: ImageMetadata }).default,
    };
  })
  .sort((a, b) => a.page - b.page);

const renderedTotalPages = orderedSlides.length;
const announcedTotalPages = totalPages > 0 ? totalPages : renderedTotalPages;
const hasSlides = renderedTotalPages > 0;
const hasMultipleSlides = renderedTotalPages > 1;
const viewerId = `slide-viewer-${src.replace(/[^a-zA-Z0-9_-]/g, '-')}`;
---

{
  hasSlides ? (
    <section
      id={viewerId}
      data-slide-viewer
      data-total={renderedTotalPages}
      role="region"
      aria-label={`Visor de presentacion: ${alt}`}
      tabindex="0"
      class:list={[
        'not-prose max-w-none overflow-hidden rounded-[var(--radius-lg)] border border-[color:var(--border-subtle)] bg-[var(--bg-secondary)]',
        className,
      ]}
    >
      <div class="relative aspect-video w-full select-none">
        {orderedSlides.map((slide, index) => (
          <div
            data-slide-frame
            data-index={index}
            class:list={[
              'absolute inset-0 transition-opacity duration-200',
              index === 0 ? 'opacity-100' : 'pointer-events-none opacity-0',
            ]}
            aria-hidden={index === 0 ? 'false' : 'true'}
          >
            <Image
              src={slide.image}
              alt={`${alt} - pagina ${index + 1} de ${announcedTotalPages}`}
              loading={index === 0 ? 'eager' : 'lazy'}
              class="h-full w-full object-contain"
            />
          </div>
        ))}

        {hasMultipleSlides && (
          <>
            <button
              type="button"
              data-slide-prev
              aria-label="Pagina anterior"
              class="absolute left-2 top-1/2 z-10 inline-flex min-h-11 min-w-11 -translate-y-1/2 items-center justify-center rounded-full border border-[color:var(--border-subtle)] bg-black text-[var(--color-accent-400)] opacity-90 shadow-sm transition hover:border-[color:var(--border-normal)] hover:opacity-100 focus-visible:opacity-100 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[color:var(--color-accent-400)] sm:left-4"
            >
              <span aria-hidden="true">‹</span>
            </button>

            <button
              type="button"
              data-slide-next
              aria-label="Pagina siguiente"
              class="absolute right-2 top-1/2 z-10 inline-flex min-h-11 min-w-11 -translate-y-1/2 items-center justify-center rounded-full border border-[color:var(--border-subtle)] bg-black text-[var(--color-accent-400)] opacity-90 shadow-sm transition hover:border-[color:var(--border-normal)] hover:opacity-100 focus-visible:opacity-100 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[color:var(--color-accent-400)] sm:right-4"
            >
              <span aria-hidden="true">›</span>
            </button>
          </>
        )}

        {hasMultipleSlides && (
          <p
            aria-live="polite"
            data-slide-indicator
            class="absolute bottom-3 right-3 z-10 rounded-full border border-[color:var(--border-subtle)] bg-[var(--bg-primary)]/75 px-3 py-1 text-sm text-[var(--text-secondary)] backdrop-blur-sm"
          >
            1 / {announcedTotalPages}
          </p>
        )}
      </div>

      <script>
        (() => {
          const viewer = document.currentScript?.closest('[data-slide-viewer]');
          if (!viewer) return;

          const total = Number.parseInt(viewer.getAttribute('data-total') ?? '0', 10);
          if (!Number.isFinite(total) || total <= 0) return;

          const frames = Array.from(viewer.querySelectorAll('[data-slide-frame]'));
          const prevBtn = viewer.querySelector('[data-slide-prev]');
          const nextBtn = viewer.querySelector('[data-slide-next]');
          const indicator = viewer.querySelector('[data-slide-indicator]');
          let current = 0;
          let startX = 0;
          let endX = 0;
          const swipeThreshold = 40;

          const render = () => {
            frames.forEach((frame, index) => {
              const active = index === current;
              frame.classList.toggle('opacity-100', active);
              frame.classList.toggle('opacity-0', !active);
              frame.classList.toggle('pointer-events-none', !active);
              frame.setAttribute('aria-hidden', active ? 'false' : 'true');
            });
            if (indicator) indicator.textContent = `${current + 1} / ${total}`;
            if (prevBtn) {
              const isFirst = current === 0;
              prevBtn.toggleAttribute('disabled', isFirst);
              prevBtn.classList.toggle('invisible', isFirst);
            }
            if (nextBtn) {
              const isLast = current === total - 1;
              nextBtn.toggleAttribute('disabled', isLast);
              nextBtn.classList.toggle('invisible', isLast);
            }
          };

          const goPrev = () => {
            if (current === 0) return;
            current -= 1;
            render();
          };

          const goNext = () => {
            if (current >= total - 1) return;
            current += 1;
            render();
          };

          prevBtn?.addEventListener('click', goPrev);
          nextBtn?.addEventListener('click', goNext);

          viewer.addEventListener('keydown', (event) => {
            if (event.key === 'ArrowLeft') {
              event.preventDefault();
              goPrev();
            }
            if (event.key === 'ArrowRight') {
              event.preventDefault();
              goNext();
            }
          });

          viewer.addEventListener(
            'touchstart',
            (event) => {
              startX = event.changedTouches[0]?.clientX ?? 0;
              endX = startX;
            },
            { passive: true },
          );

          viewer.addEventListener(
            'touchmove',
            (event) => {
              endX = event.changedTouches[0]?.clientX ?? startX;
            },
            { passive: true },
          );

          viewer.addEventListener('touchend', () => {
            const delta = endX - startX;
            if (Math.abs(delta) < swipeThreshold) return;
            if (delta > 0) goPrev();
            else goNext();
          });

          render();
        })();
      </script>
    </section>
  ) : (
    <section
      role="region"
      aria-label={`Visor de presentacion: ${alt}`}
      class:list={[
        'not-prose max-w-none rounded-[var(--radius-lg)] border border-dashed border-[color:var(--border-subtle)] bg-[var(--bg-secondary)] p-4 text-sm text-[var(--text-secondary)]',
        className,
      ]}
    >
      Slides no disponibles para <strong class="text-[var(--text-primary)]">{src}</strong>.
    </section>
  )
}
