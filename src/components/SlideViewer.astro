---
import { Image } from 'astro:assets';
import { getSlideImageFromGlobModule } from '../lib/slides';

interface Props {
  src: string;
  alt: string;
  class?: string;
}

const { src, alt, class: className } = Astro.props;

const slideModules = import.meta.glob('../assets/slides/**/slide-*.webp', { eager: true });
const folderNeedle = `/slides/${src}/`;

const orderedSlides = Object.entries(slideModules)
  .filter(([path]) => path.includes(folderNeedle))
  .map(([path, mod]) => {
    const match = path.match(/slide-(\d+)\.webp$/);
    return {
      path,
      page: match ? Number.parseInt(match[1], 10) : Number.POSITIVE_INFINITY,
      image: getSlideImageFromGlobModule(mod),
    };
  })
  .sort((a, b) => a.page - b.page);

const renderedTotalPages = orderedSlides.length;
const hasSlides = renderedTotalPages > 0;
const hasMultipleSlides = renderedTotalPages > 1;
const viewerId = `slide-viewer-${src.replace(/[^a-zA-Z0-9_-]/g, '-')}`;
const fullscreenBtnId = `${viewerId}-fullscreen-btn`;
---

{
  hasSlides ? (
    <section
      id={viewerId}
      data-slide-viewer
      role="region"
      aria-label={`Visor de presentación: ${alt}`}
      tabindex="0"
      class:list={['not-prose max-w-none outline-none', className]}
    >
      <div data-slide-host>
        <div
          data-slide-surface
          class="w-full max-w-6xl overflow-hidden rounded-[var(--radius-lg)] border border-[color:var(--border-subtle)] bg-[hsla(0,0%,100%,0.82)] dark:bg-[hsla(240,13%,10%,0.80)] backdrop-blur-[20px] [-webkit-backdrop-filter:blur(20px)]"
        >
          <div data-slide-media-wrapper class="relative aspect-video w-full select-none">
            {orderedSlides.map((slide, index) => (
              <div
                data-slide-frame
                data-slide
                data-index={index}
                class:list={[
                  'absolute inset-0 transition-opacity duration-200',
                  index === 0 ? 'opacity-100' : 'pointer-events-none opacity-0',
                ]}
                aria-hidden={index === 0 ? 'false' : 'true'}
              >
                <Image
                  src={slide.image}
                  alt={`${alt} - pagina ${index + 1} de ${renderedTotalPages}`}
                  loading={index === 0 ? 'eager' : 'lazy'}
                  class="h-full w-full object-contain"
                />
              </div>
            ))}

            <button
              type="button"
              id={fullscreenBtnId}
              data-slide-fullscreen
              aria-label="Ver en pantalla completa"
              class="absolute left-2 top-2 z-20 inline-flex h-8 w-8 items-center justify-center rounded-full border border-[color:var(--border-subtle)] bg-black text-[var(--color-accent-400)] opacity-90 shadow-sm transition hover:border-[color:var(--border-normal)] hover:opacity-100 focus-visible:opacity-100 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[color:var(--color-accent-400)] sm:left-4 sm:top-3"
            >
              <span data-slide-fs-icon-expand class="block" aria-hidden="true">
                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M3.75 3.75v4.5m0-4.5h4.5m-4.5 0L9 9M3.75 20.25v-4.5m0 4.5h4.5m-4.5 0L9 15M20.25 3.75h-4.5m4.5 0v4.5m0-4.5L15 9m5.25 11.25h-4.5m4.5 0v-4.5m0 4.5L15 15"
                  />
                </svg>
              </span>
              <span data-slide-fs-icon-collapse class="hidden" aria-hidden="true">
                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M9 9V4.5M9 9H4.5M9 9L3.75 3.75M9 15v4.5M9 15H4.5M9 15l-5.25 5.25M15 9h4.5M15 9V4.5M15 9l5.25-5.25M15 15h4.5M15 15v4.5m0-4.5l5.25 5.25"
                  />
                </svg>
              </span>
            </button>

            {hasMultipleSlides && (
              <>
                <button
                  type="button"
                  data-slide-prev
                  aria-label="Página anterior"
                  class="absolute left-2 top-1/2 z-10 inline-flex min-h-11 min-w-11 -translate-y-1/2 items-center justify-center rounded-full border border-[color:var(--border-subtle)] bg-black text-[var(--color-accent-400)] opacity-90 shadow-sm transition hover:border-[color:var(--border-normal)] hover:opacity-100 focus-visible:opacity-100 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[color:var(--color-accent-400)] sm:left-4"
                >
                  <span aria-hidden="true">‹</span>
                </button>

                <button
                  type="button"
                  data-slide-next
                  aria-label="Página siguiente"
                  class="absolute right-2 top-1/2 z-10 inline-flex min-h-11 min-w-11 -translate-y-1/2 items-center justify-center rounded-full border border-[color:var(--border-subtle)] bg-black text-[var(--color-accent-400)] opacity-90 shadow-sm transition hover:border-[color:var(--border-normal)] hover:opacity-100 focus-visible:opacity-100 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[color:var(--color-accent-400)] sm:right-4"
                >
                  <span aria-hidden="true">›</span>
                </button>
              </>
            )}

            {hasMultipleSlides && (
              <p
                aria-live="polite"
                data-slide-indicator
                class="absolute bottom-3 right-3 z-10 rounded-full border border-[color:var(--border-subtle)] bg-[var(--bg-primary)]/75 px-3 py-1 text-sm text-[var(--text-secondary)] backdrop-blur-sm"
              >
                1 / {renderedTotalPages}
              </p>
            )}
          </div>
        </div>
      </div>

      <div
        data-slide-overlay
        class="hidden fixed inset-0 z-50 w-screen overflow-hidden bg-[hsla(0,0%,100%,0.55)] dark:bg-[hsla(240,13%,10%,0.65)] backdrop-blur-[20px] [-webkit-backdrop-filter:blur(20px)]"
        aria-hidden="true"
        inert
      >
        <div
          data-slide-overlay-inner
          class="flex h-full w-full items-center justify-center overflow-hidden p-2 box-border"
        />
      </div>

      <script define:vars={{ viewerId, fullscreenBtnId }}>
        const viewer = document.getElementById(viewerId);
        if (!viewer) return;

        const fsBtn = document.getElementById(fullscreenBtnId);
        const iconExpand = viewer.querySelector('[data-slide-fs-icon-expand]');
        const iconCollapse = viewer.querySelector('[data-slide-fs-icon-collapse]');

        const total = viewer.querySelectorAll('[data-slide]').length;
        if (!Number.isFinite(total) || total <= 0) return;

        const frames = Array.from(viewer.querySelectorAll('[data-slide-frame]'));
        const prevBtn = viewer.querySelector('[data-slide-prev]');
        const nextBtn = viewer.querySelector('[data-slide-next]');
        const indicator = viewer.querySelector('[data-slide-indicator]');
        const surface = viewer.querySelector('[data-slide-surface]');
        const mediaWrapper = viewer.querySelector('[data-slide-media-wrapper]');
        const surfaceHost = viewer.querySelector('[data-slide-host]');
        const overlay = viewer.querySelector('[data-slide-overlay]');
        const overlayInner = viewer.querySelector('[data-slide-overlay-inner]');
        let current = 0;
        let startX = 0;
        let endX = 0;
        const swipeThreshold = 40;

        const render = () => {
          frames.forEach((frame, index) => {
            const active = index === current;
            frame.classList.toggle('opacity-100', active);
            frame.classList.toggle('opacity-0', !active);
            frame.classList.toggle('pointer-events-none', !active);
            frame.setAttribute('aria-hidden', active ? 'false' : 'true');
          });
          if (indicator) indicator.textContent = `${current + 1} / ${total}`;
          if (prevBtn) {
            const isFirst = current === 0;
            prevBtn.toggleAttribute('disabled', isFirst);
            prevBtn.classList.toggle('invisible', isFirst);
          }
          if (nextBtn) {
            const isLast = current === total - 1;
            nextBtn.toggleAttribute('disabled', isLast);
            nextBtn.classList.toggle('invisible', isLast);
          }
        };

        const goPrev = () => {
          if (current === 0) return;
          current -= 1;
          render();
        };

        const goNext = () => {
          if (current >= total - 1) return;
          current += 1;
          render();
        };

        const setFullscreenUi = (expanded) => {
          if (fsBtn) {
            fsBtn.setAttribute(
              'aria-label',
              expanded ? 'Salir de pantalla completa' : 'Ver en pantalla completa',
            );
          }
          if (iconExpand instanceof HTMLElement) iconExpand.classList.toggle('hidden', expanded);
          if (iconCollapse instanceof HTMLElement) iconCollapse.classList.toggle('hidden', !expanded);
        };

        const setFullscreenLayout = (expanded) => {
          if (surface instanceof HTMLElement) {
            // Evita alto 0 del wrapper cuando `aspect-video` se desactiva en fullscreen.
            surface.classList.toggle('h-full', expanded);
          }

          if (!(mediaWrapper instanceof HTMLElement)) return;

          // En fullscreen quitamos la restricción del ratio para que el wrapper pueda llenar la viewport.
          // Esto permite que la imagen `object-contain` respete el tamaño disponible.
          if (expanded) {
            mediaWrapper.classList.remove('aspect-video');
            mediaWrapper.classList.add('h-full');
          } else {
            mediaWrapper.classList.add('aspect-video');
            mediaWrapper.classList.remove('h-full');
          }
        };

        const getFullscreenDom = () => {
          if (
            !(overlay instanceof HTMLElement) ||
            !(overlayInner instanceof HTMLElement) ||
            !(surface instanceof HTMLElement)
          )
            return null;

          return { overlay, overlayInner, surface };
        };

        const setOverlayVisibility = (overlayEl, expanded) => {
          overlayEl.classList.toggle('hidden', !expanded);
          overlayEl.setAttribute('aria-hidden', expanded ? 'false' : 'true');
          overlayEl.toggleAttribute('inert', !expanded);
        };

        const collapseFullscreen = () => {
          const fullscreenDom = getFullscreenDom();
          if (!fullscreenDom) return;
          const { overlay: overlayEl, surface: surfaceEl } = fullscreenDom;
          if (overlayEl.classList.contains('hidden')) return;

          // Restaurar el árbol original.
          if (surfaceHost instanceof HTMLElement) {
            surfaceHost.appendChild(surfaceEl);
          }
          setOverlayVisibility(overlayEl, false);
          document.body.classList.remove('overflow-hidden');
          setFullscreenUi(false);
          setFullscreenLayout(false);
          fsBtn?.focus();
        };

        const expandFullscreen = () => {
          const fullscreenDom = getFullscreenDom();
          if (!fullscreenDom) return;
          const { overlay: overlayEl, overlayInner: overlayInnerEl, surface: surfaceEl } = fullscreenDom;

          // Fallback de viewport units para Safari móvil.
          let heightValue = '100vh';
          if (CSS.supports('height: 100dvh')) heightValue = '100dvh';
          else if (CSS.supports('height: 100svh')) heightValue = '100svh';

          overlayEl.style.height = heightValue;

          // Mover el contenedor visual al overlay dedicado.
          overlayInnerEl.appendChild(surfaceEl);

          setOverlayVisibility(overlayEl, true);
          document.body.classList.add('overflow-hidden');
          setFullscreenUi(true);
          setFullscreenLayout(true);
          viewer.focus();
        };

        const toggleFullscreen = () => {
          const fullscreenDom = getFullscreenDom();
          if (!fullscreenDom) return;
          if (fullscreenDom.overlay.classList.contains('hidden')) expandFullscreen();
          else collapseFullscreen();
        };

        fsBtn?.addEventListener('click', toggleFullscreen);

        prevBtn?.addEventListener('click', goPrev);
        nextBtn?.addEventListener('click', goNext);

        viewer.addEventListener('keydown', (event) => {
          if (event.key === 'ArrowLeft') {
            event.preventDefault();
            goPrev();
          }
          if (event.key === 'ArrowRight') {
            event.preventDefault();
            goNext();
          }
        });

        viewer.addEventListener(
          'touchstart',
          (event) => {
            startX = event.changedTouches[0]?.clientX ?? 0;
            endX = startX;
          },
          { passive: true },
        );

        viewer.addEventListener(
          'touchmove',
          (event) => {
            endX = event.changedTouches[0]?.clientX ?? startX;
          },
          { passive: true },
        );

        viewer.addEventListener('touchend', () => {
          const delta = endX - startX;
          if (Math.abs(delta) < swipeThreshold) return;
          if (delta > 0) goPrev();
          else goNext();
        });

        document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape') collapseFullscreen();
        });

        render();
      </script>
    </section>
  ) : (
    <section
      role="region"
      aria-label={`Visor de presentación: ${alt}`}
      class:list={[
        'not-prose max-w-none rounded-[var(--radius-lg)] border border-dashed border-[color:var(--border-subtle)] bg-[var(--bg-secondary)] p-4 text-sm text-[var(--text-secondary)]',
        className,
      ]}
    >
      Slides no disponibles para <strong class="text-[var(--text-primary)]">{src}</strong>.
    </section>
  )
}
