---
interface Props {
  activePage?: 'home' | 'servicios' | 'talento' | 'blog';
}
const { activePage = 'home' } = Astro.props;
---

<header>
  <nav class="nav" role="navigation" aria-label="Navegación principal">

    <!-- Logo -->
    <a href="/" class="nav-logo" aria-label="Nicolás Hruszczak — Inicio">
      nh<span>.</span>
    </a>

    <!-- Links centro (desktop) — siempre en el DOM para SEO -->
    <ul class="nav-tabs" role="list">
      <li><a
        href="/"
        class={`nav-tab ${activePage === 'home' ? 'active' : ''}`}
        aria-current={activePage === 'home' ? 'page' : undefined}
        data-en="Home" data-es="Inicio"
      >Inicio</a></li>

      <li class="nav-tab-dropdown-wrapper">
        <button
          class={`nav-tab nav-tab--dropdown ${activePage === 'servicios' ? 'active' : ''}`}
          id="services-btn"
          aria-haspopup="true"
          aria-expanded="false"
          aria-controls="services-menu"
          data-en="B2B Services" data-es="Servicios B2B"
        >Servicios B2B <span class="dropdown-arrow" aria-hidden="true">▾</span></button>
        <div id="services-menu" class="services-menu" role="menu" aria-labelledby="services-btn" hidden>
          <a role="menuitem" href="/servicios#agentes-ia" class="services-item">
            <svg aria-hidden="true" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M12 2v3m0 14v3M4.22 4.22l2.12 2.12m11.32 11.32 2.12 2.12M2 12h3m14 0h3M4.22 19.78l2.12-2.12M17.66 6.34l2.12-2.12"/></svg>
            Agentes IA
          </a>
          <a role="menuitem" href="/servicios#ecommerce" class="services-item">
            <svg aria-hidden="true" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
            E-commerce
          </a>
          <a role="menuitem" href="/servicios#automatizacion" class="services-item">
            <svg aria-hidden="true" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 3 21 3 21 8"/><line x1="4" y1="20" x2="21" y2="3"/><polyline points="21 16 21 21 16 21"/><line x1="15" y1="15" x2="21" y2="21"/></svg>
            Automatización
          </a>
          <a role="menuitem" href="/servicios#landing" class="services-item">
            <svg aria-hidden="true" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg>
            Landing Pages
          </a>
        </div>
      </li>

      <li><a
        href="/blog"
        class={`nav-tab ${activePage === 'blog' ? 'active' : ''}`}
        aria-current={activePage === 'blog' ? 'page' : undefined}
        data-en="Blog" data-es="Blog"
      >Blog</a></li>

      <li><a
        href="/talento"
        class={`nav-tab ${activePage === 'talento' ? 'active' : ''}`}
        aria-current={activePage === 'talento' ? 'page' : undefined}
        data-en="Profile" data-es="Perfil profesional"
      >Perfil profesional</a></li>
    </ul>

    <!-- Derecha desktop: controles + CTA -->
    <div class="nav-right">
      <!-- Controles agrupados -->
      <div class="nav-controls">
        <button
          id="theme-btn"
          class="ctrl-btn"
          onclick="nhTheme.toggle()"
          aria-label="Cambiar tema claro/oscuro"
          title="Tema"
        >◑ Dark</button>

        <button
          id="lang-btn"
          class="ctrl-btn"
          onclick="nhLang.toggle()"
          aria-label="Switch to English"
          title="Language / Idioma"
        >EN</button>

        <button
          id="a11y-btn"
          class="ctrl-btn"
          onclick="nhA11y.togglePanel()"
          aria-label="Opciones de accesibilidad"
          aria-expanded="false"
          aria-controls="a11y-panel"
          title="Accesibilidad"
        >☰ Accesibilidad</button>
      </div>

      <!-- CTA desktop -->
      <a
        href="/servicios#contacto"
        class="nav-cta"
        data-en="Free diagnosis →"
        data-es="Diagnóstico gratis →"
        aria-label="Solicitar diagnóstico gratuito"
      >Diagnóstico gratis →</a>
    </div>

    <!-- Mobile right: CTA compacto + hamburguesa -->
    <div class="nav-mobile-right">
      <a
        href="/servicios#contacto"
        class="nav-cta nav-cta--compact"
        data-en="Diagnosis →"
        data-es="Diagnóstico →"
        aria-label="Solicitar diagnóstico gratuito"
      >Diagnóstico →</a>

      <button
        class="nav-burger"
        id="nav-burger"
        aria-label="Abrir menú de navegación"
        aria-expanded="false"
        aria-controls="nav-drawer"
      >
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>

  </nav>

  <!-- Drawer mobile — todos los links en el DOM, visibles para crawlers -->
  <div
    id="nav-drawer"
    class="nav-drawer"
    aria-label="Menú móvil"
    aria-hidden="true"
  >
    <ul class="drawer-links">
      <li><a
        href="/"
        class={`drawer-link ${activePage === 'home' ? 'active' : ''}`}
        aria-current={activePage === 'home' ? 'page' : undefined}
        data-en="Home" data-es="Inicio"
      >Inicio</a></li>

      <li><a
        href="/servicios#agentes-ia"
        class={`drawer-link drawer-link--sub ${activePage === 'servicios' ? 'active' : ''}`}
        aria-current={activePage === 'servicios' ? 'page' : undefined}
        data-en="AI Agents" data-es="Agentes IA"
      >Agentes IA</a></li>
      <li><a
        href="/servicios#ecommerce"
        class="drawer-link drawer-link--sub"
        data-en="E-commerce" data-es="E-commerce"
      >E-commerce</a></li>
      <li><a
        href="/servicios#automatizacion"
        class="drawer-link drawer-link--sub"
        data-en="Automation" data-es="Automatización"
      >Automatización</a></li>
      <li><a
        href="/servicios#landing"
        class="drawer-link drawer-link--sub"
        data-en="Landing Pages" data-es="Landing Pages"
      >Landing Pages</a></li>

      <li><a
        href="/blog"
        class={`drawer-link ${activePage === 'blog' ? 'active' : ''}`}
        aria-current={activePage === 'blog' ? 'page' : undefined}
        data-en="Blog" data-es="Blog"
      >Blog</a></li>

      <li><a
        href="/talento"
        class={`drawer-link ${activePage === 'talento' ? 'active' : ''}`}
        aria-current={activePage === 'talento' ? 'page' : undefined}
        data-en="Profile" data-es="Perfil profesional"
      >Perfil profesional</a></li>
    </ul>

    <!-- Controles dentro del drawer -->
    <div class="drawer-controls">
      <button
        class="ctrl-btn"
        onclick="nhTheme.toggle()"
        aria-label="Cambiar tema claro/oscuro"
      >◑ Dark</button>

      <button
        class="ctrl-btn"
        onclick="nhLang.toggle()"
        aria-label="Switch to English"
      >EN</button>

      <button
        class="ctrl-btn"
        onclick="nhA11y.togglePanel()"
        aria-label="Opciones de accesibilidad"
      >☰ Accesibilidad</button>
    </div>

    <a
      href="/servicios#contacto"
      class="drawer-cta"
      data-en="Request free diagnosis →"
      data-es="Solicitar diagnóstico gratuito →"
    >Solicitar diagnóstico gratuito →</a>

    <!-- Iconos sociales — solo visibles en mobile drawer -->
    <div class="drawer-social">
      <a href="https://github.com/Nicolasgh91" target="_blank" rel="noopener noreferrer" aria-label="GitHub de Nicolás Hruszczak">
        <svg aria-hidden="true" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2z"/>
        </svg>
      </a>
      <a href="https://linkedin.com/in/nicolasgh91" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn de Nicolás Hruszczak">
        <svg aria-hidden="true" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
          <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
        </svg>
      </a>
      <a href="https://x.com/nicolasgh91" target="_blank" rel="noopener noreferrer" aria-label="X (Twitter) de Nicolás Hruszczak">
        <svg aria-hidden="true" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
          <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.737-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
        </svg>
      </a>
      <a href="https://instagram.com/nicolasgh91" target="_blank" rel="noopener noreferrer" aria-label="Instagram de Nicolás Hruszczak">
        <svg aria-hidden="true" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/>
        </svg>
      </a>
    </div>
  </div>

  <!-- Panel de accesibilidad (sin cambios) -->
  <div
    id="a11y-panel"
    class="a11y-panel"
    role="region"
    aria-label="Panel de accesibilidad"
  >
    <div class="a11y-group">
      <span class="a11y-label" id="font-size-label">Tamaño de texto</span>
      <div class="a11y-btns" role="group" aria-labelledby="font-size-label">
        <button class="a11y-btn a11y-fs-btn on" data-scale="1"
          onclick="nhA11y.setFontScale(1)" aria-pressed="true">A</button>
        <button class="a11y-btn a11y-fs-btn" data-scale="1.15"
          onclick="nhA11y.setFontScale(1.15)" aria-pressed="false">A+</button>
        <button class="a11y-btn a11y-fs-btn" data-scale="1.3"
          onclick="nhA11y.setFontScale(1.3)" aria-pressed="false">A++</button>
      </div>
    </div>

    <div class="a11y-group">
      <span class="a11y-label" id="contrast-label">Contraste</span>
      <div class="a11y-btns" role="group" aria-labelledby="contrast-label">
        <button class="a11y-btn on" id="hc-off"
          onclick="nhA11y.setHighContrast(false)" aria-pressed="false">Normal</button>
        <button class="a11y-btn" id="hc-on"
          onclick="nhA11y.setHighContrast(true)" aria-pressed="false">Alto contraste</button>
      </div>
    </div>

    <div class="a11y-group">
      <span class="a11y-label" id="motion-label">Movimiento</span>
      <div class="a11y-btns" role="group" aria-labelledby="motion-label">
        <button class="a11y-btn on" id="mot-on"
          onclick="nhA11y.setReducedMotion(false)" aria-pressed="true">Activado</button>
        <button class="a11y-btn" id="mot-off"
          onclick="nhA11y.setReducedMotion(true)" aria-pressed="false">Reducido</button>
      </div>
    </div>
  </div>
</header>

<style>
  /* ─────────────────────────────────────────
     NAV BASE — split layout: logo | tabs | right
  ───────────────────────────────────────── */
  .nav {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 0 24px;
    height: 52px;
    background: var(--nav-bg);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 0.5px solid var(--nav-border);
    position: sticky;
    top: 0;
    z-index: 50;
  }

  /* ─────────────────────────────────────────
     LOGO
  ───────────────────────────────────────── */
  .nav-logo {
    font-family: var(--font-display);
    font-size: 20px;
    font-weight: 800;
    letter-spacing: -0.5px;
    color: var(--nav-logo-color);
    text-decoration: none;
    flex-shrink: 0;
    margin-right: 8px;
  }
  .nav-logo span { color: var(--accent); }

  /* ─────────────────────────────────────────
     TABS CENTRO — crecen para ocupar espacio disponible
  ───────────────────────────────────────── */
  .nav-tabs {
    display: flex;
    gap: 3px;
    flex: 1;
    min-width: 0;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .nav-tabs li {
    display: contents; /* CRITICO: preserva layout flex; el <li> es invisible para layout */
  }

  .nav-tab {
    height: 32px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0 13px;
    border: 0.5px solid var(--nav-idle-border);
    border-radius: var(--radius-md);
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--nav-text-idle);
    background: transparent;
    text-decoration: none;
    white-space: nowrap;
    position: relative;
    transition:
      color 0.12s ease,
      border-color 0.12s ease,
      background 0.12s ease,
      transform 0.12s ease;
  }

  /* Indicador de página activa: punto circular bajo el tab */
  .nav-tab::after {
    content: '';
    position: absolute;
    bottom: -5px;
    left: 50%;
    transform: translateX(-50%);
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--accent);
    opacity: 0;
    transition: opacity 0.2s ease;
  }
  .nav-tab.active::after {
    opacity: 1;
  }
  @media (prefers-reduced-motion: reduce) {
    .nav-tab::after { transition: none; }
  }
  :root.no-motion .nav-tab::after {
    transition: none !important;
  }
  .nav-tab:hover {
    color: var(--nav-logo-color);
    border-color: var(--nav-btn-hover-border);
    transform: translateY(-1px);
  }
  .nav-tab.active {
    color: var(--accent);
    border-color: var(--accent-border);
    background: var(--accent-bg);
  }

  /* ─────────────────────────────────────────
     DROPDOWN DE SERVICIOS
  ───────────────────────────────────────── */
  li.nav-tab-dropdown-wrapper {
    position: relative;
    display: flex;
    align-items: center;
  }

  .nav-tab--dropdown {
    position: relative; /* ancla el .services-menu independientemente del display del <li> padre */
    border: 0.5px solid var(--nav-idle-border);
    cursor: pointer;
    gap: 5px;
  }
  .nav-tab--dropdown:hover {
    color: var(--nav-logo-color);
    border-color: var(--nav-btn-hover-border);
    transform: translateY(-1px);
  }

  .dropdown-arrow {
    font-size: 10px;
    display: inline-block;
    transition: transform 0.15s ease;
    line-height: 1;
  }
  .nav-tab--dropdown[aria-expanded="true"] .dropdown-arrow {
    transform: rotate(180deg);
  }

  .services-menu {
    position: absolute;
    top: calc(100% + 8px);
    left: 0;
    min-width: 200px;
    background: var(--bg-secondary);
    border: 0.5px solid var(--nav-border);
    border-radius: var(--radius-md);
    padding: 6px;
    z-index: 200;
    box-shadow: 0 8px 24px hsla(0, 0%, 0%, 0.35);
  }

  .services-item {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px 12px;
    border-radius: var(--radius-sm);
    color: var(--nav-text-idle);
    font-family: var(--font-body);
    font-size: var(--text-sm);
    text-decoration: none;
    transition: color 0.12s ease, background 0.12s ease;
  }
  .services-item:hover,
  .services-item:focus {
    color: var(--nav-logo-color);
    background: var(--nav-btn-hover-bg);
    outline: none;
  }

  /* Sub-links en drawer (estilo más compacto con indentado) */
  .drawer-link--sub {
    padding-left: 28px;
    font-size: var(--text-xs);
    height: 36px;
  }

  /* ─────────────────────────────────────────
     DERECHA DESKTOP: controles + CTA
  ───────────────────────────────────────── */
  .nav-right {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-shrink: 0;
  }

  .nav-controls {
    display: flex;
    gap: 4px;
    align-items: center;
  }

  .ctrl-btn {
    height: 32px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 5px;
    padding: 0 11px;
    border: 0.5px solid var(--nav-idle-border);
    border-radius: var(--radius-md);
    font-family: var(--font-body);
    font-size: var(--text-xs);
    color: var(--nav-text-idle);
    background: transparent;
    cursor: pointer;
    white-space: nowrap;
    transition:
      color 0.12s ease,
      border-color 0.12s ease,
      background 0.12s ease,
      transform 0.12s ease;
  }
  .ctrl-btn:hover {
    border-color: var(--nav-btn-hover-border);
    color: var(--nav-btn-hover-color);
    background: var(--nav-btn-hover-bg);
    transform: translateY(-1px);
  }
  .ctrl-btn.on {
    border-color: var(--accent-border);
    color: var(--accent);
    background: var(--accent-bg);
  }

  /* ─────────────────────────────────────────
     CTA — botón de conversión principal
  ───────────────────────────────────────── */
  .nav-cta {
    height: 32px;
    display: inline-flex;
    align-items: center;
    padding: 0 14px;
    border-radius: var(--radius-md);
    background: var(--accent);
    color: var(--color-on-accent);
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 700;
    text-decoration: none;
    white-space: nowrap;
    flex-shrink: 0;
    transition:
      background 0.15s ease,
      transform 0.15s ease,
      box-shadow 0.15s ease;
  }
  .nav-cta:hover {
    background: var(--color-accent-500);
    transform: translateY(-1px);
    box-shadow: 0 4px 12px var(--accent-glow);
  }
  .nav-cta:active {
    transform: translateY(0);
  }

  /* ─────────────────────────────────────────
     MOBILE RIGHT: CTA compacto + hamburguesa
     Solo visible en mobile
  ───────────────────────────────────────── */
  .nav-mobile-right {
    display: none;
    align-items: center;
    gap: 8px;
    margin-left: auto;
  }

  .nav-cta--compact {
    padding: 0 10px;
    font-size: 11px;
  }

  /* ─────────────────────────────────────────
     HAMBURGUESA
  ───────────────────────────────────────── */
  .nav-burger {
    width: 36px;
    height: 36px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 5px;
    border: 0.5px solid var(--nav-idle-border);
    border-radius: var(--radius-md);
    background: transparent;
    cursor: pointer;
    padding: 0;
    flex-shrink: 0;
    transition: border-color 0.15s ease;
  }
  .nav-burger:hover {
    border-color: var(--nav-btn-hover-border);
  }
  .nav-burger span {
    display: block;
    width: 16px;
    height: 1.5px;
    background: var(--nav-text-idle);
    border-radius: 1px;
    transition: transform 0.25s ease, opacity 0.25s ease;
  }

  /* Hamburguesa → X cuando está abierto */
  .nav-burger[aria-expanded="true"] span:nth-child(1) {
    transform: translateY(6.5px) rotate(45deg);
  }
  .nav-burger[aria-expanded="true"] span:nth-child(2) {
    opacity: 0;
    transform: scaleX(0);
  }
  .nav-burger[aria-expanded="true"] span:nth-child(3) {
    transform: translateY(-6.5px) rotate(-45deg);
  }

  /* ─────────────────────────────────────────
     DRAWER MOBILE
     Siempre en el DOM → todos los links
     son crawleables por Google sin JS
  ───────────────────────────────────────── */
  .nav-drawer {
    display: none; /* ocultado visualmente, no removido del DOM */
    flex-direction: column;
    gap: 4px;
    padding: 12px 20px 16px;
    background: var(--nav-bg);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 0.5px solid var(--nav-border);
    /* Animación de apertura */
    transform: translateY(-8px);
    opacity: 0;
    transition:
      opacity 0.2s ease,
      transform 0.2s ease;
  }
  .nav-drawer.open {
    display: flex;
    opacity: 1;
    transform: translateY(0);
  }

  .drawer-links {
    display: flex;
    flex-direction: column;
    gap: 2px;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .drawer-links li {
    display: contents; /* CRITICO: preserva layout flex; el <li> es invisible para layout */
  }

  .drawer-link {
    height: 40px;
    display: flex;
    align-items: center;
    padding: 0 12px;
    border-radius: var(--radius-md);
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--nav-text-idle);
    text-decoration: none;
    border: 0.5px solid transparent;
    transition:
      color 0.12s ease,
      background 0.12s ease,
      border-color 0.12s ease;
  }
  .drawer-link:hover {
    color: var(--nav-logo-color);
    background: var(--nav-btn-hover-bg);
  }
  .drawer-link.active {
    color: var(--accent);
    background: var(--accent-bg);
    border-color: var(--accent-border);
  }

  .drawer-controls {
    display: flex;
    gap: 4px;
    flex-wrap: wrap;
    padding-top: 8px;
    border-top: 0.5px solid var(--nav-border);
    margin-top: 4px;
  }

  .drawer-cta {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 40px;
    border-radius: var(--radius-md);
    background: var(--accent);
    color: var(--color-on-accent);
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 700;
    text-decoration: none;
    margin-top: 8px;
    transition: background 0.15s ease, transform 0.15s ease;
  }
  .drawer-cta:hover {
    background: var(--color-accent-500);
    transform: translateY(-1px);
  }

  /* ─────────────────────────────────────────
     ICONOS SOCIALES DRAWER MOBILE
  ───────────────────────────────────────── */
  .drawer-social {
    display: flex;
    gap: 16px;
    justify-content: center;
    padding-top: 12px;
    border-top: 0.5px solid var(--nav-border);
    margin-top: 4px;
  }
  .drawer-social a {
    display: flex;
    align-items: center;
    color: var(--nav-text-idle);
    transition: color 0.15s ease;
  }
  .drawer-social a:hover {
    color: var(--accent);
  }

  /* ─────────────────────────────────────────
     PANEL ACCESIBILIDAD — sin cambios
  ───────────────────────────────────────── */
  .a11y-panel {
    display: none;
    background: var(--nav-bg);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 0.5px solid var(--nav-border);
    padding: 12px 24px;
    gap: var(--sp-lg);
    flex-wrap: wrap;
    align-items: center;
  }
  .a11y-panel.open { display: flex; }

  .a11y-group { display: flex; align-items: center; gap: var(--sp-sm); }
  .a11y-label {
    font-size: var(--text-xs);
    color: var(--nav-text-idle);
    letter-spacing: 0.5px;
    text-transform: uppercase;
    white-space: nowrap;
  }
  .a11y-btns { display: flex; gap: 4px; }
  .a11y-btn {
    height: 32px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0 10px;
    border: 0.5px solid var(--nav-idle-border);
    border-radius: var(--radius-md);
    font-family: var(--font-body);
    font-size: var(--text-xs);
    color: var(--nav-text-idle);
    background: transparent;
    cursor: pointer;
    transition:
      color 0.12s ease,
      border-color 0.12s ease,
      background 0.12s ease,
      transform 0.12s ease;
  }
  .a11y-btn:hover,
  .a11y-btn.on {
    border-color: var(--accent-border);
    color: var(--accent);
    background: var(--accent-bg);
  }
  .a11y-btn:hover { transform: translateY(-1px); }

  /* ─────────────────────────────────────────
     RESPONSIVE
  ───────────────────────────────────────── */

  /* Tablet: ocultar controles de accesibilidad, mantener tabs y CTA */
  @media (max-width: 900px) {
    #a11y-btn { display: none; }
  }

  /* Mobile: mostrar hamburguesa, ocultar tabs y controles desktop */
  @media (max-width: 680px) {
    .nav-tabs    { display: none; }
    .nav-right   { display: none; }
    .nav-mobile-right { display: flex; }
  }

  /* ─────────────────────────────────────────
     CTA PULSE — solo cuando el usuario no prefiere movimiento reducido
  ───────────────────────────────────────── */
  @media (prefers-reduced-motion: no-preference) {
    @keyframes cta-pulse {
      0%, 100% { box-shadow: 0 0 0 0 var(--accent-glow); }
      60%       { box-shadow: 0 0 0 7px transparent; }
    }
    .nav-cta {
      animation: cta-pulse 2.8s ease-in-out infinite;
    }
  }

  /* Clase expuesta por nhA11y.setReducedMotion(true) */
  :root.no-motion .nav-cta {
    animation: none !important;
  }
</style>

<script>
  /* ── Dropdown de servicios ── */
  const servicesBtn  = document.getElementById('services-btn') as HTMLButtonElement | null;
  const servicesMenu = document.getElementById('services-menu') as HTMLElement | null;

  function openServices() {
    servicesMenu?.removeAttribute('hidden');
    servicesBtn?.setAttribute('aria-expanded', 'true');
    (servicesMenu?.querySelector('[role="menuitem"]') as HTMLElement | null)?.focus();
  }
  function closeServices() {
    servicesMenu?.setAttribute('hidden', '');
    servicesBtn?.setAttribute('aria-expanded', 'false');
  }

  servicesBtn?.addEventListener('click', (e) => {
    e.stopPropagation();
    servicesMenu?.hasAttribute('hidden') ? openServices() : closeServices();
  });

  document.addEventListener('click', () => closeServices());

  servicesBtn?.addEventListener('keydown', (e: KeyboardEvent) => {
    if (e.key === 'Escape') { closeServices(); servicesBtn.focus(); }
    if (e.key === 'ArrowDown') { e.preventDefault(); openServices(); }
  });

  servicesMenu?.addEventListener('keydown', (e: KeyboardEvent) => {
    const items = Array.from(
      servicesMenu.querySelectorAll<HTMLElement>('[role="menuitem"]')
    );
    const idx = items.indexOf(document.activeElement as HTMLElement);
    if (e.key === 'ArrowDown') { e.preventDefault(); items[(idx + 1) % items.length]?.focus(); }
    if (e.key === 'ArrowUp')   { e.preventDefault(); items[(idx - 1 + items.length) % items.length]?.focus(); }
    if (e.key === 'Escape')    { closeServices(); servicesBtn?.focus(); }
    if (e.key === 'Tab')       { closeServices(); }
  });

  /* ── Drawer mobile ── */
  const burger  = document.getElementById('nav-burger');
  const drawer  = document.getElementById('nav-drawer');

  burger?.addEventListener('click', () => {
    const isOpen = drawer?.classList.contains('open');

    if (isOpen) {
      drawer?.classList.remove('open');
      burger.setAttribute('aria-expanded', 'false');
      drawer?.setAttribute('aria-hidden', 'true');
    } else {
      drawer?.classList.add('open');
      burger.setAttribute('aria-expanded', 'true');
      drawer?.setAttribute('aria-hidden', 'false');
    }
  });

  // Cerrar drawer al hacer click en cualquier link interno
  drawer?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      drawer?.classList.remove('open');
      burger?.setAttribute('aria-expanded', 'false');
      drawer?.setAttribute('aria-hidden', 'true');
    });
  });

  // Cerrar drawer con Escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && drawer?.classList.contains('open')) {
      drawer?.classList.remove('open');
      burger?.setAttribute('aria-expanded', 'false');
      drawer?.setAttribute('aria-hidden', 'true');
      burger?.focus();
    }
  });
</script>