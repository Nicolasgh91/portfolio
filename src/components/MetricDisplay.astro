---
interface Props {
  value: string;
  label: string;
  labelEn: string;
  valueColorClass?: string;
}
import { localeFromPathname } from "../lib/locale-path";

const {
  value,
  label,
  labelEn,
  valueColorClass = "text-[var(--accent)]",
} = Astro.props;
const isEnglish = localeFromPathname(Astro.url.pathname) === "en";
---

<div class="text-center">
  <p
    class:list={[
      "font-display font-black leading-none tracking-tighter",
      valueColorClass,
    ]}
    style="font-size: var(--text-metric);"
  >
    {value}
  </p>
  <p
    class="mt-2 text-sm font-medium uppercase tracking-wider text-[var(--text-secondary)]"
  >
    {isEnglish ? labelEn : label}
  </p>
</div>
