---
// ServiceCard.astro
// Tarjeta de catálogo de servicios B2B
// Hover: barra lateral amber que crece + glow radial cálido
// Uso: <ServiceCard service={service} />

interface Props {
  service: {
    title: string;
    titleEn?: string;
    description: string;
    descriptionEn?: string;
    icon?: string;
    href?: string;
    roiFocus?: string;
    priceFrom?: string;
  };
}

const { service } = Astro.props;

const El = service.href ? 'a' : 'div';
---

<El
  class="group relative flex h-full cursor-pointer flex-col gap-3 overflow-hidden rounded-xl border border-white/10 bg-slate-800 px-5 py-6 text-left no-underline transition-all duration-300 ease-out hover:-translate-y-1 hover:border-orange-500/35 hover:shadow-[0_16px_40px_-8px_rgba(245,158,11,0.12)] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-orange-500"
  href={service.href ?? undefined}
  aria-label={service.href ? service.title : undefined}
>
  <span
    class="absolute inset-y-[12%] left-0 w-[3px] origin-center scale-y-0 rounded-r-sm bg-orange-500 transition-transform duration-300 ease-out group-hover:scale-y-100"
    aria-hidden="true"
  ></span>

  <span
    class="pointer-events-none absolute inset-0 rounded-xl bg-[radial-gradient(ellipse_at_0%_50%,rgba(245,158,11,0.09)_0%,transparent_65%)] opacity-0 transition-opacity duration-300 group-hover:opacity-100"
    aria-hidden="true"
  ></span>

  {service.icon && (
    <div class="relative z-[1] flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-orange-500/10 text-lg transition-all duration-300 group-hover:scale-105 group-hover:bg-orange-500/20" aria-hidden="true">
      {service.icon}
    </div>
  )}

  <h3
    class="relative z-[1] text-sm font-bold leading-[1.35] text-slate-100 transition-colors duration-200 group-hover:text-white"
    data-en={service.titleEn ?? service.title}
    data-es={service.title}
  >
    {service.title}
  </h3>

  <p
    class="relative z-[1] flex-1 text-[13px] leading-relaxed text-slate-300"
    data-en={service.descriptionEn ?? service.description}
    data-es={service.description}
  >
    {service.description}
  </p>

  {service.roiFocus && (
    <p class="relative z-[1] mt-1 border-l-2 border-orange-500 bg-orange-500/10 p-3 text-sm leading-relaxed text-slate-300">
      {service.roiFocus}
    </p>
  )}

  {(service.priceFrom || service.href) && (
    <div class="relative z-[1] mt-2 flex items-center justify-between gap-3">
      {service.priceFrom ? (
        <span class="text-sm font-semibold text-orange-400">{service.priceFrom}</span>
      ) : (
        <span aria-hidden="true"></span>
      )}
      {service.href && (
        <span class="inline-flex translate-x-[-4px] items-center gap-1 text-xs font-semibold text-orange-500 opacity-0 transition-all duration-200 group-hover:translate-x-0 group-hover:opacity-100" aria-hidden="true">
          Ver más
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M14 5l7 7m0 0l-7 7m7-7H3"/>
          </svg>
        </span>
      )}
    </div>
  )}
</El>
