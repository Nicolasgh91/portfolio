---
/**
 * Tarjeta catálogo servicios (RD-2): ratio ~4:5, imagen ~60 % arriba, label + título + CTA.
 * Tema claro sobre filas white / slate-50; sin borde duro (sombra suave + hover).
 */
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import humanAi from '../assets/blog/human-ai.webp';
import cloudServers from '../assets/blog/cloud-servers.webp';
import satellite from '../assets/blog/satellite.webp';
import site from '../data/site.json';

interface Props {
  service: {
    title: string;
    titleEn?: string;
    shortDescription: string;
    shortDescriptionEn?: string;
    roiFocus?: string;
    roiFocusEn?: string;
    href?: string;
    coverImage?: ImageMetadata;
    imageKey?: 'human-ai' | 'cloud-servers' | 'satellite';
    featured?: boolean;
    price?: string;
    priceUnit?: string;
    pricePrefix?: string;
  };
}

const { service } = Astro.props;
const pricePrefix = service.pricePrefix ?? '$';
const inquire = service.price === 'Consultar';
const whatsappHref = site.author?.whatsapp;

const imageMap = {
  'human-ai': humanAi,
  'cloud-servers': cloudServers,
  satellite: satellite,
} as const;

const imageSrc = service.coverImage ?? (service.imageKey ? imageMap[service.imageKey] : humanAi);
const imageSizes =
  '(min-width: 1024px) 32vw, (min-width: 768px) 45vw, min(86vw, 300px)';

const isFullCardLink = !inquire && Boolean(service.href);
const linkHref = service.href ?? undefined;

const shellClass =
  'group relative flex aspect-[4/5] w-full shrink-0 snap-start flex-col overflow-hidden rounded-2xl bg-white shadow-sm transition-[transform,box-shadow] duration-300 hover:-translate-y-1 hover:shadow-md motion-reduce:hover:translate-y-0 motion-reduce:hover:shadow-sm motion-reduce:transition-none focus-within:shadow-md focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-orange-500';
---

{inquire ? (
  <div class={shellClass}>
    {service.href ? (
      <a
        href={service.href}
        class="flex min-h-0 flex-1 flex-col no-underline outline-none"
        aria-label={service.title}
      >
        <div class="relative min-h-0 flex-[3] basis-0 overflow-hidden bg-slate-100" aria-hidden="true">
          <Image
            src={imageSrc}
            alt=""
            width={800}
            height={1000}
            widths={[400, 560, 800]}
            sizes={imageSizes}
            loading="lazy"
            decoding="async"
            class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-[1.03] motion-reduce:transition-none motion-reduce:group-hover:scale-100"
          />
          {service.featured && (
            <span
              class="absolute right-3 top-3 rounded-full bg-orange-500 px-2.5 py-0.5 text-[10px] font-bold uppercase tracking-wide text-white"
              data-en="Most chosen"
              data-es="Más elegido"
            >
              Más elegido
            </span>
          )}
        </div>
        <div class="flex min-h-0 flex-[2] basis-0 flex-col gap-2 border-t border-slate-100 p-5">
          <p class="text-xs font-bold uppercase tracking-widest text-orange-500 transition-colors duration-300 group-hover:text-orange-600">
            <span data-es>Servicio</span>
            <span data-en class="hidden">Service</span>
          </p>
          <h3
            class="font-display text-xl font-semibold leading-tight tracking-tight text-slate-900 md:text-2xl"
            data-en={service.titleEn ?? service.title}
            data-es={service.title}
          >
            {service.title}
          </h3>
          <p
            class="line-clamp-2 text-sm leading-relaxed text-slate-600"
            data-en={service.shortDescriptionEn ?? service.shortDescription}
            data-es={service.shortDescription}
          >
            {service.shortDescription}
          </p>
          {(service.roiFocus || service.roiFocusEn) && (
            <p
              class="line-clamp-2 text-xs leading-relaxed text-slate-500"
              data-en={service.roiFocusEn ?? service.roiFocus}
              data-es={service.roiFocus ?? service.roiFocusEn}
            >
              {service.roiFocus ?? service.roiFocusEn}
            </p>
          )}
          <span class="mt-auto inline-flex items-center gap-1 pt-1 text-sm font-semibold text-orange-600">
            <span data-en="View service" data-es="Ver servicio">Ver servicio</span>
            <svg
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="shrink-0"
              aria-hidden="true"
            >
              <path d="M5 12h14M13 6l6 6-6 6" />
            </svg>
          </span>
        </div>
      </a>
    ) : (
      <>
        <div class="relative min-h-0 flex-[3] basis-0 overflow-hidden bg-slate-100" aria-hidden="true">
          <Image
            src={imageSrc}
            alt=""
            width={800}
            height={1000}
            widths={[400, 560, 800]}
            sizes={imageSizes}
            loading="lazy"
            decoding="async"
            class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-[1.03] motion-reduce:transition-none motion-reduce:group-hover:scale-100"
          />
          {service.featured && (
            <span
              class="absolute right-3 top-3 rounded-full bg-orange-500 px-2.5 py-0.5 text-[10px] font-bold uppercase tracking-wide text-white"
              data-en="Most chosen"
              data-es="Más elegido"
            >
              Más elegido
            </span>
          )}
        </div>
        <div class="flex min-h-0 flex-[2] basis-0 flex-col gap-2 border-t border-slate-100 p-5">
          <p class="text-xs font-bold uppercase tracking-widest text-orange-500 transition-colors duration-300 group-hover:text-orange-600">
            <span data-es>Servicio</span>
            <span data-en class="hidden">Service</span>
          </p>
          <h3
            class="font-display text-xl font-semibold leading-tight tracking-tight text-slate-900 md:text-2xl"
            data-en={service.titleEn ?? service.title}
            data-es={service.title}
          >
            {service.title}
          </h3>
          <p
            class="line-clamp-2 text-sm leading-relaxed text-slate-600"
            data-en={service.shortDescriptionEn ?? service.shortDescription}
            data-es={service.shortDescription}
          >
            {service.shortDescription}
          </p>
          {(service.roiFocus || service.roiFocusEn) && (
            <p
              class="line-clamp-2 text-xs leading-relaxed text-slate-500"
              data-en={service.roiFocusEn ?? service.roiFocus}
              data-es={service.roiFocus ?? service.roiFocusEn}
            >
              {service.roiFocus ?? service.roiFocusEn}
            </p>
          )}
        </div>
      </>
    )}

    <div
      class="mt-auto flex flex-shrink-0 flex-wrap gap-3 border-t border-slate-100 px-5 py-4"
      role="group"
      aria-label="Contacto comercial"
    >
      <a
        href="#contacto"
        class="text-sm font-semibold text-orange-600 underline-offset-2 hover:underline"
        data-en="Request pricing"
        data-es="Consultar precio"
      >
        Consultar precio
      </a>
      {whatsappHref && (
        <a
          href={whatsappHref}
          class="text-sm font-medium text-slate-600 underline-offset-2 hover:text-slate-900 hover:underline"
          target="_blank"
          rel="noopener noreferrer"
          data-en="WhatsApp"
          data-es="WhatsApp"
        >
          WhatsApp
        </a>
      )}
    </div>
  </div>
) : isFullCardLink ? (
  <a href={linkHref} class:list={[shellClass, 'no-underline']} aria-label={service.title}>
    <div class="relative min-h-0 flex-[3] basis-0 overflow-hidden bg-slate-100" aria-hidden="true">
      <Image
        src={imageSrc}
        alt=""
        width={800}
        height={1000}
        widths={[400, 560, 800]}
        sizes={imageSizes}
        loading="lazy"
        decoding="async"
        class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-[1.03] motion-reduce:transition-none motion-reduce:group-hover:scale-100"
      />
      {service.featured && (
        <span
          class="absolute right-3 top-3 rounded-full bg-orange-500 px-2.5 py-0.5 text-[10px] font-bold uppercase tracking-wide text-white"
          data-en="Most chosen"
          data-es="Más elegido"
        >
          Más elegido
        </span>
      )}
    </div>
    <div class="flex min-h-0 flex-[2] basis-0 flex-col gap-2 border-t border-slate-100 p-5">
      <p class="text-xs font-bold uppercase tracking-widest text-orange-500 transition-colors duration-300 group-hover:text-orange-600">
        <span data-es>Servicio</span>
        <span data-en class="hidden">Service</span>
      </p>
      <h3
        class="font-display text-xl font-semibold leading-tight tracking-tight text-slate-900 md:text-2xl"
        data-en={service.titleEn ?? service.title}
        data-es={service.title}
      >
        {service.title}
      </h3>
      <p
        class="line-clamp-2 text-sm leading-relaxed text-slate-600"
        data-en={service.shortDescriptionEn ?? service.shortDescription}
        data-es={service.shortDescription}
      >
        {service.shortDescription}
      </p>
      {(service.roiFocus || service.roiFocusEn) && (
        <p
          class="line-clamp-2 text-xs leading-relaxed text-slate-500"
          data-en={service.roiFocusEn ?? service.roiFocus}
          data-es={service.roiFocus ?? service.roiFocusEn}
        >
          {service.roiFocus ?? service.roiFocusEn}
        </p>
      )}
      {service.price && (
        <div class="mt-1">
          <span
            class="text-[10px] font-semibold uppercase tracking-wider text-slate-400"
            data-en="From"
            data-es="Desde"
          >
            Desde
          </span>
          <div class="flex items-baseline gap-1">
            <span class="font-display text-lg font-bold text-orange-600">
              {pricePrefix}{service.price}
            </span>
            {service.priceUnit && (
              <span class="text-xs font-medium text-slate-500">{service.priceUnit}</span>
            )}
          </div>
        </div>
      )}
      <span class="mt-auto inline-flex items-center gap-1 pt-2 text-sm font-semibold text-orange-600">
        <span data-en="View service" data-es="Ver servicio">Ver servicio</span>
        <svg
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="shrink-0"
          aria-hidden="true"
        >
          <path d="M5 12h14M13 6l6 6-6 6" />
        </svg>
      </span>
    </div>
  </a>
) : (
  <div class={shellClass}>
    <div class="relative min-h-0 flex-[3] basis-0 overflow-hidden bg-slate-100" aria-hidden="true">
      <Image
        src={imageSrc}
        alt=""
        width={800}
        height={1000}
        widths={[400, 560, 800]}
        sizes={imageSizes}
        loading="lazy"
        decoding="async"
        class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-[1.03] motion-reduce:transition-none motion-reduce:group-hover:scale-100"
      />
      {service.featured && (
        <span
          class="absolute right-3 top-3 rounded-full bg-orange-500 px-2.5 py-0.5 text-[10px] font-bold uppercase tracking-wide text-white"
          data-en="Most chosen"
          data-es="Más elegido"
        >
          Más elegido
        </span>
      )}
    </div>
    <div class="flex min-h-0 flex-[2] basis-0 flex-col gap-2 border-t border-slate-100 p-5">
      <p class="text-xs font-bold uppercase tracking-widest text-orange-500 transition-colors duration-300 group-hover:text-orange-600">
        <span data-es>Servicio</span>
        <span data-en class="hidden">Service</span>
      </p>
      <h3
        class="font-display text-xl font-semibold leading-tight tracking-tight text-slate-900 md:text-2xl"
        data-en={service.titleEn ?? service.title}
        data-es={service.title}
      >
        {service.title}
      </h3>
      <p
        class="line-clamp-2 text-sm leading-relaxed text-slate-600"
        data-en={service.shortDescriptionEn ?? service.shortDescription}
        data-es={service.shortDescription}
      >
        {service.shortDescription}
      </p>
      {(service.roiFocus || service.roiFocusEn) && (
        <p
          class="line-clamp-2 text-xs leading-relaxed text-slate-500"
          data-en={service.roiFocusEn ?? service.roiFocus}
          data-es={service.roiFocus ?? service.roiFocusEn}
        >
          {service.roiFocus ?? service.roiFocusEn}
        </p>
      )}
      {service.price && (
        <div class="mt-1">
          <span
            class="text-[10px] font-semibold uppercase tracking-wider text-slate-400"
            data-en="From"
            data-es="Desde"
          >
            Desde
          </span>
          <div class="flex items-baseline gap-1">
            <span class="font-display text-lg font-bold text-orange-600">
              {pricePrefix}{service.price}
            </span>
            {service.priceUnit && (
              <span class="text-xs font-medium text-slate-500">{service.priceUnit}</span>
            )}
          </div>
        </div>
      )}
    </div>
  </div>
)}
