---
import { Image } from 'astro:assets';
/** Fondo atmosférico del hero (LCP); asset dedicado home. */
import heroBackdrop from '../assets/home/hero-banner.webp';
---

<section
  class="section-dark relative min-h-screen overflow-hidden bg-slate-950"
  aria-labelledby="hero-heading"
>
  <div class="pointer-events-none absolute inset-0 z-0">
    <Image
      src={heroBackdrop}
      alt=""
      width={1536}
      height={1024}
      widths={[640, 768, 1024, 1280, 1536]}
      sizes="100vw"
      loading="eager"
      fetchpriority="high"
      decoding="async"
      class="h-full min-h-full w-full object-cover opacity-[0.28]"
    />
  </div>
  <div
    class="pointer-events-none absolute inset-0 z-[1] bg-gradient-to-b from-slate-950/90 via-slate-950/82 to-slate-950"
    aria-hidden="true"
  >
  </div>
  <div
    class="pointer-events-none absolute inset-x-0 bottom-0 z-[1] h-[58%] bg-gradient-to-t from-slate-950 from-35% via-slate-950/92 to-transparent"
    aria-hidden="true"
  >
  </div>
  <div
    class="pointer-events-none absolute inset-0 z-[2] opacity-[0.35] motion-reduce:hidden"
    aria-hidden="true"
    style="background-image:url(\"data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E\");"
  >
  </div>
  <div
    class="hero-glow pointer-events-none absolute -top-28 left-1/2 z-[2] h-[400px] w-[600px] -translate-x-1/2 motion-reduce:hidden"
    aria-hidden="true"
    style="background: radial-gradient(ellipse, hsla(var(--accent-h), var(--accent-s), 56%, 0.12) 0%, transparent 70%);"
  >
  </div>

  <div
    class="relative z-10 mx-auto grid min-h-[calc(100vh-4rem)] max-w-7xl grid-cols-1 items-center gap-10 px-6 py-16 lg:grid-cols-2 lg:gap-16 lg:py-24"
  >
    <div class="min-w-0 max-w-2xl">
      <h1
        id="hero-heading"
        class="font-display font-bold leading-[1.08] tracking-tight text-white"
        style="font-size: var(--text-5xl);"
      >
        <span data-es
          >Software a medida para <strong class="font-bold text-orange-400">multiplicar</strong> el ROI.</span
        >
        <span data-en class="hidden"
          >Custom software to <strong class="font-bold text-orange-400">multiply</strong> your ROI.</span
        >
      </h1>
      <p class="mt-6 max-w-lg font-body text-lg leading-relaxed text-slate-300">
        <span data-es
          >Reducimos costos operativos con automatización, IA y sistemas de gestión exclusivos. Tu negocio deja
          de pagar por herramientas y empieza a cobrar por resultados.</span
        >
        <span data-en class="hidden"
          >We cut operating costs with automation, AI and proprietary management systems. Your business stops
          paying for tools and starts earning from outcomes.</span
        >
      </p>
    </div>

    <div class="relative w-full max-w-xl justify-self-center lg:max-w-none lg:justify-self-end" aria-hidden="true">
      <div
        class="absolute -right-2 -top-3 z-10 flex items-center gap-2 rounded-xl border border-slate-600/80 bg-slate-900/95 px-3 py-2 shadow-lg backdrop-blur-sm"
      >
        <div
          class="flex h-7 w-7 items-center justify-center rounded-lg border border-emerald-500/30 bg-emerald-500/10 text-sm text-emerald-400"
        >
          ↑
        </div>
        <div class="leading-tight">
          <div class="text-xs font-medium text-slate-200">ROI este mes</div>
          <div class="text-[10px] text-emerald-400">+340% vs herramientas SaaS</div>
        </div>
      </div>

      <div
        class="overflow-hidden rounded-[14px] border border-slate-700/80 bg-slate-900 shadow-2xl shadow-orange-500/10"
      >
        <div class="flex items-center gap-2.5 border-b border-slate-700/80 bg-slate-950 px-4 py-3">
          <div class="flex gap-1.5">
            <div class="h-2 w-2 rounded-full bg-[#ff5f56]"></div>
            <div class="h-2 w-2 rounded-full bg-[#ffbd2e]"></div>
            <div class="h-2 w-2 rounded-full bg-[#27c93f]"></div>
          </div>
          <span class="ml-1 text-xs text-slate-500">Panel operativo — Double Click™</span>
        </div>
        <div class="flex flex-col gap-4 p-5">
          <div class="grid grid-cols-3 gap-2.5">
            <div class="rounded-[10px] border border-slate-700/80 bg-slate-800/80 p-3">
              <div class="mb-1 font-display text-xl font-bold leading-none text-orange-400">$847k</div>
              <div class="text-[10px] text-slate-500">Facturación mes</div>
            </div>
            <div class="rounded-[10px] border border-slate-700/80 bg-slate-800/80 p-3">
              <div class="mb-1 font-display text-xl font-bold leading-none text-emerald-400">+28%</div>
              <div class="text-[10px] text-slate-500">Retención clientes</div>
            </div>
            <div class="rounded-[10px] border border-slate-700/80 bg-slate-800/80 p-3">
              <div class="mb-1 font-display text-xl font-bold leading-none text-white">142</div>
              <div class="text-[10px] text-slate-500">Reservas activas</div>
            </div>
          </div>
          <div class="rounded-[10px] border border-slate-700/80 bg-slate-800/80 p-4">
            <div class="mb-3.5 flex items-center justify-between">
              <span class="text-xs font-medium text-slate-300">Ingresos por semana</span>
              <span
                class="rounded-md border border-emerald-500/25 bg-emerald-500/10 px-2 py-0.5 text-[10px] text-emerald-400"
                >↑ 18% vs mes ant.</span
              >
            </div>
            <div class="flex h-[70px] items-end gap-1.5">
              {[
                { h: '38%', type: 'semi' as const },
                { h: '52%', type: 'semi' as const },
                { h: '44%', type: 'semi' as const },
                { h: '61%', type: 'semi' as const },
                { h: '35%', type: 'base' as const },
                { h: '48%', type: 'base' as const },
                { h: '55%', type: 'base' as const },
                { h: '82%', type: 'active' as const },
              ].map((bar, i) => (
                <div class="flex h-full flex-1 flex-col items-center justify-end gap-1">
                  <div
                    class="w-full rounded-t-[4px]"
                    style={{
                      height: bar.h,
                      background:
                        bar.type === 'active'
                          ? 'var(--color-accent-400)'
                          : bar.type === 'semi'
                            ? 'hsla(var(--accent-h), var(--accent-s), 35%, 0.9)'
                            : 'hsla(215, 25%, 27%, 0.9)',
                    }}
                  />
                  <span class="text-[9px] text-slate-500">S{i + 1}</span>
                </div>
              ))}
            </div>
          </div>
          <div class="flex gap-2.5">
            <div class="flex-1 rounded-[10px] border border-slate-700/80 bg-slate-800/80 p-3">
              <div class="mb-2.5 text-[11px] text-slate-500">Actividad reciente</div>
              {[
                { color: '#34d399', text: 'Nueva reserva confirmada', time: '2m' },
                { color: 'var(--color-accent-400)', text: 'Pago procesado $3.200', time: '8m' },
                { color: '#34d399', text: 'Lead calificado por IA', time: '15m' },
              ].map((item) => (
                <div class="flex items-center gap-2 border-b border-slate-700/60 py-1.5 last:border-b-0">
                  <div
                    class="h-1.5 w-1.5 shrink-0 rounded-full"
                    style={{ background: item.color }}
                  />
                  <span class="flex-1 text-[11px] text-slate-300">{item.text}</span>
                  <span class="text-[10px] text-slate-500">{item.time}</span>
                </div>
              ))}
            </div>
            <div
              class="flex w-[130px] shrink-0 flex-col gap-2 rounded-[10px] border border-orange-500/20 bg-orange-500/5 p-3"
            >
              <div class="text-[10px] font-semibold uppercase tracking-widest text-orange-400">IA activa</div>
              <div class="font-display text-[22px] font-bold text-orange-400">24/7</div>
              <div class="text-[10px] leading-snug text-slate-500">Respondiendo consultas sin intervención manual.</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
