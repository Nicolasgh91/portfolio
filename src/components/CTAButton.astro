---
interface Props {
  href: string;
  label: string;
  labelEn: string;
  variant?: 'primary' | 'secondary' | 'inverse';
  arrow?: boolean;
  class?: string;
}

const { href, label, labelEn, variant = 'primary', arrow = true, class: className = '' } = Astro.props;

const base =
  'inline-flex items-center justify-center gap-2 rounded-lg px-8 py-4 text-lg font-semibold no-underline transition-colors focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2';

const variants = {
  primary:
    'bg-orange-500 text-white hover:bg-orange-600 focus-visible:outline-orange-400',
  secondary: 'bg-slate-800 text-white hover:bg-slate-700 focus-visible:outline-slate-400',
  inverse:
    'bg-white text-orange-600 hover:bg-slate-50 focus-visible:outline-white',
} as const;
---

<a href={href} class:list={[base, variants[variant], className]}>
  <span data-es>{label}</span>
  <span data-en class="hidden">{labelEn}</span>
  {arrow && (
    <svg
      width="20"
      height="20"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2.2"
      stroke-linecap="round"
      stroke-linejoin="round"
      class="shrink-0"
      aria-hidden="true"
    >
      <path d="M5 12h14M13 6l6 6-6 6" />
    </svg>
  )}
</a>
