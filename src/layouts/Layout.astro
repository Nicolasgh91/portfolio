---
import '../styles/tokens.css';
import Analytics from '@vercel/analytics/astro';
import Footer from '../components/Footer.astro';
import BackToTop from '../components/BackToTop.astro';
import site from '../data/site.json';

interface Props {
  title: string;
  description: string;
  lang?: 'es' | 'en';
  ogImage?: string;
  /** MIME type for og:image (e.g. image/webp). If omitted, inferred from ogImage path extension. */
  ogImageType?: string;
  ogImageWidth?: string | number;
  ogImageHeight?: string | number;
}

const {
  title,
  description,
  lang = 'es',
  ogImage = '/og-desktop.png',
  ogImageType: ogImageTypeProp,
  ogImageWidth: ogImageWidthProp,
  ogImageHeight: ogImageHeightProp,
} = Astro.props;

const canonical = Astro.url.href;
const siteName = 'Nicolás Hruszczak';
const siteUrl = 'https://escalatunegocioconia.com';

function inferOgImageType(path: string): string {
  const lower = path.split('?')[0].toLowerCase();
  if (lower.endsWith('.webp')) return 'image/webp';
  if (lower.endsWith('.jpg') || lower.endsWith('.jpeg')) return 'image/jpeg';
  if (lower.endsWith('.gif')) return 'image/gif';
  return 'image/png';
}

const ogImageType = ogImageTypeProp ?? inferOgImageType(ogImage);
const ogImageWidth = ogImageWidthProp ?? 1366;
const ogImageHeight = ogImageHeightProp ?? 768;
---

<!doctype html>
<html lang={lang} class="dark no-js">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="author" content="Nicolás Hruszczak" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph base -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`${siteUrl}${ogImage}`} />
    <meta property="og:image:width" content={String(ogImageWidth)} />
    <meta property="og:image:height" content={String(ogImageHeight)} />
    <meta property="og:image:type" content={ogImageType} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:locale" content="es_AR" />
    <meta property="og:locale:alternate" content="en_US" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${siteUrl}${ogImage}`} />

    <meta name="theme-color" content="#FBBF24" />

    <!-- SEC-005: Content Security Policy is now served as a header via vercel.json.
         Previous <meta> tag required 'unsafe-inline' on script-src; inline scripts
         have been extracted to /scripts/*.js so CSP can drop that directive. -->

    <!-- hreflang -->
    <link rel="alternate" hreflang="es" href={canonical} />
    <link rel="alternate" hreflang="en" href={canonical} />
    <link rel="alternate" hreflang="x-default" href={canonical} />

    <!-- Favicons -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <!-- Sitemap -->
    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- JSON-LD global: Person (FT-06: sameAs y knowsAbout desde site.json) -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Person",
      "name": site.author.name,
      "jobTitle": "Analista Funcional y Desarrollador Full Stack",
      "description": "Gestión de tecnología, arquitectura de software e implementación de IA para soluciones escalables.",
      "url": site.author.siteUrl,
      "sameAs": Object.values(site.social),
      "knowsAbout": site.stack
    })} />

    <!-- JSON-LD global: ProfessionalService -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "ProfessionalService",
        "name": "Nicolás Hruszczak — Desarrollo de Software",
        "description": "Software a medida, automatización inteligente y posicionamiento SEO/GEO para empresas y pymes.",
        "url": "https://escalatunegocioconia.com",
        "areaServed": ["Argentina", "United States"],
        "availableLanguage": ["Spanish", "English"],
        "serviceType": [
          "Desarrollo de software a medida",
          "Automatización con IA",
          "Auditoría y optimización de procesos",
          "Posicionamiento SEO/GEO"
        ]
      }
    </script>

    <!-- SLOT: JSON-LD y meta adicional por página (artículos, etc.) -->
    <slot name="head" />

    <title>{title}</title>

    <!-- Tema + strip no-js + no-motion antes del primer paint.
         Sync script (no defer/async) para evitar FOUC en el cambio de tema. -->
    <script src="/scripts/boot.js" is:inline></script>

    <!-- Controladores globales (nhTheme, nhLang, nhA11y) + event delegation.
         defer: se ejecuta tras parsear el DOM, antes de DOMContentLoaded. -->
    <script src="/scripts/controllers.js" defer is:inline></script>

    <!-- Scroll reveal IntersectionObserver; depende de nhA11y (controllers.js). -->
    <script src="/scripts/reveal.js" defer is:inline></script>
  </head>

  <body>
    <a href="#main-content" class="skip-link">Saltar al contenido principal</a>

    <slot />
    <BackToTop />
    <Footer />
    <Analytics />

    <!-- Controladores globales (nhTheme/nhLang/nhA11y) y reveal observer cargados
         desde /scripts/*.js en <head>. Ver public/scripts/ y vercel.json CSP. -->

    <script>
      (function() {
        function initChatWidget() {
          const iframe = document.createElement('iframe');
          iframe.src = '/chatbot/widget/index.html';
          iframe.setAttribute('allowtransparency', 'true');
          iframe.setAttribute('title', 'Asistente virtual');
          iframe.setAttribute('aria-label', 'Chat de asistencia');

          iframe.style.cssText = [
            'position:fixed',
            'bottom:0',
            'right:0',
            'width:84px',
            'height:84px',
            'border:none',
            'z-index:9999',
            'background:transparent',
          ].join(';');
          document.body.appendChild(iframe);

          let chatOpen = false;

          window.addEventListener('message', (e) => {
            if (e.source !== iframe.contentWindow) return;
            if (e.data?.chat === 'open') {
              chatOpen = true;
              iframe.style.width = '420px';
              iframe.style.height = '680px';
            }
            if (e.data?.chat === 'close') {
              chatOpen = false;
              iframe.style.width = '84px';
              iframe.style.height = '84px';
            }
          });

          // L-14: solo notificamos "chat:close" cuando el widget está abierto.
          // Antes se posteaba en cada click del documento, independientemente
          // del estado del iframe.
          document.addEventListener('click', () => {
            if (!chatOpen) return;
            try { iframe.contentWindow.postMessage('chat:close', '*'); } catch(e) {}
          });
        }

        // Defer chat widget until browser is idle to reduce TBT
        if ('requestIdleCallback' in window) {
          requestIdleCallback(initChatWidget, { timeout: 3500 });
        } else {
          setTimeout(initChatWidget, 3500);
        }
      })();
    </script>
  </body>
</html>