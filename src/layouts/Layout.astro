---
import "../styles/tokens.css";
import Analytics from "@vercel/analytics/astro";
import SpeedInsights from "@vercel/speed-insights/astro";
import Footer from "../components/Footer.astro";
import BackToTop from "../components/BackToTop.astro";
import site from "../data/site.json";
import { getAlternatePathname, localeFromPathname } from "../lib/locale-path";

interface Props {
  title: string;
  description: string;
  titleEn?: string;
  descriptionEn?: string;
  lang?: "es" | "en";
  ogImage?: string;
  /** MIME type for og:image (e.g. image/webp). If omitted, inferred from ogImage path extension. */
  ogImageType?: string;
  ogImageWidth?: string | number;
  ogImageHeight?: string | number;
}

const {
  title,
  description,
  titleEn,
  descriptionEn,
  lang,
  ogImage = "/og-desktop.png",
  ogImageType: ogImageTypeProp,
  ogImageWidth: ogImageWidthProp,
  ogImageHeight: ogImageHeightProp,
} = Astro.props;

const siteName = "Nicolás Hruszczak";
const siteUrl = "https://escalatunegocioconia.com";
const pathname = Astro.url.pathname;
const locale = localeFromPathname(pathname);
const alternatePathname = getAlternatePathname(pathname);
const canonical = new URL(pathname, siteUrl).href;
const englishHref =
  locale === "en" ? canonical : new URL(alternatePathname, siteUrl).href;
const spanishHref =
  locale === "es" ? canonical : new URL(alternatePathname, siteUrl).href;
const xDefaultHref = spanishHref;
const resolvedTitle = locale === "en" ? (titleEn ?? title) : title;
const resolvedDescription =
  locale === "en" ? (descriptionEn ?? description) : description;
const skipLinkLabel =
  locale === "en" ? "Skip to main content" : "Saltar al contenido principal";
const personJobTitle =
  locale === "en"
    ? "Functional Analyst and Full Stack Developer"
    : "Analista Funcional y Desarrollador Full Stack";
const personDescription =
  locale === "en"
    ? "Technology management, software architecture, and AI implementation for scalable solutions."
    : "Gestión de tecnología, arquitectura de software e implementación de IA para soluciones escalables.";
const serviceName =
  locale === "en"
    ? "Nicolás Hruszczak — Software Development"
    : "Nicolás Hruszczak — Desarrollo de Software";
const serviceDescription =
  locale === "en"
    ? "Custom software, intelligent automation, and SEO/GEO positioning for companies and SMEs."
    : "Software a medida, automatización inteligente y posicionamiento SEO/GEO para empresas y pymes.";
const serviceTypes =
  locale === "en"
    ? [
        "Custom software development",
        "AI automation",
        "Process audit and optimization",
        "SEO/GEO positioning",
      ]
    : [
        "Desarrollo de software a medida",
        "Automatización con IA",
        "Auditoría y optimización de procesos",
        "Posicionamiento SEO/GEO",
      ];

function inferOgImageType(path: string): string {
  const lower = path.split("?")[0].toLowerCase();
  if (lower.endsWith(".webp")) return "image/webp";
  if (lower.endsWith(".jpg") || lower.endsWith(".jpeg")) return "image/jpeg";
  if (lower.endsWith(".gif")) return "image/gif";
  return "image/png";
}

const ogImageType = ogImageTypeProp ?? inferOgImageType(ogImage);
const ogImageWidth = ogImageWidthProp ?? 1366;
const ogImageHeight = ogImageHeightProp ?? 768;
---

<!doctype html>
<html lang={lang ?? locale} class="dark no-js">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={resolvedDescription} />
    <meta name="author" content="Nicolás Hruszczak" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph base -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={resolvedTitle} />
    <meta property="og:description" content={resolvedDescription} />
    <meta property="og:image" content={`${siteUrl}${ogImage}`} />
    <meta property="og:image:width" content={String(ogImageWidth)} />
    <meta property="og:image:height" content={String(ogImageHeight)} />
    <meta property="og:image:type" content={ogImageType} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:locale" content="es_AR" />
    <meta property="og:locale:alternate" content="en_US" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={resolvedTitle} />
    <meta name="twitter:description" content={resolvedDescription} />
    <meta name="twitter:image" content={`${siteUrl}${ogImage}`} />

    <!-- allow-raw-hex: theme-color does not accept CSS vars; mirrors --color-accent-300. -->
    <meta name="theme-color" content="#FBBF24" />

    <!-- SEC-005: Content Security Policy is now served as a header via vercel.json.
         Previous <meta> tag required 'unsafe-inline' on script-src; inline scripts
         have been extracted to /scripts/*.js so CSP can drop that directive. -->

    <!-- hreflang -->
    <link rel="alternate" hreflang="es" href={spanishHref} />
    <link rel="alternate" hreflang="en" href={englishHref} />
    <link rel="alternate" hreflang="x-default" href={xDefaultHref} />

    <!-- Favicons -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <!-- Sitemap -->
    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- JSON-LD global: Person (FT-06: sameAs y knowsAbout desde site.json) -->
    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "Person",
        name: site.author.name,
        jobTitle: personJobTitle,
        description: personDescription,
        url: site.author.siteUrl,
        sameAs: Object.values(site.social),
        knowsAbout: site.stack,
      })}
    />

    <!-- JSON-LD global: ProfessionalService -->
    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "ProfessionalService",
        name: serviceName,
        description: serviceDescription,
        url: siteUrl,
        areaServed: ["Argentina", "United States"],
        availableLanguage: ["Spanish", "English"],
        serviceType: serviceTypes,
      })}
    />

    <!-- SLOT: JSON-LD y meta adicional por página (artículos, etc.) -->
    <slot name="head" />

    <title>{resolvedTitle}</title>

    <!-- Tema + strip no-js + no-motion antes del primer paint.
         Sync script (no defer/async) para evitar FOUC en el cambio de tema. -->
    <script src="/scripts/boot.js" is:inline></script>

    <!-- Controladores globales (nhTheme, nhLang, nhA11y) + event delegation.
         defer: se ejecuta tras parsear el DOM, antes de DOMContentLoaded. -->
    <script src="/scripts/controllers.js" defer is:inline></script>

    <!-- Scroll reveal IntersectionObserver; depende de nhA11y (controllers.js). -->
    <script src="/scripts/reveal.js" defer is:inline></script>

    <!-- Chat widget loader (idle-callback + lazy iframe). External so the HTML
         stays small and CSP can keep script-src 'self' without 'unsafe-inline'. -->
    <script src="/scripts/chat-widget.js" defer is:inline></script>
  </head>

  <body>
    <a href="#main-content" class="skip-link">{skipLinkLabel}</a>

    <slot />
    <BackToTop />
    <Footer />
    <Analytics />
    <SpeedInsights />

    <!-- Controladores globales (nhTheme/nhLang/nhA11y), reveal observer y chat
         widget cargados desde /scripts/*.js en <head>. Ver public/scripts/ y
         vercel.json CSP. -->
  </body>
</html>
