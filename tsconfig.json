{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "types": ["node"]
  },
  "include": [
    "schemas/**/*.ts",
    "src/**/*.ts",
    "src/**/*.d.ts",
    ".astro/types.d.ts"
  ]
}
